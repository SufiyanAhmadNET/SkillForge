@{
    Layout = "~/Areas/Pubic/Views/Shared/_AuthLayout.cshtml";
    ViewData["Title"] = "Register";
    ViewData["RoleClass"] = "role-student";
}

@* ================= Registration Section ================= *@

<section class="d-flex align-items-center justify-content-center py-3 bg-light flex-grow-1">

    <div class="card auth-card auth-card-wide shadow-sm">
        <div class="text-center mb-3">
            <h2 class="fw-bold mb-0">Create Account</h2>
            <p class="text-muted small">Join 50,000+ students already learning on SkillForge</p>
        </div>

        <div class="row g-0">
            <!-- Left Column: Main Form -->
            <div class="col-md-7 auth-col-left">
                <form method="post" id="registerForm" onsubmit="return handleAuthSubmit('registerForm', 'Register')"
                      asp-area="User" asp-controller="Auth" asp-action="StudentRegistration">

                    @Html.AntiForgeryToken()
                    <input type="hidden" name="role" value="Student" />

                    @* otp trigger *@
                    @if (TempData["VerifyEmail"] != null)
                    {
                        <script>
                            window.addEventListener("load", function () {
                                openOtpModal("@TempData["VerifyEmail"]");
                            });
                        </script>
                    }

                    <div class="mb-2">
                        <label class="form-label">Email address</label>
                        <input type="email" class="form-control" name="email" placeholder="you@example.com" required>
                    </div>

                    <div class="mb-2">
                        <label class="form-label">Password</label>
                        <input type="password" class="form-control" name="password" placeholder="Create a strong password" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Confirm Password</label>
                        <input type="password" class="form-control" name="confirmpassword" placeholder="Repeat your password" required>
                    </div>

                    <button type="submit" class="btn-auth">
                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                        <span class="btn-text">Register Now</span>
                    </button>
                </form>
            </div>

            <!-- Right Column: Secondary Actions -->
            <div class="col-md-5 auth-col-right">
                <div class="text-center w-100">
                    <p class="text-muted small fw-bold mb-2">QUICK SIGNUP</p>
                    
                    <div class="google-auth-container">
                        <div id="g_id_onload"
                             data-client_id="@Configuration["GoogleAuth:ClientId"]"
                             data-login_uri="/User/Auth/GoogleLogin"
                             data-auto_prompt="false">
                        </div>

                        <div class="g_id_signin"
                             data-type="standard"
                             data-shape="rectangular"
                             data-theme="outline"
                             data-text="signup_with"
                             data-size="large"
                             data-width="100%">
                        </div>
                    </div>

                    <p class="text-muted small mt-3 mb-3">
                        Already have an account? 
                        <a asp-area="User" asp-controller="Auth" asp-action="StudentLogin" class="text-decoration-none fw-bold ms-1" style="color:var(--orange);">Login</a>
                    </p>

                    <div class="role-switcher border-0 pt-0">
                        <p class="role-switcher-label">REGISTER AS</p>
                        <div class="role-switcher-links">
                            <a asp-area="Instructor" asp-controller="Auth" asp-action="InstructorRegistration" class="role-link">
                                <i class="bi bi-person-video3"></i> Instructor
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @await Html.PartialAsync("_OtpModal")
    </div>
</section>

<script>
    // Google login logic handled by data-login_uri

    function triggerOtpFlow() {
        setTimeout(() => {
            const email = document.querySelector("input[name='email']").value;

            if (email) {
                openOtpModal(email);
            }
        }, 500);
    }
</script>