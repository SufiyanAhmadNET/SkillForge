@{
    Layout = "~/Areas/Pubic/Views/Shared/_AuthLayout.cshtml";
    ViewData["Title"] = "Recover Password";
    ViewData["RoleClass"] = "role-student";
}

@* ================= Recovery Section ================= *@

<section class="d-flex align-items-center justify-content-center py-5 bg-light flex-grow-1">
    <div class="card auth-card shadow-sm">
        
        <div class="text-center mb-4">
            <div class="d-inline-flex align-items-center justify-content-center mb-3" style="width: 64px; height: 64px; background: rgba(var(--role-color-rgb), 0.1); border-radius: 50%;">
                <i class="bi bi-shield-lock fs-2" style="color: var(--role-color);"></i>
            </div>
            <h4 class="fw-bold mb-1">Recover Your Password</h4>
            <p class="text-muted small">Enter your email , we will send OTP.</p>
        </div>

        <div id="recoveryForm">
            @await Html.PartialAsync("_ForgotPasswordPartial", "")

            <div class="text-center mt-4 pt-3 border-top">
                <a asp-action="StudentLogin" class="text-decoration-none small fw-bold text-muted">
                    <i class="bi bi-arrow-left me-1"></i> Back to Login
                </a>
            </div>
        </div>
    </div>
</section>
