@{
    Layout = "~/Areas/Pubic/Views/Shared/_AuthLayout.cshtml";
    ViewData["Title"] = "Recover Password";
    ViewData["RoleClass"] = "role-student";
}

<section class="d-flex align-items-center justify-content-center py-5 bg-light" style="min-height: 80vh;">
    <div class="card auth-card shadow-sm p-4 border-premium-orange" style="max-width: 450px; width: 100%; border-radius: 16px;">
        
        <div class="text-center mb-4">
            <div class="d-inline-flex align-items-center justify-content-center bg-orange-soft rounded-circle mb-3" style="width: 64px; height: 64px;">
                <i class="bi bi-shield-lock text-orange fs-2"></i>
            </div>
            <h4 class="fw-bold">Password Recovery</h4>
            <p class="text-muted small">Enter your email to reset your account password</p>
        </div>

        <div id="recoveryForm">
            @await Html.PartialAsync("_ForgotPasswordPartial", "")

            <div class="text-center mt-4 pt-2 border-top">
                <a asp-action="StudentLogin" class="text-decoration-none small fw-bold text-muted">
                    <i class="bi bi-arrow-left me-1"></i> Back to Login
                </a>
            </div>
        </div>
    </div>
</section>

<style>
    .border-premium-orange { border: 1px solid #ffe0b2 !important; }
    .bg-orange-soft { background-color: #fff3e0; }
    .text-orange { color: #ff6b00; }
</style>
