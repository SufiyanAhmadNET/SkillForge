@{
    Layout = "/Areas/User/Views/Shared/_StudentLayout.cshtml";
}

<div class="mb-4">
    <h4 class="fw-bold mb-0">Orders & Billing</h4>
    <span class="text-muted small">Your purchase history</span>
</div>

<div class="row g-4">

    <!-- LEFT: order list -->
    <div class="col-lg-8">
        <div class="section-card">
            <div class="section-card-title">Purchase History</div>

            <!-- order 1 -->
            <div class="order-row">
                <img class="order-thumb"
                     src="https://images.unsplash.com/photo-1498050108023-c5249f4df085?w=200" alt="">
                <div class="flex-grow-1">
                    <div class="order-title">Full Stack Web Development</div>
                    <div class="order-meta">Order #SF-1001 · Jan 5, 2026 · UPI</div>
                </div>
                <div class="text-end flex-shrink-0">
                    <div class="fw-bold mb-1">₹4,999</div>
                    <span class="badge-paid">Paid</span>
                </div>
                <a href="#" class="invoice-link ms-2">
                    <i class="bi bi-download me-1"></i>Invoice
                </a>
            </div>

            <!-- order 2 -->
            <div class="order-row">
                <img class="order-thumb"
                     src="https://images.unsplash.com/photo-1677442135703-1787eea5ce01?w=200" alt="">
                <div class="flex-grow-1">
                    <div class="order-title">Machine Learning A–Z</div>
                    <div class="order-meta">Order #SF-1002 · Jan 8, 2026 · Razorpay</div>
                </div>
                <div class="text-end flex-shrink-0">
                    <div class="fw-bold mb-1">₹5,999</div>
                    <span class="badge-paid">Paid</span>
                </div>
                <a href="#" class="invoice-link ms-2">
                    <i class="bi bi-download me-1"></i>Invoice
                </a>
            </div>

            <!-- order 3 -->
            <div class="order-row">
                <img class="order-thumb"
                     src="https://images.unsplash.com/photo-1451187580459-43490279c0fa?w=200" alt="">
                <div class="flex-grow-1">
                    <div class="order-title">AWS Cloud Practitioner</div>
                    <div class="order-meta">Order #SF-1003 · Jan 10, 2026 · Card</div>
                </div>
                <div class="text-end flex-shrink-0">
                    <div class="fw-bold mb-1">₹4,499</div>
                    <span class="badge-paid">Paid</span>
                </div>
                <a href="#" class="invoice-link ms-2">
                    <i class="bi bi-download me-1"></i>Invoice
                </a>
            </div>

            <!-- order 4 — completed -->
            <div class="order-row">
                <img class="order-thumb"
                     src="https://images.unsplash.com/photo-1461749280684-dccba630e2f6?w=200" alt="">
                <div class="flex-grow-1">
                    <div class="order-title">UI/UX Design Fundamentals</div>
                    <div class="order-meta">Order #SF-1000 · Dec 20, 2025 · UPI</div>
                </div>
                <div class="text-end flex-shrink-0">
                    <div class="fw-bold mb-1">₹2,999</div>
                    <span class="badge-paid">Paid</span>
                </div>
                <a href="#" class="invoice-link ms-2">
                    <i class="bi bi-download me-1"></i>Invoice
                </a>
            </div>

        </div>
    </div>

    <!-- RIGHT: billing summary -->
    <div class="col-lg-4">
        <div class="section-card">
            <div class="section-card-title">Billing Summary</div>
            <div class="billing-summary mb-3">
                <div class="d-flex justify-content-between mb-2 small">
                    <span class="text-muted">Total Courses</span>
                    <span class="fw-semibold">4</span>
                </div>
                <div class="d-flex justify-content-between mb-2 small">
                    <span class="text-muted">Total Spent</span>
                    <span class="fw-semibold">₹18,496</span>
                </div>
                <div class="d-flex justify-content-between small">
                    <span class="text-muted">Total Saved</span>
                    <span class="fw-semibold" style="color:#2e7d32">₹18,502</span>
                </div>
            </div>
            <p class="text-muted small mb-3">
                All purchases are covered by a 30-day money-back guarantee.
            </p>
            <a href="#" class="btn-orange-outline w-100 text-center d-block" style="font-size:.85rem;text-decoration:none;padding:8px">
                <i class="bi bi-headset me-1"></i> Request Refund
            </a>
        </div>
    </div>

</div>

@*  Orders CSS *@
<style>
    /* order row */
    .order-row {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 16px 0;
        border-bottom: 1px solid #f0f0f0;
    }

        .order-row:last-child {
            border-bottom: none;
        }

    .order-thumb {
        width: 64px;
        height: 48px;
        border-radius: 8px;
        object-fit: cover;
        flex-shrink: 0;
    }

    .order-title {
        font-size: .9rem;
        font-weight: 600;
        margin-bottom: 2px;
    }

    .order-meta {
        font-size: .75rem;
        color: var(--muted);
    }

    /* status badge */
    .badge-paid {
        background: #e8f5e9;
        color: #2e7d32;
        font-size: .72rem;
        font-weight: 600;
        padding: 3px 10px;
        border-radius: 20px;
    }

    .badge-refunded {
        background: #fff3e0;
        color: #e65100;
        font-size: .72rem;
        font-weight: 600;
        padding: 3px 10px;
        border-radius: 20px;
    }

    /* invoice download link */
    .invoice-link {
        font-size: .78rem;
        color: var(--orange);
        text-decoration: none;
        font-weight: 500;
        white-space: nowrap;
    }

        .invoice-link:hover {
            text-decoration: underline;
        }

    /* summary box */
    .billing-summary {
        background: linear-gradient(135deg, var(--orange-soft), #fff);
        border: 1.5px solid rgba(255,122,0,.15);
        border-radius: 14px;
        padding: 20px;
    }
</style>