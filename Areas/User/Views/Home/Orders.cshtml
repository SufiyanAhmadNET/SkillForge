@model SkillForge.Models.OrderHistoryVM
@{
    Layout = "/Areas/User/Views/Shared/_StudentLayout.cshtml";
    ViewData["Title"] = "Orders & Billing";
}

<div class="mb-4">
    <span class="text-muted small">Your purchase history</span>
</div>

<div class="row g-4">

    <!-- LEFT: order list -->
    <div class="col-lg-8">
        <div class="section-card">
            <div class="section-card-title">Purchase History</div>

            @if (Model.Orders != null && Model.Orders.Any())
            {
                @foreach (var order in Model.Orders)
                {
                    <a href="/User/Home/CourseDetails?id=@order.CourseId" class="text-decoration-none text-dark">
                        <div class="order-row">
                            <img class="order-thumb"
                                 src="@(string.IsNullOrEmpty(order.ThumbnailUrl) ? "/uploads/thumbnails/Default_Thumbnail.avif" : order.ThumbnailUrl)" 
                                 alt="@order.CourseTitle">
                            <div class="flex-grow-1">
                                <div class="order-title">@order.CourseTitle</div>
                                <div class="order-meta">
                                    Order #@(order.RazorpayOrderId != "N/A" ? (order.RazorpayOrderId.Length > 8 ? order.RazorpayOrderId.Substring(order.RazorpayOrderId.Length - 8) : order.RazorpayOrderId) : order.OrderId.ToString()) 
                                    · @order.OrderDate.ToString("MMM dd, yyyy") 
                                    · @order.PaymentMethod
                                </div>
                            </div>
                            <div class="text-end flex-shrink-0">
                                <div class="fw-bold mb-1">₹@order.Amount.ToString("N0")</div>
                                <span class="@(order.PaymentStatus == "Success" ? "badge-paid" : "badge-refunded")">
                                    @order.PaymentStatus
                                </span>
                            </div>
                            <span class="invoice-link ms-3">
                                <i class="bi bi-download me-1"></i>Invoice
                            </span>
                        </div>
                    </a>
                }
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-cart-x display-4 text-muted mb-3"></i>
                    <p class="text-muted">You haven't purchased any courses yet.</p>
                    <a asp-action="Courses" class="btn btn-orange btn-sm">Browse Courses</a>
                </div>
            }

        </div>
    </div>

    <!-- RIGHT: billing summary -->
    <div class="col-lg-4">
        <div class="section-card">
            <div class="section-card-title">Billing Summary</div>
            <div class="billing-summary mb-3">
                <div class="d-flex justify-content-between mb-2 small">
                    <span class="text-muted">Total Courses</span>
                    <span class="fw-semibold">@Model.TotalCourses</span>
                </div>
                <div class="d-flex justify-content-between mb-2 small">
                    <span class="text-muted">Total Spent</span>
                    <span class="fw-semibold">₹@Model.TotalSpent.ToString("N0")</span>
                </div>
                <div class="d-flex justify-content-between small">
                    <span class="text-muted">Total Saved</span>
                    <span class="fw-semibold" style="color:#2e7d32">₹@Model.TotalSaved.ToString("N0")</span>
                </div>
            </div>
            <p class="text-muted small mb-3">
                All purchases are covered by a 30-day money-back guarantee.
            </p>
            <a href="#" class="btn-orange-outline w-100 text-center d-block" style="font-size:.85rem;text-decoration:none;padding:8px">
                <i class="bi bi-headset me-1"></i> Request Refund
            </a>
        </div>
    </div>

</div>

@*  Orders CSS *@
<style>
    /* order row */
    .order-row {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 16px 0;
        border-bottom: 1px solid #f0f0f0;
    }

        .order-row:last-child {
            border-bottom: none;
        }

    .order-thumb {
        width: 64px;
        height: 48px;
        border-radius: 8px;
        object-fit: cover;
        flex-shrink: 0;
    }

    .order-title {
        font-size: .9rem;
        font-weight: 600;
        margin-bottom: 2px;
    }

    .order-meta {
        font-size: .75rem;
        color: var(--muted);
    }

    /* status badge */
    .badge-paid {
        background: #e8f5e9;
        color: #2e7d32;
        font-size: .72rem;
        font-weight: 600;
        padding: 3px 10px;
        border-radius: 20px;
    }

    .badge-refunded {
        background: #fff3e0;
        color: #e65100;
        font-size: .72rem;
        font-weight: 600;
        padding: 3px 10px;
        border-radius: 20px;
    }

    /* invoice download link */
    .invoice-link {
        font-size: .78rem;
        color: var(--orange);
        text-decoration: none;
        font-weight: 500;
        white-space: nowrap;
    }

        .invoice-link:hover {
            text-decoration: underline;
        }

    /* summary box */
    .billing-summary {
        background: linear-gradient(135deg, var(--orange-soft), #fff);
        border: 1.5px solid rgba(255,122,0,.15);
        border-radius: 14px;
        padding: 20px;
    }

    .btn-orange {
        background-color: var(--orange);
        color: white;
        border: none;
    }
    .btn-orange:hover {
        background-color: #e66e00;
        color: white;
    }
</style>