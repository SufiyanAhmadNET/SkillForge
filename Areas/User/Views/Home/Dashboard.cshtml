@model SkillForge.Areas.User.Models.DashboardVM

@{
    Layout = "/Areas/User/Views/Shared/_StudentLayout.cshtml";
    ViewData["Title"] = "Dashboard";
}

@* email not verified *@
@if (TempData["Verify"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show py-4 small" role="alert">
        <i class="bi bi-envelope-exclamation me-1"></i> @TempData["NotVerified"]
        <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
}
 
    <!-- welcome banner -->
    <div class="welcome-banner" id="welcomeBanner" style="display: none;">
        <button type="button" class="btn-close btn-close-white position-absolute top-0 end-0 m-3" 
                onclick="closeWelcomeBanner()" 
                aria-label="Close"></button>
        <div class="row align-items-center">
            <div class="col">
            <h4 class="fw-bold mb-1">Welcome back, <span>@Model.FirstName</span> 👋</h4>
                <p class="mb-3 opacity-75">Ready to continue your learning journey today?</p>
                <a asp-area="User" asp-controller="Home" asp-action="EnrolledCourses"
                class="btn btn-light btn-sm px-4 fw-semibold">
                    Continue Learning
                </a>
            </div>
            <div class="col-auto d-none d-md-block">
                <i class="bi bi-fire" style="font-size:4rem;opacity:.3"></i>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // check if banner was closed in this session
            if (!sessionStorage.getItem('welcomeBannerClosed')) {
                document.getElementById('welcomeBanner').style.display = 'block';
            }
        });

        function closeWelcomeBanner() {
            document.getElementById('welcomeBanner').style.display = 'none';
            // set flag to hide for the rest of the session
            sessionStorage.setItem('welcomeBannerClosed', 'true');
        }
    </script>

    <!-- stat cards -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-xl-3">
            <div class="stat-card">
                <div class="stat-icon" style="background:#fff3e0">
                    <i class="bi bi-play-btn-fill" style="color:var(--orange)"></i>
                </div>
                <div><h4>@Model.EnrolledCount</h4><p>Enrolled Courses</p></div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="stat-card">
                <div class="stat-icon" style="background:#e8f5e9">
                    <i class="bi bi-heart-fill" style="color:#e53935"></i>
                </div>
                <div><h4>@Model.WishlistCount</h4><p>Wishlist</p></div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="stat-card">
                <div class="stat-icon" style="background:#e3f2fd">
                    <i class="bi bi-award-fill" style="color:#1565c0"></i>
                </div>
                <div><h4>@Model.CertificateCount</h4><p>Certificates</p></div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="stat-card">
                <div class="stat-icon" style="background:#fce4ec">
                    <i class="bi bi-clock-fill" style="color:#c62828"></i>
                </div>
                <div><h4>0h</h4><p>Hours Learned</p></div>
            </div>
        </div>
    </div>

    <!-- main grid -->
    <div class="row g-4">

        <div class="col-lg-8">

            <div class="section-card">
                <div class="section-card-title">
                    Continue Learning <a asp-action="EnrolledCourses">View all →</a>
                </div>
                <div class="row g-3">
                    @if (Model.EnrolledCourses != null && Model.EnrolledCourses.Any())
                    {
                        @foreach (var course in Model.EnrolledCourses)
                        {
                            <div class="col-md-6">
                                <div class="enrolled-card h-100">
                                    <img src="@(course.Thumbnail_Url ?? "https://via.placeholder.com/300")" alt="@course.Title">
                                    <div class="p-3">
                                        <h6 class="fw-bold mb-1 small text-truncate">@course.Title</h6>
                                        <p class="text-muted mb-2 text-truncate" style="font-size:.75rem">@course.SubTitle</p>
                                        <span style="font-size:.75rem;color:var(--orange);font-weight:600">Active Course</span>
                                        <div class="progress my-2"><div class="progress-bar" style="width:0%"></div></div>
                                        <a href="/User/Home/CourseDetails?id=@course.courseId" class="btn-resume"><i class="bi bi-play-fill me-1"></i>Resume</a>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="col-12 text-center py-4">
                            <p class="text-muted">You haven't enrolled in any courses yet.</p>
                            <a asp-action="Courses" class="btn btn-orange btn-sm">Explore Courses</a>
                        </div>
                    }
                </div>
            </div>

            <div class="section-card">
                <div class="section-card-title">Certificates Earned <a asp-action="Certificates">View all →</a></div>
                <div class="text-center py-3 text-muted small">No certificates earned yet.</div>
            </div>

        </div>

        <div class="col-lg-4">

            <div class="section-card">
                <div class="section-card-title">Recommended for You <a href="/User/Home/Courses">Browse →</a></div>
                @foreach (var course in Model.RecommendedCourses)
                {
                    <a class="rec-card" href="/User/Home/CourseDetails?id=@course.courseId">
                        <img src="@(course.Thumbnail_Url ?? "https://via.placeholder.com/200")" alt="@course.Title">
                        <div>
                            <div class="rec-card-title text-truncate" style="max-width: 150px;">@course.Title</div>
                            <div class="rec-card-meta"><span style="color:#f5a623">★</span> 5.0 · ₹@course.Total_Price</div>
                        </div>
                    </a>
                }
            </div>

            <!-- streak -->
            <div class="section-card">
                <div class="section-card-title">Learning Streak 🔥</div>
                <div class="d-flex gap-1 justify-content-between mb-2">
                    <div class="text-center" style="flex:1">
                        <div style="width:32px;height:32px;border-radius:50%;background:var(--orange);margin:0 auto 4px;display:flex;align-items:center;justify-content:center"><i class="bi bi-check-lg text-white" style="font-size:.7rem"></i></div>
                        <div style="font-size:.65rem;color:var(--muted)">Mon</div>
                    </div>
                    <div class="text-center" style="flex:1">
                        <div style="width:32px;height:32px;border-radius:50%;background:var(--orange);margin:0 auto 4px;display:flex;align-items:center;justify-content:center"><i class="bi bi-check-lg text-white" style="font-size:.7rem"></i></div>
                        <div style="font-size:.65rem;color:var(--muted)">Tue</div>
                    </div>
                    <div class="text-center" style="flex:1">
                        <div style="width:32px;height:32px;border-radius:50%;background:var(--orange);margin:0 auto 4px;display:flex;align-items:center;justify-content:center"><i class="bi bi-check-lg text-white" style="font-size:.7rem"></i></div>
                        <div style="font-size:.65rem;color:var(--muted)">Wed</div>
                    </div>
                    <div class="text-center" style="flex:1">
                        <div style="width:32px;height:32px;border-radius:50%;background:var(--orange);margin:0 auto 4px;display:flex;align-items:center;justify-content:center"><i class="bi bi-check-lg text-white" style="font-size:.7rem"></i></div>
                        <div style="font-size:.65rem;color:var(--muted)">Thu</div>
                    </div>
                    <div class="text-center" style="flex:1">
                        <div style="width:32px;height:32px;border-radius:50%;background:var(--orange);margin:0 auto 4px;display:flex;align-items:center;justify-content:center"><i class="bi bi-check-lg text-white" style="font-size:.7rem"></i></div>
                        <div style="font-size:.65rem;color:var(--muted)">Fri</div>
                    </div>
                    <div class="text-center" style="flex:1">
                        <div style="width:32px;height:32px;border-radius:50%;border:2px solid var(--orange);margin:0 auto 4px;display:flex;align-items:center;justify-content:center"><i class="bi bi-circle" style="font-size:.5rem;color:var(--orange)"></i></div>
                        <div style="font-size:.65rem;color:var(--orange);font-weight:600">Sat</div>
                    </div>
                    <div class="text-center" style="flex:1">
                        <div style="width:32px;height:32px;border-radius:50%;background:#eee;margin:0 auto 4px"></div>
                        <div style="font-size:.65rem;color:var(--muted)">Sun</div>
                    </div>
                </div>
                <p class="text-muted small mb-0 text-center">🔥 <strong>Streak Active</strong> — Keep going!</p>
            </div>

        </div>
    </div>


