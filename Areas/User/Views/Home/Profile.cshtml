@model SkillForge.Areas.User.Models.DashboardVM

@{
    Layout = "/Areas/User/Views/Shared/_StudentLayout.cshtml";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-0">My Profile</h4>
        <span class="text-muted small">Manage your personal info and settings</span>
    </div>
</div>

<div class="row g-4">

    <!-- LEFT SIDE -->
    <div class="col-lg-3">
        <div class="section-card text-center p-3">

            <!-- PROFILE PHOTO -->
            <img src="@((Model?.PhotoPath ?? "/images/DefaultProfilePhoto.jfif") + "?t=" + DateTime.Now.Ticks)"
                 id="avatarPreview"
                 class="rounded-circle mb-2"
                 style="width:100px;height:100px;object-fit:cover;">

            <label for="PhotoFile" style="cursor:pointer;">
                <i class="bi bi-camera-fill text-orange"></i>
                <span class="small text-muted ms-1">Change Photo</span>
            </label>


            <h6 class="fw-bold mt-2 mb-0">@(Model?.FirstName ?? "Guest") @(Model?.LastName ?? "User")</h6>
            <p class="text-muted small mb-2">@Model?.Email</p>

            <!-- ACTION BUTTONS -->
            <button class="btn btn-sm w-100 mt-2 py-1 btn-basic-info"
                    onclick="toggleSection('basicSection')">
                <i class="bi bi-person me-1"></i> Basic Info
            </button>

            <button class="btn btn-sm btn-outline-dark w-100 mt-2 py-1"
                    onclick="toggleSection('professionalSection')">
                <i class="bi bi-briefcase me-1"></i> Professional
            </button>

            <button class="btn btn-sm btn-outline-primary w-100 mt-2 py-1"
                    onclick="toggleSection('socialSection')">
                <i class="bi bi-link-45deg me-1"></i> Social Links
            </button>

            <button class="btn btn-sm btn-outline-secondary w-100 mt-2 py-1"
                    onclick="toggleSection('projectSection')">
                <i class="bi bi-folder me-1"></i> My Projects
            </button>

            <button class="btn btn-sm btn-outline-danger w-100 mt-2 py-1"
                    onclick="toggleSection('passwordSection')">
                <i class="bi bi-lock me-1"></i> Change Password
            </button>


            <!-- PROFESSIONAL (-->
            <div id="professionalSection" style="display:none" class="mt-2 text-start">
                <div class="text-muted small">Professional details form coming soon...</div>
            </div>


            <!-- SOCIAL SECTION -->
            <div id="socialSection" style="display:none" class="mt-2 text-start">

                <input type="url" class="form-control form-control-sm mb-1"
                       placeholder="LinkedIn profile">

                <input type="url" class="form-control form-control-sm mb-2"
                       placeholder="GitHub profile">

                <button class="btn-orange w-100 btn-sm py-1">Save</button>
            </div>


            <!-- PROJECT SECTION -->
            <div id="projectSection" style="display:none" class="mt-2 text-start">
                <div class="text-muted small">Projects section coming soon...</div>
            </div>


            <!-- PASSWORD SECTION -->
            <div id="passwordSection" style="display:none" class="mt-2 text-start">

                <div class="d-flex gap-1 mb-2">
                    <button type="button" class="btn btn-sm btn-outline-secondary active py-1 w-50"
                            onclick="togglePasswordMode('current')">
                        Password
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-secondary py-1 w-50"
                            onclick="togglePasswordMode('otp')">
                        OTP
                    </button>
                </div>

                <div id="pwd-current">
                    <input type="password" class="form-control form-control-sm mb-1"
                           placeholder="Current password">
                    <input type="password" class="form-control form-control-sm mb-1"
                           placeholder="New password">
                    <input type="password" class="form-control form-control-sm mb-2"
                           placeholder="Confirm password">

                    <button class="btn-orange w-100 btn-sm py-1">Update</button>
                </div>

                <div id="pwd-otp" style="display:none">
                    <input type="email" class="form-control form-control-sm mb-1"
                           value="@Model?.Email" readonly>

                    <button type="button"
                            class="btn btn-outline-primary w-100 mb-1 btn-sm py-1">
                        Send OTP
                    </button>

                    <input type="text" class="form-control form-control-sm mb-1"
                           placeholder="Enter OTP">

                    <input type="password" class="form-control form-control-sm mb-2"
                           placeholder="New password">

                    <button class="btn-orange w-100 btn-sm py-1">Update</button>
                </div>
            </div>


            <!-- STATS SECTION -->
            <div class="mt-3">

                <div class="d-flex gap-2">

                    <div class="stat-box w-50 text-center">
                        <div class="stat-number">5</div>
                        <div class="stat-label">Enrolled</div>
                    </div>

                    <div class="stat-box w-50 text-center">
                        <div class="stat-number">2</div>
                        <div class="stat-label">Completed</div>
                    </div>

                </div>

                <div class="stat-box text-center mt-2">
                    <div class="stat-number">1</div>
                    <div class="stat-label">Certificates</div>
                </div>

            </div>

        </div> @* sectiond card *@
    </div>


    <!-- RIGHT SIDE -->
    <div class="col-lg-9">
        <div class="section-card">

            <div class="form-section-title">Personal Information</div>

            <form asp-area="User" asp-controller="Home" asp-action="Profile" method="post" enctype="multipart/form-data">

                <!-- FILE INPUT -->
                <input type="file"
                       id="PhotoFile"
                       name="PhotoFile"
                       accept="image/*"
                       class="d-none"
                       onchange="previewAvatar(this)">

                <div class="row g-3">

                    <div class="col-md-6">
                        <label class="form-label small fw-medium">First Name</label>
                        <input type="text" class="form-control"
                               value="@(Model?.FirstName ?? "Guest")"
                               name="FirstName">
                    </div>

                    <div class="col-md-6">
                        <label class="form-label small fw-medium">Last Name</label>
                        <input type="text" class="form-control"
                               value="@(Model?.LastName ?? "User")"
                               name="LastName">
                    </div>

                    <div class="col-md-6">
                        <label class="form-label small fw-medium">Email Address</label>
                        <input type="email" class="form-control"
                               value="@Model?.Email"
                               name="Email"
                               readonly>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label small fw-medium">Phone Number</label>
                        <input type="tel" class="form-control"
                               value="@(Model?.Mobile ?? "1234567890")"
                               name="Mobile">
                    </div>

                    <div class="col-12">
                        <label class="form-label small fw-medium">Bio</label>
                        <textarea class="form-control"
                                  rows="3"
                                  name="Bio">@Model?.Bio</textarea>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label small fw-medium">City</label>
                        <input type="text" class="form-control"
                               value="@Model?.City"
                               name="City">
                    </div>

                    <div class="col-md-6">
                        <label class="form-label small fw-medium">Profession</label>
                        <input type="text" class="form-control"
                               value="@(Model?.Profession ?? "Your Profession")"
                               name="Profession">
                    </div>

                    <div class="col-12">
                        <button type="submit" class="btn-orange px-4">Save Changes</button>
                    </div>
                </div>
            </form>

        </div>
    </div>
</div>

<!-- CSS -->
<style>
    .form-section-title {
        font-size: .78rem;
        font-weight: 700;
        letter-spacing: .6px;
        color: #bbb;
        text-transform: uppercase;
        margin-bottom: 14px;
        padding-bottom: 8px;
        border-bottom: 1px solid #eee;
    }

 /* Action Button Css */

    .btn-basic-info {
        background-color: #1f7a63; /* deep muted green */
        color: #fff;
        border: none;
    }

        .btn-basic-info:hover {
            background-color: #176651;
        }

    .stat-box {
        background: #f8f9fa;
        border-radius: 10px;
        padding: 10px 0;
        box-shadow: 0 2px 6px rgba(0,0,0,0.05);
    }

    .stat-number {
        font-size: 18px;
        font-weight: 600;
        color: #212529;
    }

    .stat-label {
        font-size: 12px;
        color: #6c757d;
    }

</style>

<!-- JS -->
<script>
    function toggleSection(id) {
        let el = document.getElementById(id);
        el.style.display = (el.style.display === "none") ? "block" : "none";
    }

    function previewAvatar(input) {
        if (input.files && input.files[0]) {
            var reader = new FileReader();
            reader.onload = function (e) {
                document.getElementById('avatarPreview').src = e.target.result;
            };
            reader.readAsDataURL(input.files[0]);
        }
    }

    function togglePasswordMode(mode) {
        document.getElementById('pwd-current').style.display = mode === 'current' ? 'block' : 'none';
        document.getElementById('pwd-otp').style.display = mode === 'otp' ? 'block' : 'none';
    }
</script>