@model List<SkillForge.Models.CourseCardVM>
@{
    Layout = "/Areas/User/Views/Shared/_StudentLayout.cshtml";
    ViewData["Title"] = "My Cart";
    decimal totalAmount = Model?.Sum(c => c.Total_Price) ?? 0;
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <span class="text-muted small">@Model?.Count courses in cart</span>
    </div>
    <a asp-action="Courses" class="btn btn-sm btn-orange-outline">Continue Shopping</a>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        @if (Model != null && Model.Any())
        {
            <div class="cart-items">
                @foreach (var course in Model)
                {
                    <div class="cart-item-card mb-3" id="cart-item-@course.courseId">
                        <div class="row g-0 align-items-center">
                            <div class="col-3 col-md-2">
                                <img src="@(course.Thumbnail_Url ?? "/uploads/thumbnails/Default_Thumbnail.avif")" class="img-fluid rounded" style="height:70px; object-fit:cover;" alt="@course.Title">
                            </div>
                            <div class="col-9 col-md-7 ps-3">
                                <div class="fw-bold mb-1">@course.Title</div>
                                <div class="text-muted small mb-1">@course.CategoryName</div>
                                <button class="btn-link-danger p-0 border-0 bg-transparent small" onclick="removeFromCart(@course.courseId)">Remove</button>
                            </div>
                            <div class="col-12 col-md-3 text-md-end mt-2 mt-md-0">
                                <div class="fw-bold text-orange">₹@course.Total_Price.ToString("N0")</div>
                                @if (course.Discount_Percent > 0)
                                {
                                    <div class="text-muted small text-decoration-line-through">₹@course.Actual_Price.ToString("N0")</div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-cart">
                <i class="bi bi-cart-x"></i>
                <h5>Your cart is empty</h5>
                <p class="text-muted small">Your cart is empty. Keep shopping to find a course!</p>
                <a asp-action="Courses" class="btn btn-orange px-4 mt-2 text-white text-decoration-none">Explore Courses</a>
            </div>
        }
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="col-lg-4">
            <div class="summary-card shadow-sm border-0">
                <h5 class="fw-bold mb-3">Order Summary</h5>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Original Price</span>
                    <span>₹@Model.Sum(c => c.Actual_Price).ToString("N0")</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Discount</span>
                    <span class="text-success">- ₹@((Model.Sum(c => c.Actual_Price) - Model.Sum(c => c.Total_Price)).ToString("N0"))</span>
                </div>
                <hr>
                <div class="d-flex justify-content-between mb-4">
                    <span class="fw-bold">Total</span>
                    <span class="fw-bold fs-5 text-orange">₹@totalAmount.ToString("N0")</span>
                </div>
                
                <a asp-action="Checkout" asp-route-courseId="0" class="btn btn-orange w-100 py-2 fw-bold text-white text-decoration-none">Proceed to Checkout</a>
                <p class="text-center text-muted small mt-3">Secure Payment with Razorpay</p>
            </div>
        </div>
    }
</div>

<style>
    .cart-item-card {
        background: #fff;
        border: 1px solid #eee;
        border-radius: 12px;
        padding: 15px;
        transition: 0.2s;
    }
    .cart-item-card:hover {
        border-color: var(--orange);
    }
    .btn-link-danger {
        color: #e53935;
        text-decoration: none;
        font-weight: 500;
        cursor: pointer;
    }
    .btn-link-danger:hover {
        text-decoration: underline;
    }
    .summary-card {
        background: #fff;
        border-radius: 16px;
        padding: 24px;
        position: sticky;
        top: 80px;
    }
    .text-orange {
        color: var(--orange);
    }
    .empty-cart {
        text-align: center;
        padding: 80px 20px;
        background: #fff;
        border-radius: 16px;
        border: 1px dashed #ddd;
    }
    .empty-cart i {
        font-size: 3.5rem;
        color: #ddd;
        margin-bottom: 1rem;
    }
    .btn-orange-outline {
        border: 1.5px solid var(--orange);
        color: var(--orange);
        font-weight: 600;
    }
    .btn-orange-outline:hover {
        background: var(--orange);
        color: #fff;
    }
</style>

<script>
    function removeFromCart(courseId) {
        if(confirm("Remove this course from your cart?")) {
            $.post('/User/Home/RemoveFromCart', { courseId: courseId }, function (res) {
                if (res.success) {
                    $(`#cart-item-${courseId}`).fadeOut(300, function() {
                        $(this).remove();
                        if ($('.cart-item-card').length == 0) {
                            location.reload();
                        } else {
                            const badge = document.querySelector('.sf-cart-badge');
                            if (badge) {
                                if (res.cartCount > 0) {
                                    badge.innerText = res.cartCount;
                                } else {
                                    badge.remove();
                                }
                            }
                            // reload to update summary
                            location.reload();
                        }
                    });
                }
            });
        }
    }
</script>
