@* Move Clicked Cateory row to first row *@
<script>
         function scrollRow(el, dir) {

        const container = el.closest('.course-section-inner');
        const row = container.querySelector('.course-row');
        const card = row.querySelector('.c-card');

        if (!card) return;

        const cardWidth = card.offsetWidth;
        const gap = 16; // must match CSS gap
        const scrollAmount = (cardWidth + gap) * 3;

        row.scrollBy({
            left: scrollAmount * dir,
            behavior: 'smooth'
        });
    }
</script>