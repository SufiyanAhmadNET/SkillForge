@model CourseDetailsVM
@{
    Layout = "/Areas/User/Views/Shared/_StudentLayout.cshtml";
    ViewData["Title"] = "Learning: " + Model.Title;
    var completedLessons = ViewBag.CompletedLessons as List<int> ?? new List<int>();
}

<div class="container-fluid p-0">
    <div class="row g-0">
        @* player & details *@
        <div class="col-lg-8 border-end bg-white">
            <div class="video-section bg-black p-0 position-relative shadow-sm" style="min-height: 480px;">
                <div id="videoContainer" class="ratio ratio-16x9">
                    <div class="d-flex align-items-center justify-content-center text-white flex-column h-100 bg-dark bg-gradient">
                        <i class="bi bi-play-circle display-1 opacity-25 mb-3"></i>
                        <h5 class="fw-light opacity-75">Select a lesson to start learning</h5>
                    </div>
                </div>
            </div>

            <div class="content-section p-4">
                <div class="d-flex justify-content-between align-items-start mb-4">
                    <div>
                        <h4 class="fw-bold mb-1">@Model.Title</h4>
                        <div class="text-muted small">
                            <span class="me-3"><i class="bi bi-person-badge me-1"></i>Instructor: @Model.EnrolledStudents.FirstOrDefault()?.Name</span>
                            <span><i class="bi bi-journal-text me-1"></i>@Model.modules?.Count Modules</span>
                        </div>
                    </div>
                    <div class="text-end">
                        <div class="progress mb-1" style="height: 6px; width: 120px; background-color: #eee;">
                            <div id="courseProgressBar" class="progress-bar bg-success" role="progressbar" style="width: 0%;"></div>
                        </div>
                        <span id="courseProgressText" class="text-muted" style="font-size: 11px;">0% Complete</span>
                    </div>
                </div>

                <ul class="nav nav-tabs border-bottom mb-4" id="courseTab" role="tablist">
                    <li class="nav-item">
                        <button class="nav-link active fw-bold border-0 bg-transparent text-dark" data-bs-toggle="tab" data-bs-target="#description">Description</button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link fw-bold border-0 bg-transparent text-dark" data-bs-toggle="tab" data-bs-target="#outcomes">Outcomes</button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link fw-bold border-0 bg-transparent text-dark" data-bs-toggle="tab" data-bs-target="#details">More Details</button>
                    </li>
                </ul>

                <div class="tab-content pt-2">
                    <div class="tab-pane fade show active" id="description">
                        <p class="text-muted" style="line-height: 1.7; font-size: 15px;">@Model.Desciption</p>
                    </div>
                    <div class="tab-pane fade" id="outcomes">
                        <div class="row g-3">
                            @foreach (var outcome in Model.outcomes)
                            {
                                <div class="col-md-6">
                                    <div class="d-flex gap-2">
                                        <i class="bi bi-check-circle-fill text-success" style="font-size: 14px;"></i>
                                        <span class="text-muted small">@outcome.Outcome</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                    <div class="tab-pane fade" id="details">
                        <div class="row g-4">
                            <div class="col-md-4">
                                <div class="small text-muted mb-1 text-uppercase ls-1" style="font-size: 10px;">Difficulty</div>
                                <div class="fw-bold text-dark">@Model.Difficulty</div>
                            </div>
                            <div class="col-md-4">
                                <div class="small text-muted mb-1 text-uppercase ls-1" style="font-size: 10px;">Duration</div>
                                <div class="fw-bold text-dark">@Model.Duration Weeks</div>
                            </div>
                            <div class="col-md-4">
                                <div class="small text-muted mb-1 text-uppercase ls-1" style="font-size: 10px;">Category</div>
                                <div class="fw-bold text-dark">@Model.CategoryName</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* syllabus sidebar *@
        <div class="col-lg-4 bg-light border-start">
            <div class="syllabus-header p-3 bg-white border-bottom sticky-top" style="top: 0; z-index: 10;">
                <h6 class="fw-bold mb-0">Course Content</h6>
            </div>
            <div class="syllabus-body overflow-auto" style="height: calc(100vh - 120px);">
                <div class="accordion accordion-flush" id="syllabusAccordion">
                    @if (Model.modules != null && Model.modules.Any())
                    {
                        @for (int i = 0; i < Model.modules.Count; i++)
                        {
                            var module = Model.modules[i];
                            <div class="accordion-item border-bottom">
                                <h2 class="accordion-header">
                                    <button class="accordion-button @(i == 0 ? "" : "collapsed") bg-white py-3 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#module-@module.Id">
                                        <div class="w-100">
                                            <div class="fw-bold small text-dark" style="font-size: 13px;">Module @(i + 1): @module.ModuleName</div>
                                            <div class="text-muted mt-1" style="font-size: 11px;">@module.Lessons.Count Lessons</div>
                                        </div>
                                    </button>
                                </h2>
                                <div id="module-@module.Id" class="accordion-collapse collapse @(i == 0 ? "show" : "")" data-bs-parent="#syllabusAccordion">
                                    <div class="accordion-body p-0">
                                        <div class="list-group list-group-flush">
                                            @foreach (var lesson in module.Lessons)
                                            {
                                                var isCompleted = completedLessons.Contains(lesson.Id);
                                                <div class="list-group-item list-group-item-action border-0 lesson-item d-flex align-items-center gap-3 p-3 bg-white" 
                                                        style="cursor: pointer;" onclick="loadVideo('@lesson.VideoUrl', @lesson.Id, this)">
                                                    <div class="lesson-status flex-shrink-0">
                                                        @if (isCompleted)
                                                        {
                                                            <i class="bi bi-check-circle-fill text-success lesson-check-@lesson.Id" style="font-size: 18px;"></i>
                                                        }
                                                        else
                                                        {
                                                            <i class="bi bi-play-circle text-muted lesson-check-@lesson.Id" style="font-size: 18px;"></i>
                                                        }
                                                    </div>
                                                    <div class="flex-grow-1 min-w-0">
                                                        <div class="small fw-medium text-dark text-truncate lesson-title" style="font-size: 13px;">@lesson.Title</div>
                                                        <div class="text-muted d-flex align-items-center mt-1" style="font-size: 10px;">
                                                            <i class="bi bi-youtube me-1 text-danger"></i>Video · 10m
                                                        </div>
                                                    </div>
                                                    <div class="form-check m-0">
                                                        <input class="form-check-input lesson-checkbox" type="checkbox" @(isCompleted ? "checked" : "") 
                                                               onclick="toggleCompletion(@lesson.Id, @Model.CourseId, event, this)" style="cursor: pointer; border-color: #ddd;">
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="p-4 text-center text-muted small">Syllabus details coming soon.</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function loadVideo(url, lessonId, element) {
            if (!url) {
                showAlert("No video link available for this lesson.", "info");
                return;
            }

            // extract youtube id
            let videoId = '';
            if (url.includes('youtube.com/watch?v=')) {
                videoId = url.split('v=')[1].split('&')[0];
            } else if (url.includes('youtu.be/')) {
                videoId = url.split('youtu.be/')[1].split('?')[0];
            } else if (url.includes('embed/')) {
                 videoId = url.split('embed/')[1].split('?')[0];
            }

            if (videoId) {
                const embedUrl = `https://www.youtube.com/embed/${videoId}?autoplay=1&rel=0&modestbranding=1`;
                document.getElementById('videoContainer').innerHTML = `<iframe src="${embedUrl}" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>`;
            } else {
                document.getElementById('videoContainer').innerHTML = `<div class='p-5 text-center text-white'>Invalid YouTube Link</div>`;
            }

            // ui feedback
            document.querySelectorAll('.lesson-item').forEach(el => el.classList.remove('bg-light-orange', 'border-start-orange'));
            element.classList.add('bg-light-orange', 'border-start-orange');
        }

        function toggleCompletion(lessonId, courseId, event, checkbox) {
            event.stopPropagation(); // prevent video trigger
            
            $.ajax({
                url: '/User/Home/MarkLessonComplete',
                type: 'POST',
                data: { lessonId: lessonId, courseId: courseId },
                success: function (res) {
                    if (res.success) {
                        const icon = document.querySelector(`.lesson-check-${lessonId}`);
                        if (checkbox.checked) {
                            icon.className = `bi bi-check-circle-fill text-success lesson-check-${lessonId}`;
                        } else {
                            icon.className = `bi bi-play-circle text-muted lesson-check-${lessonId}`;
                        }
                        
                        // update progress
                        document.getElementById('courseProgressBar').style.width = res.progress + '%';
                        document.getElementById('courseProgressText').innerText = res.progress + '% Complete';
                    }
                }
            });
        }

        // init progress
        $(document).ready(function() {
            const totalLessons = @(Model.modules?.SelectMany(m => m.Lessons).Count() ?? 0);
            const completedLessons = @completedLessons.Count;
            const progress = totalLessons > 0 ? Math.round((completedLessons / totalLessons) * 100) : 0;
            
            document.getElementById('courseProgressBar').style.width = progress + '%';
            document.getElementById('courseProgressText').innerText = progress + '% Complete';
        });
    </script>
}

<style>
    /* custom learning page styles */
    .ls-1 { letter-spacing: 0.5px; }
    .nav-tabs .nav-link { border-bottom: 2px solid transparent !important; }
    .nav-tabs .nav-link.active {
        color: #ff6600 !important;
        border-bottom: 2px solid #ff6600 !important;
    }
    .lesson-item {
        transition: all 0.2s;
        border-left: 3px solid transparent !important;
    }
    .lesson-item:hover {
        background-color: #fff8f5 !important;
    }
    .bg-light-orange {
        background-color: #fff8f5 !important;
    }
    .border-start-orange {
        border-left: 3px solid #ff6600 !important;
    }
    .accordion-button:not(.collapsed) {
        background-color: #fff;
        color: #ff6600;
    }
    #videoContainer iframe {
        width: 100%;
        height: 100%;
    }
    .syllabus-body::-webkit-scrollbar {
        width: 4px;
    }
    .syllabus-body::-webkit-scrollbar-thumb {
        background: #ddd;
        border-radius: 10px;
    }
</style>
