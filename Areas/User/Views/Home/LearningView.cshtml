@model CourseDetailsVM
@{
    Layout = "/Areas/User/Views/Shared/_StudentLayout.cshtml";
    ViewData["Title"] = Model.Title;
    var completedLessons = ViewBag.CompletedLessons as List<int> ?? new List<int>();
}

<div class="container-fluid py-3 px-lg-4 bg-light min-vh-100">
    <div class="row g-4">
        
        <!-- LEFT: Video & Course Details -->
        <div class="col-lg-8 col-xl-9">
            
            <!-- Video Player Section -->
            <div class="card border-0 shadow-sm overflow-hidden mb-4 rounded-3 bg-dark">
                <div id="videoContainer" class="ratio ratio-16x9 mx-auto" style="max-height: 540px;">
                    <div class="d-flex flex-column align-items-center justify-content-center text-white h-100 bg-dark opacity-75">
                        <i class="bi bi-play-circle mb-3" style="font-size: 4rem; color: var(--orange);"></i>
                        <h5 class="fw-bold">Select a lesson to begin your journey</h5>
                        <p class="text-white-50 small">Your progress is automatically saved as you learn.</p>
                    </div>
                </div>
            </div>

            <!-- Course Meta & Progress -->
            <div class="card border-0 shadow-sm p-3 mb-4 rounded-3">
                <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
                    <div class="d-flex align-items-center gap-3">
                        <a asp-action="EnrolledCourses" class="btn btn-sm btn-outline-secondary rounded-pill px-3 fw-semibold">
                            <i class="bi bi-arrow-left me-1"></i> My Courses
                        </a>
                        <span class="badge rounded-pill px-3 py-2" style="background: #fff3e6; color: var(--orange); border: 1px solid #ffe5d4;">
                            @Model.CategoryName
                        </span>
                    </div>

                    <div class="d-flex align-items-center gap-3 flex-grow-1 justify-content-end" style="max-width: 400px;">
                        <div class="flex-grow-1">
                            <div class="progress" style="height: 8px; background-color: #eee;">
                                <div id="courseProgressBar" class="progress-bar" role="progressbar" style="width: 0%; background-color: var(--orange);" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                        </div>
                        <span id="courseProgressText" class="fw-bold text-dark small" style="min-width: 90px;">0% Complete</span>
                    </div>
                </div>
            </div>

            <!-- Course Info & Tabs -->
            <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
                <div class="card-body p-4">
                    <h2 class="fw-bold text-dark mb-3">@Model.Title</h2>
                    
                    <div class="d-flex flex-wrap gap-4 mb-4 text-muted small border-bottom pb-3">
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-collection-play text-orange"></i>
                            <span class="fw-semibold">@Model.modules?.Count Modules</span>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-bar-chart-steps text-orange"></i>
                            <span class="fw-semibold">@Model.Difficulty</span>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-clock-history text-orange"></i>
                            <span class="fw-semibold">@Model.Duration Weeks Access</span>
                        </div>
                    </div>

                    <!-- Tabs -->
                    <ul class="nav nav-pills custom-pills mb-4" id="courseTab" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active fw-bold px-4 py-2 me-2" data-bs-toggle="tab" data-bs-target="#description" type="button">About Course</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link fw-bold px-4 py-2" data-bs-toggle="tab" data-bs-target="#outcomes" type="button">What You'll Learn</button>
                        </li>
                    </ul>

                    <div class="tab-content" id="courseTabContent">
                        <div class="tab-pane fade show active" id="description" role="tabpanel">
                            <div class="lh-lg text-dark" style="font-size: 0.95rem; white-space: pre-line;">
                                @Model.Desciption
                            </div>
                        </div>
                        <div class="tab-pane fade" id="outcomes" role="tabpanel">
                            @if (Model.outcomes != null && Model.outcomes.Any())
                            {
                                <div class="row g-3">
                                    @foreach (var outcome in Model.outcomes)
                                    {
                                        <div class="col-md-6">
                                            <div class="d-flex align-items-start gap-3 p-2 rounded-3 bg-light border border-white h-100 shadow-sm">
                                                <i class="bi bi-check2-circle text-success fs-5"></i>
                                                <span class="small fw-medium text-dark mt-1">@outcome.Outcome</span>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="text-center py-4 text-muted small bg-light rounded-3 border border-dashed">
                                    <i class="bi bi-info-circle me-1"></i> No specific learning outcomes listed.
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- RIGHT: Syllabus Sidebar -->
        <div class="col-lg-4 col-xl-3">
            <div class="card border-0 shadow-sm rounded-3 sticky-top learning-sidebar" style="top: 85px; max-height: calc(100vh - 120px);">
                <div class="card-header bg-white border-bottom p-3 d-flex align-items-center justify-content-between sticky-top top-0 z-3">
                    <h6 class="fw-bold mb-0 text-dark">Course Content</h6>
                    <span class="badge bg-dark rounded-pill px-2 py-1" style="font-size: 0.65rem;">
                        @Model.modules?.SelectMany(m => m.Lessons).Count() Lessons
                    </span>
                </div>
                
                <div class="card-body p-0 overflow-auto">
                    <div class="accordion accordion-flush" id="syllabusAccordion">
                        @if (Model.modules != null && Model.modules.Any())
                        {
                            @for (int i = 0; i < Model.modules.Count; i++)
                            {
                                var module = Model.modules[i];
                                <div class="accordion-item border-bottom border-light">
                                    <h2 class="accordion-header">
                                        <button class="accordion-button @(i == 0 ? "" : "collapsed") shadow-none py-3" 
                                                type="button" 
                                                data-bs-toggle="collapse" 
                                                data-bs-target="#module-@module.Id">
                                            <div class="d-flex flex-column gap-1">
                                                <span class="fw-bold text-dark" style="font-size: 0.85rem;">Module @(i+1): @module.ModuleName</span>
                                                <span class="text-muted" style="font-size: 0.72rem;">@module.Lessons?.Count Lessons</span>
                                            </div>
                                        </button>
                                    </h2>
                                    <div id="module-@module.Id" class="accordion-collapse collapse @(i == 0 ? "show" : "")" data-bs-parent="#syllabusAccordion">
                                        <div class="accordion-body p-0 bg-white">
                                            @if (module.Lessons != null && module.Lessons.Any())
                                            {
                                                @foreach (var lesson in module.Lessons.OrderBy(l => l.Order))
                                                {
                                                    var isCompleted = completedLessons.Contains(lesson.Id);
                                                    <div class="lp-lesson d-flex align-items-center gap-3 py-3 px-3 @(isCompleted ? "lp-lesson--done" : "")" 
                                                         onclick="loadVideo('@lesson.VideoUrl', @lesson.Id, this)">
                                                        
                                                        <div class="lp-lesson-icon flex-shrink-0">
                                                            @if (isCompleted)
                                                            {
                                                                <i class="bi bi-check-circle-fill text-success lesson-check-@lesson.Id"></i>
                                                            }
                                                            else
                                                            {
                                                                <i class="bi bi-play-circle text-muted lesson-check-@lesson.Id"></i>
                                                            }
                                                        </div>

                                                        <div class="flex-grow-1 min-w-0">
                                                            <div class="lp-lesson-title text-truncate fw-medium" style="font-size: 0.82rem;">@lesson.Title</div>
                                                            <div class="d-flex align-items-center gap-2 mt-1">
                                                                <i class="bi bi-youtube text-danger" style="font-size: 0.75rem;"></i>
                                                                <span class="text-muted" style="font-size: 0.7rem;">YouTube</span>
                                                            </div>
                                                        </div>

                                                        <div class="flex-shrink-0 ms-2" onclick="event.stopPropagation();">
                                                            <input class="form-check-input lesson-checkbox rounded-1 border-secondary-subtle" 
                                                                   type="checkbox" 
                                                                   @(isCompleted ? "checked" : "")
                                                                   onchange="toggleCompletion(@lesson.Id, @Model.CourseId, event, this)"
                                                                   style="width: 1.1rem; height: 1.1rem; cursor: pointer;">
                                                        </div>
                                                    </div>
                                                }
                                            }
                                            else
                                            {
                                                <div class="py-3 px-4 text-muted italic small">No lessons in this module.</div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center py-5 px-3 text-muted">
                                <i class="bi bi-journals d-block mb-2 fs-1 opacity-25"></i>
                                <p class="small">Course syllabus will be available soon.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
<script>
    // load youtube video in player
    function loadVideo(url, lessonId, element) {
        if (!url) { showAlert("No video for this lesson.", "info"); return; }

        let videoId = '';
        if (url.includes('youtube.com/watch?v='))    videoId = url.split('v=')[1].split('&')[0];
        else if (url.includes('youtu.be/'))          videoId = url.split('youtu.be/')[1].split('?')[0];
        else if (url.includes('embed/'))             videoId = url.split('embed/')[1].split('?')[0];

        const container = document.getElementById('videoContainer');
        if (videoId) {
            container.innerHTML = `<iframe src="https://www.youtube.com/embed/${videoId}?autoplay=1&rel=0&modestbranding=1"
                frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>`;
        } else {
            container.innerHTML = `<div class='p-5 h-100 d-flex align-items-center justify-content-center text-center text-white bg-dark'>
                <div><i class="bi bi-exclamation-triangle mb-2 d-block fs-2 text-warning"></i>Invalid or missing YouTube video link</div>
            </div>`;
        }

        // highlight active lesson
        document.querySelectorAll('.lp-lesson').forEach(el => el.classList.remove('lp-lesson--active'));
        element.classList.add('lp-lesson--active');
    }

    // mark lesson complete via ajax — backend untouched
    function toggleCompletion(lessonId, courseId, event, checkbox) {
        event.stopPropagation();
        $.ajax({
            url: '/User/Home/MarkLessonComplete',
            type: 'POST',
            data: { lessonId, courseId },
            success: function (res) {
                if (res.success) {
                    const icon = document.querySelector(`.lesson-check-${lessonId}`);
                    icon.className = checkbox.checked
                        ? `bi bi-check-circle-fill text-success lesson-check-${lessonId}`
                        : `bi bi-play-circle text-muted lesson-check-${lessonId}`;

                    // toggle done state on row
                    const row = checkbox.closest('.lp-lesson');
                    row.classList.toggle('lp-lesson--done', checkbox.checked);

                    // update progress bar
                    const progress = parseInt(res.progress);
                    const progressBar = document.getElementById('courseProgressBar');
                    progressBar.style.width = progress + '%';
                    progressBar.setAttribute('aria-valuenow', progress);
                    document.getElementById('courseProgressText').innerText = progress + '% Complete';
                }
            },
            error: function() {
                checkbox.checked = !checkbox.checked; // revert if failed
                showAlert("Could not update progress. Please try again.", "danger");
            }
        });
    }

    // init progress on load
    $(document).ready(function () {
        const total     = @(Model.modules?.SelectMany(m => m.Lessons).Count() ?? 0);
        const completed = @completedLessons.Count;
        const pct       = total > 0 ? Math.round((completed / total) * 100) : 0;

        const progressBar = document.getElementById('courseProgressBar');
        if(progressBar) {
            progressBar.style.width = pct + '%';
            progressBar.setAttribute('aria-valuenow', pct);
        }
        const progressText = document.getElementById('courseProgressText');
        if(progressText) progressText.innerText  = pct + '% Complete';
    });
</script>
}

<style>
    :root {
        --text-orange: var(--orange);
    }

    .text-orange { color: var(--orange); }

    /* Custom nav pills */
    .custom-pills .nav-link {
        color: #666;
        border-radius: 8px;
        transition: all 0.2s ease;
    }
    .custom-pills .nav-link:hover {
        color: var(--orange);
        background-color: #fff3e6;
    }
    .custom-pills .nav-link.active {
        background-color: var(--orange) !important;
        color: white !important;
        box-shadow: 0 4px 12px rgba(255, 107, 0, 0.2);
    }

    /* Lesson row styling */
    .lp-lesson {
        cursor: pointer;
        border-left: 4px solid transparent;
        transition: all 0.2s ease;
    }
    .lp-lesson:hover {
        background-color: #f8f9fa;
    }
    .lp-lesson--active {
        background-color: #fff3e6 !important;
        border-left-color: var(--orange) !important;
    }
    .lp-lesson--done {
        background-color: #f0fff4;
    }
    .lp-lesson--done .lp-lesson-title {
        color: #28a745;
    }

    /* Accordion Customization */
    .accordion-button:not(.collapsed) {
        background-color: #fffaf5;
        color: var(--orange);
    }
    .accordion-button::after {
        background-size: 0.8rem;
    }

    /* Sticky Sidebar Scrollbar */
    .learning-sidebar .card-body::-webkit-scrollbar {
        width: 6px;
    }
    .learning-sidebar .card-body::-webkit-scrollbar-track {
        background: #f1f1f1;
    }
    .learning-sidebar .card-body::-webkit-scrollbar-thumb {
        background: #ccc;
        border-radius: 10px;
    }
    .learning-sidebar .card-body::-webkit-scrollbar-thumb:hover {
        background: #aaa;
    }

    /* Responsiveness tweaks */
    media (max-width: 991.98px) {
        .learning-sidebar {
            position: static !important;
            max-height: 500px !important;
            margin-top: 1.5rem;
        }
    }
</style>

