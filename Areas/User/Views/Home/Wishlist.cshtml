@{
    Layout = "/Areas/User/Views/Shared/_StudentLayout.cshtml";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-0">Wishlist</h4>
        <span class="text-muted small">3 saved courses</span>
    </div>
    <a href="/Courses" class="btn btn-light btn-sm px-3 fw-medium">Browse More</a>
</div>

<div class="row g-3" id="wishlistGrid">

    <!-- wish card 1 -->
    <div class="col-md-6 col-xl-4" id="wish-1">
        <div class="wish-card">
            <img src="https://images.unsplash.com/photo-1580927752452-89d86da3fa0a?w=600" alt="">
            <button class="wish-remove" onclick="removeWish('wish-1')" title="Remove">
                <i class="bi bi-x"></i>
            </button>
            <div class="p-3">
                <div class="d-flex gap-1 mb-2">
                    <span class="badge-level">Intermediate</span>
                    <span class="badge-tag">10 weeks</span>
                </div>
                <h6 class="fw-bold mb-1">React & Next.js Masterclass</h6>
                <p class="text-muted small mb-2">By Arjun Mehta</p>
                <div class="d-flex align-items-center gap-1 mb-3">
                    <span class="rating-stars">★★★★★</span>
                    <span class="small text-muted">(4.9) · 2,100 students</span>
                </div>
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <span class="price-main">₹5,499</span>
                        <span class="price-old ms-1">₹10,999</span>
                    </div>
                    <a href="/Course/Detail/4" class="btn-orange" style="padding:6px 16px;font-size:.82rem;text-decoration:none">Enroll</a>
                </div>
            </div>
        </div>
    </div>

    <!-- wish card 2 -->
    <div class="col-md-6 col-xl-4" id="wish-2">
        <div class="wish-card">
            <img src="https://images.unsplash.com/photo-1558494949-ef010cbdcc31?w=600" alt="">
            <button class="wish-remove" onclick="removeWish('wish-2')" title="Remove">
                <i class="bi bi-x"></i>
            </button>
            <div class="p-3">
                <div class="d-flex gap-1 mb-2">
                    <span class="badge-level">Intermediate</span>
                    <span class="badge-tag">10 weeks</span>
                </div>
                <h6 class="fw-bold mb-1">Docker & Kubernetes</h6>
                <p class="text-muted small mb-2">By Ravi Kumar</p>
                <div class="d-flex align-items-center gap-1 mb-3">
                    <span class="rating-stars">★★★★★</span>
                    <span class="small text-muted">(4.8) · 2,450 students</span>
                </div>
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <span class="price-main">₹5,999</span>
                        <span class="price-old ms-1">₹11,999</span>
                    </div>
                    <a href="/Course/Detail/5" class="btn-orange" style="padding:6px 16px;font-size:.82rem;text-decoration:none">Enroll</a>
                </div>
            </div>
        </div>
    </div>

    <!-- wish card 3 -->
    <div class="col-md-6 col-xl-4" id="wish-3">
        <div class="wish-card">
            <img src="https://images.unsplash.com/photo-1531746790731-6c087fecd65a?w=600" alt="">
            <button class="wish-remove" onclick="removeWish('wish-3')" title="Remove">
                <i class="bi bi-x"></i>
            </button>
            <div class="p-3">
                <div class="d-flex gap-1 mb-2">
                    <span class="badge-level">Beginner</span>
                    <span class="badge-tag">6 weeks</span>
                </div>
                <h6 class="fw-bold mb-1">Prompt Engineering for LLMs</h6>
                <p class="text-muted small mb-2">By Priya Sharma</p>
                <div class="d-flex align-items-center gap-1 mb-3">
                    <span class="rating-stars">★★★★☆</span>
                    <span class="small text-muted">(4.7) · 3,200 students</span>
                </div>
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <span class="price-main">₹2,499</span>
                        <span class="price-old ms-1">₹4,999</span>
                    </div>
                    <a href="/Course/Detail/6" class="btn-orange" style="padding:6px 16px;font-size:.82rem;text-decoration:none">Enroll</a>
                </div>
            </div>
        </div>
    </div>

</div><!-- /grid -->
<!-- empty state — shown when all removed -->
<div class="empty-wishlist" id="emptyWishlist" style="display:none">
    <div><i class="bi bi-heart"></i></div>
    <h5 class="fw-bold">Your wishlist is empty</h5>
    <p class="text-muted small mb-3">Save courses you're interested in for later</p>
    <a href="/Courses" class="btn-orange px-4" style="text-decoration:none">Browse Courses</a>
</div>



@* Wishlist CSS *@
<style>
    /* wishlist card — grid layout */
    .wish-card {
        background: #fff;
        border: 1px solid #eee;
        border-radius: 14px;
        overflow: hidden;
        transition: box-shadow .2s, transform .2s;
        position: relative;
    }

        .wish-card:hover {
            box-shadow: 0 6px 24px rgba(0,0,0,.09);
            transform: translateY(-3px);
        }

        .wish-card img {
            width: 100%;
            height: 160px;
            object-fit: cover;
        }

    /* remove from wishlist — X button top-right of card */
    .wish-remove {
        position: absolute;
        top: 10px;
        right: 10px;
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: rgba(0,0,0,.5);
        color: #fff;
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font-size: .75rem;
        transition: background .2s;
    }

        .wish-remove:hover {
            background: #dc3545;
        }

    /* empty state */
    .empty-wishlist {
        text-align: center;
        padding: 80px 20px;
    }

        .empty-wishlist i {
            font-size: 3.5rem;
            color: #eee;
            margin-bottom: 16px;
        }
</style>