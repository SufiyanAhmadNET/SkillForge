@model List<SkillForge.Models.CourseCardVM>
@{
    Layout = "/Areas/User/Views/Shared/_StudentLayout.cshtml";
    ViewData["Title"] = "My Wishlist";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <span class="text-muted small">Courses you saved for later</span>
    </div>
    <a asp-action="Courses" class="btn btn-sm btn-orange-outline">Browse More Courses</a>
</div>

<div class="wishlist-container">
    @if (Model != null && Model.Any())
    {
        <div class="row g-4">
            @foreach (var course in Model)
            {
                <div class="col-xl-3 col-lg-4 col-sm-6 wishlist-item" id="wish-item-@course.courseId">
                    <div class="c-card h-100 shadow-sm">
                        <div class="c-thumb">
                            <img src="@(course.Thumbnail_Url ?? "/uploads/thumbnails/Default_Thumbnail.avif")" alt="@course.Title">
                            <span class="diff-tag">@course.Difficulty</span>
                            
                            <button class="remove-wish" onclick="removeFromWishlist(@course.courseId)" title="Remove">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        </div>

                        <div class="c-body">
                            <div class="c-cat">@course.CategoryName</div>
                            <div class="c-title">@course.Title</div>
                            
                            <div class="c-price-row mt-2">
                                <div>
                                    <span class="c-price">₹@course.Total_Price</span>
                                </div>
                                <span class="c-off">@course.Discount_Percent% OFF</span>
                            </div>

                            <a href="/User/Home/CourseDetails?id=@course.courseId" class="c-btn d-block text-center text-decoration-none mt-3">
                                View Details
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-wishlist">
            <i class="bi bi-heart"></i>
            <h5>Your wishlist is empty</h5>
            <p class="text-muted small">Explore courses and save your favorites here.</p>
            <a asp-action="Courses" class="btn btn-orange btn-sm px-4 mt-2">Explore Courses</a>
        </div>
    }
</div>

<style>
    /* wishlist item container */
    .wishlist-container {
        min-height: 400px;
    }

    /* removal button overlay */
    .remove-wish {
        position: absolute;
        top: 10px;
        right: 10px;
        width: 30px;
        height: 30px;
        border-radius: 50%;
        background: rgba(255,255,255,0.9);
        border: none;
        color: #e53935;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: 0.2s;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }
    .remove-wish:hover {
        background: #e53935;
        color: #fff;
        transform: scale(1.1);
    }

    /* course card styling tweaks for wishlist */
    .c-card {
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid #eee;
        transition: 0.3s;
    }
    .c-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }

    /* empty state */
    .empty-wishlist {
        text-align: center;
        padding: 80px 20px;
        background: #fff;
        border-radius: 16px;
        border: 1px dashed #ddd;
    }
    .empty-wishlist i {
        font-size: 3rem;
        color: #ddd;
        margin-bottom: 1rem;
    }

    .btn-orange {
        background: var(--orange);
        color: #fff;
        border: none;
    }
    .btn-orange:hover {
        background: #e66e00;
        color: #fff;
    }

    .btn-orange-outline {
        border: 1.5px solid var(--orange);
        color: var(--orange);
        font-weight: 600;
    }
    .btn-orange-outline:hover {
        background: var(--orange);
        color: #fff;
    }
</style>

<script>
    function removeFromWishlist(courseId) {
        if(confirm("Remove this course from your wishlist?")) {
            $.post('/User/Home/ToggleWishlist', { courseId: courseId }, function (res) {
                if (res.success && !res.added) {
                    $(`#wish-item-${courseId}`).fadeOut(300, function() {
                        $(this).remove();
                        if ($('.wishlist-item').length == 0) {
                            location.reload(); // Show empty state
                        }
                    });
                }
            });
        }
    }
</script>