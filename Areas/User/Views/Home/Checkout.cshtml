@{
    Layout = "/Areas/User/Views/Shared/_StudentLayout.cshtml";
    ViewData["Title"] = "Checkout";
}

<div class="container py-5" style="max-width:520px;">

    @* ── order summary card ── *@
    <div class="checkout-card">

        <div class="ck-header">
            <i class="bi bi-shield-lock-fill me-2"></i> Secure Checkout
        </div>

        <div class="ck-body">

            @* course name + amount *@
            <div class="ck-course-row">
                <div class="ck-course-name">@ViewBag.CourseTitle</div>
                <div class="ck-amount">₹@ViewBag.AmountDisplay</div>
            </div>

            <hr class="ck-divider">

            @* what student gets *@
            <ul class="ck-trust">
                <li><i class="bi bi-infinity text-orange"></i> Lifetime access</li>
                <li><i class="bi bi-award text-orange"></i> Certificate included</li>
                <li><i class="bi bi-arrow-counterclockwise text-orange"></i> 30-day money-back</li>
            </ul>

            <hr class="ck-divider">

            @* UPI options note *@
            <div class="ck-upi-note">
                <i class="bi bi-phone me-1"></i>
                Pay via <strong>UPI, GPay, PhonePe, Paytm, Net Banking, Cards</strong> — all options available
            </div>

            @* pay button — triggers razorpay modal *@
            <button id="payBtn" class="ck-pay-btn">
                <i class="bi bi-lock-fill me-2"></i>Pay ₹@ViewBag.AmountDisplay Securely
            </button>

            <p class="ck-footer-note">
                <i class="bi bi-shield-check me-1"></i>
                Powered by Razorpay · 256-bit SSL encryption
            </p>
        </div>
    </div>
</div>


@* ── hidden form — POSTed after razorpay success ── *@
<form id="paymentForm" method="post" 
    asp-area="User" asp-controller="Home" asp-action="VerifyPayment">
    <input type="hidden" name="razorpay_order_id" id="rzp_order_id" value="">
    <input type="hidden" name="razorpay_payment_id" id="rzp_payment_id" value="">
    <input type="hidden" name="razorpay_signature" id="rzp_signature" value="">
    <input type="hidden" name="courseId" value="@ViewBag.CourseId">
</form>


@* ── razorpay SDK ── *@
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>

<script>
    document.getElementById('payBtn').addEventListener('click', function () {

    var options = {
    key:         "@ViewBag.RazorpayKeyId",
    amount:      "@ViewBag.Amount",          // paise
    currency:    "INR",
    name:        "SkillForge",
    description: "@ViewBag.CourseTitle",
    order_id:    "@ViewBag.RazorpayOrderId",

    prefill: {
    contact: "@ViewBag.StudentMobile",
    email:   "@ViewBag.StudentEmail",
    name:    "@ViewBag.StudentName"
    },

    // razorpay calls this on success
    handler: function (response) {
    document.getElementById('rzp_order_id').value   = response.razorpay_order_id;
    document.getElementById('rzp_payment_id').value = response.razorpay_payment_id;
    document.getElementById('rzp_signature').value  = response.razorpay_signature;

    // auto-submit to our verify endpoint
    document.getElementById('paymentForm').submit();
    },

    theme: {
    color: "#ff7a00"   // orange — matches SkillForge theme
    },

    modal: {
    ondismiss: function () {
    console.log('Payment modal closed by user');
    }
    }
    };

    var rzp = new Razorpay(options);

    // handle payment failure inside modal
    rzp.on('payment.failed', function (response) {
    alert('Payment failed: ' + response.error.description);
    });

    rzp.open();
    });
</script>


@* ── checkout styles ── *@
<style>
    .checkout-card {
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(0,0,0,.08);
    border: 1px solid #eee;
    }

    /* orange header bar */
    .ck-header {
    background: var(--orange);
    color: #fff;
    padding: 14px 24px;
    font-weight: 600;
    font-size: .95rem;
    }

    .ck-body {
    padding: 24px;
    background: #fff;
    }

    /* course + price row */
    .ck-course-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    }

    .ck-course-name {
    font-weight: 600;
    font-size: 1rem;
    color: #212529;
    }

    .ck-amount {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--orange);
    white-space: nowrap;
    }

    .ck-divider {
    margin: 16px 0;
    border-color: #f0f0f0;
    }

    /* trust list */
    .ck-trust {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
    font-size: .9rem;
    color: #444;
    }

    .ck-trust li {
    display: flex;
    align-items: center;
    gap: 8px;
    }

    .text-orange {
    color: var(--orange);
    }

    /* UPI note */
    .ck-upi-note {
    background: #fff8f0;
    border-left: 3px solid var(--orange);
    padding: 10px 14px;
    border-radius: 0 8px 8px 0;
    font-size: .85rem;
    color: #555;
    margin-bottom: 20px;
    }

    /* pay button */
    .ck-pay-btn {
    width: 100%;
    background: var(--orange);
    color: #fff;
    border: none;
    padding: 14px;
    border-radius: 10px;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    transition: .2s ease;
    }

    .ck-pay-btn:hover {
    background: var(--orange-dark, #e66e00);
    transform: translateY(-1px);
    }

    /* footer note */
    .ck-footer-note {
    text-align: center;
    font-size: .78rem;
    color: #999;
    margin-top: 14px;
    margin-bottom: 0;
    }
</style>
