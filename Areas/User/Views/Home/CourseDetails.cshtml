@{
    Layout = "/Areas/User/Views/Shared/_StudentLayout.cshtml";
}



<body>

    <div class="container-fluid">
        <!-- row: left + right (VIDEO + TITLE integrated with left) -->
        <div class="row g-4 align-items-stretch">
            <!-- LEFT COLUMN (Video + Title + What you'll learn) -->
            <div class="col-lg-8">
                <!-- VIDEO (clean embed) -->
                <div class="course-video">
                    <iframe src="https://youtu.be/lXYLTTPM5x4?si=CUEGuzGzOvPozbct" title="Course preview" allowfullscreen></iframe>
                </div>

                <!-- TITLE + short description (exactly as spec) -->
                <h1 class="c-title">Full Stack Web Development <span style="font-weight: 400; color: var(--orange);">3.0</span></h1>
                <div class="c-sub">
                    Build real-world apps using ASP.NET Core, SQL Server & modern frontend — from zero to production.
                </div>

                <!-- WHAT YOU’LL LEARN -->
                <div class="course-box">
                    <div class="cat-title">
                        <i>📘</i> What you’ll learn
                    </div>
                    <ul>
                        <li>Build full-stack applications from absolute scratch with industry patterns</li>
                        <li>Master backend development using ASP.NET Core Web API & MVC</li>
                        <li>Work with real-world databases (SQL Server) and Entity Framework Core</li>
                        <li>Deploy, secure, and manage production-ready apps on cloud</li>
                        <li>Create responsive UIs with Bootstrap & JavaScript</li>
                    </ul>
                    <div class="mt-3 text-muted small" style="opacity: 0.7;">✨ 40+ hours · updated 2026 · includes source code</div>
                </div>
            </div>

            <!-- RIGHT CARD -->
            <div class="col-lg-4">
                <div class="course-box">
                    <!-- PRICE -->
                    <div class="c-price-row">
                        <div class="d-flex align-items-center flex-wrap">
                            <span class="c-price">₹499</span>
                            <span class="c-original">₹3,999</span>
                            <span class="c-off">87% OFF</span>
                        </div>
                    </div>

                    <div class="text-muted small mt-1">⚡ Limited time offer</div>

                    <!-- CTA -->
                    <button class="c-btn enroll-btn">✨ Enroll Now — Start Learning</button>

                    <!-- TRUST -->
                    <ul>
                        <li>✔ Lifetime access, anywhere</li>
                        <li>✔ Certificate of completion</li>
                        <li>✔ 30-day money-back guarantee</li>
                        <li>✔ 24x7 doubt clearing</li>
                    </ul>

                    <hr>

                    <!-- LANGUAGE -->
                    <div class="d-flex justify-content-between">
                        <span>🗣️ Course language</span>
                        <strong style="color: var(--orange);">English (Hinglish support)</strong>
                    </div>

                    <div class="mt-3 text-center small opacity-75">
                        ⏳ 12,450+ students enrolled
                    </div>
                </div>
            </div>
        </div>

        <!-- CONTENT -->
        <div class="course-box mt-2">
            <div class="cat-title">
                <i>📚</i> Content · step-by-step curriculum
            </div>
            <div class="row">
                <div class="col-md-6">
                    <div><strong>Module 1:</strong> HTML5 & CSS3</div>
                    <div><strong>Module 2:</strong> JavaScript & DOM</div>
                    <div><strong>Module 3:</strong> Bootstrap</div>
                </div>
                <div class="col-md-6">
                    <div><strong>Module 4:</strong> ASP.NET Core</div>
                    <div><strong>Module 5:</strong> Entity Framework</div>
                    <div><strong>Module 6:</strong> Deployment</div>
                </div>
            </div>
            <p class="mt-3 mb-0 text-end"><span class="c-off">➕ 3 bonus projects included</span></p>
        </div>

    </div>

</body>