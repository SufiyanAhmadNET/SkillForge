@model SkillForge.Models.CourseDetailsVM

@{
    Layout = "/Areas/User/Views/Shared/_StudentLayout.cshtml";
    ViewData["Title"] = Model.Title ?? "Course Details";
}

@* ── helpr method to detect youtube vs local video ── *@
@{
    bool isYoutube = !string.IsNullOrEmpty(Model.VideoUrl) &&
                     (Model.VideoUrl.Contains("youtube") || Model.VideoUrl.Contains("youtu.be"));

    // convert watch?v= to embed/
    string embedUrl = isYoutube
        ? Model.VideoUrl!
              .Replace("watch?v=", "embed/")
              .Replace("youtu.be/", "www.youtube.com/embed/")
              .Split('?')[0]  // strip extra params after id
        : Model.VideoUrl ?? "";
}

<div class="container-fluid px-4 px-lg-5 py-4">

    <div class="row g-4 align-items-start">

        @* ── LEFT — video + info ── *@
        <div class="col-lg-8">

            @* video block *@
            <div class="course-video mb-3">
                @if (isYoutube)
                {
                    <iframe src="@embedUrl" title="Course preview" allowfullscreen></iframe>
                }
                else if (!string.IsNullOrEmpty(Model.VideoUrl))
                {
                    @* local mp4 *@
                    <video controls class="w-100">
                        <source src="@Model.VideoUrl" type="video/mp4">
                    </video>
                }
                else
                {
                    @* no video placeholder *@
                    <div class="no-video d-flex align-items-center justify-content-center">
                        <span class="text-muted">No preview video available</span>
                    </div>
                }
            </div>

            @* title + subtitle *@
            <h1 class="c-title">@Model.Title</h1>
            <div class="c-sub mb-3">@Model.SubTitle</div>

            @* what you'll learn — real outcomes from DB *@
            <div class="course-box mb-3">
                <div class="cat-title"><i>📘</i> What you'll learn</div>
                @if (Model.outcomes != null && Model.outcomes.Any())
                {
                    <ul>
                        @foreach (var o in Model.outcomes)
                        {
                            <li>@o.Outcome</li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted small">Outcomes not listed yet.</p>
                }
                <div class="mt-2 text-muted small opacity-75">✨ Includes source code · updated 2026</div>
            </div>

            @* course description *@
            @if (!string.IsNullOrEmpty(Model.Desciption))
            {
                <div class="course-box mb-3">
                    <div class="cat-title"><i>📋</i> About this course</div>
                    <p class="mb-0">@Model.Desciption</p>
                </div>
            }

            @* ── 6 static modules (curriculum) ── *@
            <div class="course-box">
                <div class="cat-title"><i>📚</i> Course Curriculum · 6 Modules</div>

                @{
                    // static modules — same for every course for now
                    var modules = new[]
                    {
                        new { No = 1, Name = "Foundations & Setup",        Desc = "Dev environment, tools, Git basics" },
                        new { No = 2, Name = "Frontend Essentials",        Desc = "HTML5, CSS3, Bootstrap, responsive design" },
                        new { No = 3, Name = "JavaScript & DOM",           Desc = "ES6+, async/await, DOM manipulation" },
                        new { No = 4, Name = "Backend Development",        Desc = "ASP.NET Core MVC, routing, controllers" },
                        new { No = 5, Name = "Database & EF Core",         Desc = "SQL Server, Entity Framework, migrations" },
                        new { No = 6, Name = "Deployment & Final Project", Desc = "Cloud deploy, CI/CD basics, capstone project" }
                    };
                }

                <div class="accordion" id="moduleAccordion">
                    @foreach (var m in modules)
                    {
                        <div class="accordion-item border-0 mb-2">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed module-btn" type="button"
                                        data-bs-toggle="collapse"
                                        data-bs-target="#mod@(m.No)">
                                    <span class="mod-num">@m.No</span>
                                    <span class="ms-2">@m.Name</span>
                                </button>
                            </h2>
                            <div id="mod@(m.No)" class="accordion-collapse collapse"
                                 data-bs-parent="#moduleAccordion">
                                <div class="accordion-body text-muted small">
                                    @m.Desc
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <p class="mt-3 mb-0 text-end small">
                    <span class="c-off">➕ 3 bonus projects included</span>
                </p>
            </div>

        </div>


        @* ── RIGHT — enroll card ── *@
        <div class="col-lg-4">
            <div class="course-box sticky-top" style="top: 80px;">

                @* price *@
                <div class="c-price-row mb-1">
                    <div class="d-flex align-items-center flex-wrap gap-2">
                        <span class="c-price">₹@Model.TotalPrice</span>
                        <span class="c-original">₹@Model.ActualPrice</span>
                        @if (Model.DiscountPercent > 0)
                        {
                            <span class="c-off">@Model.DiscountPercent% OFF</span>
                        }
                    </div>
                </div>

                <div class="text-muted small mb-3">⚡ Limited time offer</div>

                @* enroll CTA *@
                <a asp-area="User" asp-controller="Home" asp-action="Checkout"
                       asp-route-courseId="@Model.CourseId"
                       class="c-btn enroll-btn w-100 d-block text-center text-decoration-none">
                    ✨ Enroll Now — Start Learning
                </a>
                s
                @* trust points *@
                <ul class="list-unstyled small mb-3">
                    <li>✔ Lifetime access, anywhere</li>
                    <li>✔ Certificate of completion</li>
                    <li>✔ 30-day money-back guarantee</li>
                    <li>✔ 24x7 doubt clearing</li>
                </ul>

                <hr>

                <div class="d-flex justify-content-between small">
                    <span>🗣️ Course language</span>
                    <strong style="color:var(--orange);">@Model.languange (@Model.supportLanguage)</strong>
                </div>

                <div class="mt-3 text-center small opacity-75">⏳ Students already enrolled</div>
            </div>
        </div>

    </div>
</div>


@* ── module accordion styles ── *@
<style>
    /* module number badge */
    .mod-num {
        width: 26px;
        height: 26px;
        background: var(--orange);
        color: #fff;
        border-radius: 50%;
        font-size: 12px;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .module-btn {
        background: #f8f9fa;
        font-weight: 600;
        border-radius: 8px !important;
        border: 1px solid #eee;
    }

        .module-btn:not(.collapsed) {
            background: var(--orange-soft, rgba(255,122,0,.08));
            color: var(--orange);
            border-color: var(--orange);
        }

    /* no-video placeholder box */
    .no-video {
        height: 280px;
        background: #f0f0f0;
        border-radius: 12px;
    }
</style>
