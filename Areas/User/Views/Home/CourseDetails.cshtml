@model SkillForge.Models.CourseDetailsVM

@{
    Layout = "/Areas/User/Views/Shared/_StudentLayout.cshtml";
    ViewData["Title"] = Model.Title ?? "Course Details";
    bool isPreview = ViewBag.IsPreview == true;
}

@* ── helpr method to detect youtube vs local video ── *@
@{
    bool isYoutube = !string.IsNullOrEmpty(Model.VideoUrl) &&
                     (Model.VideoUrl.Contains("youtube") || Model.VideoUrl.Contains("youtu.be"));

    // convert watch?v= to embed/
    string embedUrl = isYoutube
        ? Model.VideoUrl!
              .Replace("watch?v=", "embed/")
              .Replace("youtu.be/", "www.youtube.com/embed/")
              .Split('?')[0]  // s
        : Model.VideoUrl ?? "";
}

<div class="container-fluid px-4 px-lg-5 py-4">

    @* instructor preview banner *@
    @if (ViewBag.IsPreview == true)
    {
        <div class="alert alert-info d-flex align-items-center justify-content-between mb-4 border-0 shadow-sm py-2 px-3" 
             style="background: #e3f2fd; border-left: 4px solid #2196f3 !important;">
            <div class="d-flex align-items-center gap-2">
                <i class="bi bi-eye-fill text-primary"></i>
                <span class="fw-semibold text-dark" style="font-size:14px;">Preview Mode (Instructor View)</span>
            </div>
            <a asp-area="Instructor" asp-controller="Home" asp-action="CourseDetails" asp-route-id="@Model.CourseId" 
               class="btn btn-sm btn-primary fw-semibold px-3" style="font-size:12px;">
                <i class="bi bi-arrow-left me-1"></i>Back to Manage
            </a>
        </div>
    }

    <div class="row g-4 align-items-start">

        @* ── LEFT — video + info ── *@
        <div class="col-lg-8">

            @* video block *@
            <div class="course-video mb-3">
                @if (isYoutube)
                {
                    <iframe src="@embedUrl" title="Course preview" allowfullscreen></iframe>
                }
                else if (!string.IsNullOrEmpty(Model.VideoUrl))
                {
                    @* local mp4 *@
                    <video controls class="w-100">
                        <source src="@Model.VideoUrl" type="video/mp4">
                    </video>
                }
                else
                {
                    @* no video placeholder *@
                    <div class="no-video d-flex align-items-center justify-content-center">
                        <span class="text-muted">No preview video available</span>
                    </div>
                }
            </div>

            @* title + subtitle *@
            <h1 class="fw-bold text-dark mb-2" style="font-size: 2.2rem;">@Model.Title</h1>
            <div class="text-muted fs-5 mb-4" style="font-weight: 400; line-height: 1.4;">@Model.SubTitle</div>

            @* what you'll learn — real outcomes from DB *@
            <div class="card border-0 shadow-sm rounded-4 mb-4" style="background: #fdfdfd; border: 1px solid #f0f0f0 !important;">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3 d-flex align-items-center"><i class="bi bi-bullseye text-orange me-2"></i> What you'll learn</h5>
                    <div class="row g-3">
                        @if (Model.outcomes != null && Model.outcomes.Any())
                        {
                            @foreach (var o in Model.outcomes)
                            {
                                <div class="col-md-6">
                                    <div class="d-flex gap-2">
                                        <i class="bi bi-check2 text-success fw-bold"></i>
                                        <span class="text-muted small">@o.Outcome</span>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="col-12 text-muted small">Learning outcomes coming soon.</div>
                        }
                    </div>
                </div>
            </div>

            @* course description *@
            @if (!string.IsNullOrEmpty(Model.Desciption))
            {
                <div class="mb-4">
                    <h5 class="fw-bold mb-3 d-flex align-items-center"><i class="bi bi-info-circle text-orange me-2"></i> About this course</h5>
                    <p class="text-muted" style="line-height: 1.8; font-size: 15px;">@Model.Desciption</p>
                </div>
            }

            @* dynamic modules (curriculum) *@
            <div class="course-box mb-4">
                <div class="cat-title mb-3"><i>📚</i> Course Curriculum · @(Model.modules?.Count ?? 0) Modules</div>

                <div class="accordion accordion-flush border rounded-3 overflow-hidden" id="moduleAccordion">
                    @if (Model.modules != null && Model.modules.Any())
                    {
                        @for (int i = 0; i < Model.modules.Count; i++)
                        {
                            var module = Model.modules[i];
                            <div class="accordion-item border-bottom">
                                <h2 class="accordion-header">
                                    <button class="accordion-button @(i == 0 ? "" : "collapsed") bg-light py-3" type="button"
                                            data-bs-toggle="collapse"
                                            data-bs-target="#mod-@module.Id">
                                        <span class="mod-num me-3">@(i + 1)</span>
                                        <span class="fw-bold text-dark" style="font-size: 14px;">@module.ModuleName</span>
                                    </button>
                                </h2>
                                <div id="mod-@module.Id" class="accordion-collapse collapse @(i == 0 ? "show" : "")"
                                     data-bs-parent="#moduleAccordion">
                                    <div class="accordion-body p-0">
                                        <div class="list-group list-group-flush">
                                            @foreach (var lesson in module.Lessons)
                                            {
                                                <div class="list-group-item border-0 d-flex align-items-center gap-2 py-2 ps-5 bg-white">
                                                    <i class="bi bi-play-circle text-muted" style="font-size: 13px;"></i>
                                                    <span class="text-muted small">@lesson.Title</span>
                                                </div>
                                            }
                                            @if (!module.Lessons.Any())
                                            {
                                                <div class="p-3 text-center text-muted small">Lessons coming soon.</div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="p-4 text-center text-muted small bg-light">Curriculum details are being updated.</div>
                    }
                </div>

                <p class="mt-3 mb-0 text-end small">
                    <span class="c-off fw-semibold">✨ Full lifetime access included</span>
                </p>
            </div>

        </div>


        @* ── RIGHT — enroll card ── *@
        <div class="col-lg-4">
            <div class="course-box sticky-top" style="top: 80px;">

                @* price *@
                <div class="c-price-row mb-1">
                    <div class="d-flex align-items-center flex-wrap gap-2">
                        <span class="c-price">₹@Model.TotalPrice</span>
                        <span class="c-original">₹@Model.ActualPrice</span>
                        @if (Model.DiscountPercent > 0)
                        {
                            <span class="c-off">@Model.DiscountPercent% OFF</span>
                        }
                    </div>
                </div>

                <div class="text-muted small mb-3">⚡ Limited time offer</div>

                @* Action Row: Enroll, Cart, Wishlist *@
                <div class="d-flex flex-column gap-2 mb-3">
                    @if (isPreview)
                    {
                        <button class="c-btn enroll-btn w-100 border-0 opacity-75" disabled style="cursor: not-allowed; background: #6c757d;">
                            Enroll Now
                        </button>
                        <button class="c-btn cart-btn-secondary w-100 border-0 opacity-75" disabled style="cursor: not-allowed;">
                            🛒 Add to Cart
                        </button>
                    }
                    else
                    {
                        @* Primary Action *@
                        <a asp-area="User" asp-controller="Home" asp-action="Checkout" asp-route-courseId="@Model.CourseId" 
                           class="c-btn enroll-btn w-100 text-center text-decoration-none py-2 fw-bold">
                            Enroll Now
                        </a>

                        @* Secondary Actions Row *@
                        <div class="d-flex align-items-center gap-3">
                            <button onclick="addToCart(@Model.CourseId)" class="c-btn cart-btn-secondary flex-grow-1 border-0 py-2">
                                🛒 Add to Cart
                            </button>
                            
                            <button class="wish-heart-btn @(Model.IsWishlisted ? "wishlisted" : "")" 
                                    onclick="toggleWishlistLarge(this, @Model.CourseId)" title="Add to Wishlist">
                                <i class="bi @(Model.IsWishlisted ? "bi-heart-fill" : "bi-heart")"></i>
                            </button>
                        </div>
                    }
                </div>
                @* trust points *@
                <ul class="list-unstyled small mb-3">
                    <li>✔ Lifetime access, anywhere</li>
                    <li>✔ Certificate of completion</li>
                    <li>✔ 30-day money-back guarantee</li>
                    <li>✔ 24x7 doubt clearing</li>
                </ul>

                <hr>

                <div class="d-flex justify-content-between small">
                    <span>🗣️ Course language</span>
                    <strong style="color:var(--orange);">@Model.languange (@Model.supportLanguage)</strong>
                </div>

                <div class="mt-3 text-center small opacity-75">⏳ Students already enrolled</div>
            </div>
        </div>

    </div>
</div>


@* ── module accordion styles ── *@
<style>
    /* module number badge */
    .mod-num {
        width: 26px;
        height: 26px;
        background: var(--orange);
        color: #fff;
        border-radius: 50%;
        font-size: 12px;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .module-btn {
        background: #f8f9fa;
        font-weight: 600;
        border-radius: 8px !important;
        border: 1px solid #eee;
    }

        .module-btn:not(.collapsed) {
            background: var(--orange-soft, rgba(255,122,0,.08));
            color: var(--orange);
            border-color: var(--orange);
        }

    /* no-video placeholder box */
    .no-video {
        height: 280px;
        background: #f0f0f0;
        border-radius: 12px;
    }

    /* secondary cart button */
    .cart-btn-secondary {
        background: var(--orange-soft, rgba(255,122,0,.08));
        color: var(--orange);
        font-weight: 600;
        border-radius: 8px;
        transition: .2s;
    }
    .cart-btn-secondary:hover {
        background: var(--orange);
        color: #fff;
    }

    /* wishlist heart toggle */
    .wish-heart-btn {
        background: transparent !important;
        border: none !important;
        padding: 4px !important;
        cursor: pointer !important;
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        transition: all 0.3s ease !important;
        outline: none !important;
        box-shadow: none !important;
        -webkit-appearance: none !important;
    }

    .wish-heart-btn i {
        font-size: 1.8rem !important;
        color: #ff69b4 !important; /* Pink Stroke/Fill */
        transition: all 0.3s ease !important;
        display: block !important;
        line-height: 1 !important;
    }

    .wish-heart-btn:hover {
        transform: scale(1.15) !important;
    }

    .wish-heart-btn:hover i {
        filter: drop-shadow(0 0 6px rgba(255, 105, 180, 0.5)) !important;
    }

    /* Filled state when wishlisted */
    .wish-heart-btn.wishlisted i::before {
        content: "\f415" !important; /* bi-heart-fill */
        font-family: "bootstrap-icons" !important;
    }
    </style>

<script>
    function addToCart(courseId) {
        $.post('/User/Home/AddToCart', { courseId: courseId }, function (res) {
            if (res.success) {
                showAlert("Added to cart successfully!", "success");
                setTimeout(() => {
                    window.location.href = '/User/Home/Cart';
                }, 800);
            } else {
                if (res.message === "Please login first") {
                    window.location.href = '/User/Auth/StudentLogin';
                } else {
                    showAlert(res.message, "info");
                }
            }
        });
    }

    function toggleWishlistLarge(btn, courseId) {
        $.post('/User/Home/ToggleWishlist', { courseId: courseId }, function (res) {
            if (res.success) {
                btn.classList.toggle('wishlisted');
                const icon = btn.querySelector('i');
                if (res.added) {
                    icon.classList.remove('bi-heart');
                    icon.classList.add('bi-heart-fill');
                    showAlert("Added to wishlist", "success");
                    // simple pop effect
                    btn.style.transform = "scale(1.3)";
                    setTimeout(() => btn.style.transform = "", 200);
                } else {
                    icon.classList.remove('bi-heart-fill');
                    icon.classList.add('bi-heart');
                    showAlert("Removed from wishlist", "info");
                }
            } else {
                if (res.message === "Please login first") {
                    window.location.href = '/User/Auth/StudentLogin';
                } else {
                    showAlert(res.message || "Failed to update wishlist", "danger");
                }
            }
        });
    }
</script>
