@model SkillForge.Models.CoursePageVM

@{
    Layout = "/Areas/User/Views/Shared/_StudentLayout.cshtml";
    ViewData["Title"] = "Courses";
    ViewData["Subtitle"] = "Explore our latest courses and expand your skills";
}


<main>

    @* ── hero ── *@
    <div class="course-hero">
        <div class="hero-inner">
            <h1 class="hero-title">
                Upgrade Your Skills with <span class="text-highlight">Industry-Ready</span> Courses
            </h1>
            <p class="hero-subtitle">Learn faster. Build real projects. Get job-ready.</p>
        </div>
    </div>

    @* ── category pills ── *@
    @{
        var fixedCategories = new List<string>
        {
            "Software Development", "Data Science",
            "AI / ML", "DevOps & Cloud", "Cybersecurity"
        };

        var dynamicCategories = Model.CategorySections
            .Where(c => c.Courses != null && c.Courses.Any())
            .Select(c => c.CategoryName)
            .ToList();
    }

    <div class="cat-scroll">
        @foreach (var cat in fixedCategories)
        {
            <button class="cat-pill" onclick="moveCategory('@cat', this)">@cat</button>
        }
        @foreach (var cat in dynamicCategories)
        {
            if (!fixedCategories.Contains(cat))
            {
                <button class="cat-pill" onclick="moveCategory('@cat', this)">@cat</button>
            }
        }
    </div>


    @* ── popular courses row ── *@
    <div class="category-section">
        <div class="sec-head">
            <div class="cat-left">
                <span class="cat-bar"></span>
                <h2>Popular Courses</h2>
            </div>
        </div>

        <div class="position-relative course-section-inner">
            <span class="arr left" onclick="scrollRow(this, -1)">‹</span>

            <div class="course-row">
                @foreach (var course in Model.PopularCourses)
                {
                    <partial name="_CourseCardPartial" model="course" />
                }
            </div>

            <span class="arr right" onclick="scrollRow(this, 1)">›</span>
        </div>
    </div>


    @* ── category-wise rows ── *@
    @foreach (var category in Model.CategorySections)
    {
        if (category.Courses != null && category.Courses.Any())
        {
            <div class="category-section" data-cat="@category.CategoryName">
                <div class="sec-head">
                    <div class="cat-left">
                        <span class="cat-bar"></span>
                        <h2>@category.CategoryName</h2>
                    </div>
                </div>

                <div class="position-relative course-section-inner">
                    <span class="arr left" onclick="scrollRow(this, -1)">‹</span>

                    <div class="course-row">
                        @foreach (var course in category.Courses)
                        {
                            <partial name="_CourseCardPartial" model="course" />
                        }
                    </div>

                    <span class="arr right" onclick="scrollRow(this, 1)">›</span>
                </div>
            </div>
        }
    }

</main>


@* ── heart toggle + scroll scripts ── *@
<style>
    /* heart button base — white circle, pink stroke */
    .wish-btn {
        position: absolute;
        top: 12px;
        right: 12px;
        width: 34px;
        height: 34px;
        border-radius: 50%;
        background: #fff;
        border: none;
        box-shadow: 0 4px 10px rgba(0,0,0,0.12);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        z-index: 2;
        padding: 0;
        line-height: 0;
    }

    .wish-btn:hover {
        transform: scale(1.1);
        box-shadow: 0 6px 15px rgba(0,0,0,0.15);
    }

    .wish-btn i {
        font-size: 18px;
        color: #ff69b4; /* Pink */
        display: flex;
        align-items: center;
        justify-content: center;
        transition: .2s ease;
    }

    /* filled state when wishlisted */
    .wish-btn.wishlisted i::before {
        content: "\f415"; /* bi-heart-fill unicode */
        font-family: "bootstrap-icons";
    }
</style>

<script>
    // ── horizontal scroll ──
    function scrollRow(el, dir) {
        const container = el.closest('.course-section-inner');
        const row = container.querySelector('.course-row');
        const card = row.querySelector('.c-card');
        if (!card) return;
        const scrollAmount = (card.offsetWidth + 16) * 3;
        row.scrollBy({ left: scrollAmount * dir, behavior: 'smooth' });
    }

    // ── move clicked category section to top ──
    function moveCategory(catName, btn) {
        // highlight active pill
        document.querySelectorAll('.cat-pill').forEach(p => p.classList.remove('active'));
        btn.classList.add('active');

        const target = document.querySelector(`.category-section[data-cat="${catName}"]`);
        if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
</script>
