@model SkillForge.Models.CoursePageVM

@{
    Layout = "/Areas/User/Views/Shared/_StudentLayout.cshtml";
    ViewData["Title"] = "Courses";
}

<main>

    @* ── hero ── *@
    <div class="course-hero">
        <h1>Upgrade Your Skills with Industry-Ready Courses</h1>
        <p>Learn faster. Build real projects. Get job-ready.</p>
    </div>

    @* ── category pills ── *@
    @{
        var fixedCategories = new List<string>
        {
            "Software Development", "Data Science",
            "AI / ML", "DevOps & Cloud", "Cybersecurity"
        };

        var dynamicCategories = Model.CategorySections
            .Where(c => c.Courses != null && c.Courses.Any())
            .Select(c => c.CategoryName)
            .ToList();
    }

    <div class="cat-scroll">
        @foreach (var cat in fixedCategories)
        {
            <button class="cat-pill" onclick="moveCategory('@cat', this)">@cat</button>
        }
        @foreach (var cat in dynamicCategories)
        {
            if (!fixedCategories.Contains(cat))
            {
                <button class="cat-pill" onclick="moveCategory('@cat', this)">@cat</button>
            }
        }
    </div>


    @* ── popular courses row ── *@
    <div class="category-section">
        <div class="sec-head">
            <div class="cat-left">
                <span class="cat-bar"></span>
                <h2>Popular Courses</h2>
            </div>
        </div>

        <div class="position-relative course-section-inner">
            <span class="arr left" onclick="scrollRow(this, -1)">‹</span>

            <div class="course-row">
                @foreach (var course in Model.PopularCourses)
                {
                    <div class="c-card">
                        <div class="c-thumb">
                            <img src="@(course.Thumbnail_Url ?? "https://via.placeholder.com/300")" alt="@course.Title">
                            <span class="diff-tag">@course.Difficulty</span>

                            @* heart — white circle, red border, fills red on click *@
                            <button class="wish-btn @(course.IsWishListed == true ? "wishlisted" : "")" 
                                    onclick="toggleWishlist(event, this, @course.courseId)" 
                                    title="@(course.IsWishListed == true ? "Remove from wishlist" : "Add to wishlist")">
                                <i class="bi @(course.IsWishListed == true ? "bi-heart-fill" : "bi-heart")"></i>
                            </button>
                        </div>

                        <div class="c-body">
                            <div class="c-cat">@course.CategoryName</div>
                            <div class="c-title">@course.Title</div>
                            <div class="c-sub">@course.SubTitle</div>

                            <div class="c-price-row">
                                <div>
                                    <span class="c-price">₹@course.Total_Price</span>
                                    <span class="c-original">₹@course.Actual_Price</span>
                                </div>
                                <span class="c-off">@course.Discount_Percent% OFF</span>
                            </div>

                            @* pass courseId to details page *@
                            <a href="/User/Home/CourseDetails?id=@course.courseId" class="c-btn d-block text-center text-decoration-none">
                                Check Course →
                            </a>
                        </div>
                    </div>
                }
            </div>

            <span class="arr right" onclick="scrollRow(this, 1)">›</span>
        </div>
    </div>


    @* ── category-wise rows ── *@
    @foreach (var category in Model.CategorySections)
    {
        if (category.Courses != null && category.Courses.Any())
        {
            <div class="category-section" data-cat="@category.CategoryName">
                <div class="sec-head">
                    <div class="cat-left">
                        <span class="cat-bar"></span>
                        <h2>@category.CategoryName</h2>
                    </div>
                </div>

                <div class="position-relative course-section-inner">
                    <span class="arr left" onclick="scrollRow(this, -1)">‹</span>

                    <div class="course-row">
                        @foreach (var course in category.Courses)
                        {
                            <div class="c-card">
                                <div class="c-thumb">
                                    <img src="@(course.Thumbnail_Url ?? "https://via.placeholder.com/300")" alt="@course.Title">
                                    <span class="diff-tag">@course.Difficulty</span>

                                    <button class="wish-btn @(course.IsWishListed == true ? "wishlisted" : "")" 
                                            onclick="toggleWishlist(event, this, @course.courseId)" 
                                            title="@(course.IsWishListed == true ? "Remove from wishlist" : "Add to wishlist")">
                                        <i class="bi @(course.IsWishListed == true ? "bi-heart-fill" : "bi-heart")"></i>
                                    </button>
                                </div>

                                <div class="c-body">
                                    <div class="c-cat">@course.CategoryName</div>
                                    <div class="c-title">@course.Title</div>
                                    <div class="c-sub">@course?.SubTitle</div>

                                    <div class="c-price-row">
                                        <div>
                                            <span class="c-price">₹@course.Total_Price</span>
                                            <span class="c-original">₹@course.Actual_Price</span>
                                        </div>
                                        <span class="c-off">@course.Discount_Percent% OFF</span>
                                    </div>

                                    <a href="/User/Home/CourseDetails?id=@course.courseId" class="c-btn d-block text-center text-decoration-none">
                                        Check Course →
                                    </a>
                                </div>
                            </div>
                        }
                    </div>

                    <span class="arr right" onclick="scrollRow(this, 1)">›</span>
                </div>
            </div>
        }
    }

</main>


@* ── heart toggle + scroll scripts ── *@
<style>
    /* heart button base — white circle, pink stroke */
    .wish-btn {
        position: absolute;
        top: 12px;
        right: 12px;
        width: 34px;
        height: 34px;
        border-radius: 50%;
        background: #fff;
        border: none;
        box-shadow: 0 4px 10px rgba(0,0,0,0.12);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        z-index: 2;
        padding: 0;
        line-height: 0;
    }

    .wish-btn:hover {
        transform: scale(1.1);
        box-shadow: 0 6px 15px rgba(0,0,0,0.15);
    }

    .wish-btn i {
        font-size: 18px;
        color: #ff69b4; /* Pink */
        display: flex;
        align-items: center;
        justify-content: center;
        transition: .2s ease;
    }

    /* filled state when wishlisted */
    .wish-btn.wishlisted i::before {
        content: "\f415"; /* bi-heart-fill unicode */
        font-family: "bootstrap-icons";
    }
</style>

<script>
    // ── heart toggle AJAX ──
    function toggleWishlist(event, btn, courseId) {
        // stop event from bubbling up to card click
        event.preventDefault();
        event.stopPropagation();

        $.post('/User/Home/ToggleWishlist', { courseId: courseId }, function (res) {
            if (res.success) {
                btn.classList.toggle('wishlisted');
                const icon = btn.querySelector('i');
                if (res.added) {
                    icon.classList.remove('bi-heart');
                    icon.classList.add('bi-heart-fill');
                    btn.title = "Remove from wishlist";
                    showAlert("Added to wishlist", "success");
                    // heart pop effect
                    btn.style.transform = "scale(1.3)";
                    setTimeout(() => btn.style.transform = "", 200);
                } else {
                    icon.classList.remove('bi-heart-fill');
                    icon.classList.add('bi-heart');
                    btn.title = "Add to wishlist";
                    showAlert("Removed from wishlist", "info");
                }
            } else {
                if (res.message === "Please login first") {
                    window.location.href = '/User/Auth/StudentLogin';
                } else {
                    showAlert(res.message || "Failed to update wishlist", "danger");
                }
            }
        });
    }

    // ── horizontal scroll ──
    function scrollRow(el, dir) {
        const container = el.closest('.course-section-inner');
        const row = container.querySelector('.course-row');
        const card = row.querySelector('.c-card');
        if (!card) return;
        const scrollAmount = (card.offsetWidth + 16) * 3;
        row.scrollBy({ left: scrollAmount * dir, behavior: 'smooth' });
    }

    // ── move clicked category section to top ──
    function moveCategory(catName, btn) {
        // highlight active pill
        document.querySelectorAll('.cat-pill').forEach(p => p.classList.remove('active'));
        btn.classList.add('active');

        const target = document.querySelector(`.category-section[data-cat="${catName}"]`);
        if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
</script>
