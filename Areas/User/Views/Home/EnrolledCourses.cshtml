@model List<CourseCardVM>

@{
    Layout = "/Areas/User/Views/Shared/_StudentLayout.cshtml";
}
<main>
<div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-3">
    <div>
        <h4 class="fw-bold mb-0">My Courses</h4>
        <span class="text-muted small">@Model.Count courses enrolled</span>
    </div>
    <a href="/Courses" class="btn-orange">Browse More</a>
</div>

<!-- loop through enrolled courses -->
<div class="d-flex flex-column gap-3" id="courseList">
    @foreach(var course in Model)
    {
        <div class="my-course-card" data-status="inprogress" data-title="@course.Title">
            <img src="@course.Thumbnail_Url" alt="">
            <div class="card-body">
                <h6 class="fw-bold mb-1">@course.Title</h6>
                <p class="text-muted small mb-2">@course.SubTitle</p>
                <!-- progress bar  -->

            </div>
        </div>
    }
</div>
</main>


<style>
    /* course card — landscape layout for my courses page */
    .my-course-card {
        background: #fff;
        border: 1px solid #eee;
        border-radius: 14px;
        overflow: hidden;
        display: flex;
        gap: 0;
        transition: box-shadow .2s, transform .2s;
    }

        .my-course-card:hover {
            box-shadow: 0 6px 24px rgba(0,0,0,.09);
            transform: translateY(-2px);
        }

        .my-course-card img {
            width: 200px;
            height: 140px;
            object-fit: cover;
            flex-shrink: 0;
        }

        .my-course-card .card-body {
            padding: 16px;
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

    /* filter pill — same as index.html */
    .filter-pill {
        padding: 6px 16px;
        border-radius: 50px;
        border: 1.5px solid #eee;
        background: #fff;
        font-size: .82rem;
        font-weight: 500;
        cursor: pointer;
        transition: .2s;
        color: var(--muted);
    }

        .filter-pill:hover, .filter-pill.active {
            background: var(--orange);
            border-color: var(--orange);
            color: #fff;
        }

    /* progress label */
    .progress-label {
        font-size: .75rem;
        font-weight: 600;
        color: var(--orange);
    }

        .progress-label.done {
            color: #2e7d32;
        }

    media (max-width: 576px) {
        .my-course-card

    {
        flex-direction: column;
    }

    .my-course-card img {
        width: 100%;
        height: 160px;
    }

    }
</style>