@model List<CourseCardVM>

@{
    Layout = "/Areas/User/Views/Shared/_StudentLayout.cshtml";
    ViewData["Title"] = "My Enrolled Courses";
}

<div class="container-fluid py-4">
    @* header *@
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h4 class="fw-bold mb-1 text-dark">My Learning</h4>
            <span class="text-muted small">@Model.Count courses currently in progress</span>
        </div>
        <a href="/User/Home/Courses" class="btn btn-orange px-4 rounded-pill fw-semibold shadow-sm">
            Explore More Courses
        </a>
    </div>

    @* enrolled courses grid *@
    <div class="row row-cols-1 row-cols-xxl-2 g-4" id="courseList">
        @foreach (var course in Model)
        {
            <div class="col">
                <a href="/User/Home/LearningView?id=@course.courseId" class="text-decoration-none">
                    <div class="course-card-horizontal h-100 border shadow-sm rounded-0 overflow-hidden bg-white d-flex transition-all">
                        
                        @* thumbnail *@
                        <div class="thumbnail-container flex-shrink-0" style="width: 220px; background: #f8f9fa;">
                            <img src="@(string.IsNullOrEmpty(course.Thumbnail_Url) ? "/images/CoursePlaceholder.png" : course.Thumbnail_Url)" 
                                 class="w-100 h-100" style="object-fit: cover;" alt="@course.Title">
                        </div>

                        @* content *@
                        <div class="card-body p-3 d-flex flex-column justify-content-between">
                            <div>
                                <h6 class="fw-bold text-dark mb-1 text-truncate-2" style="font-size: 16px; line-height: 1.3; min-height: 42px;">@course.Title</h6>
                                <p class="text-muted mb-2" style="font-size: 12px;">@course.CategoryName</p>
                            </div>

                            @* progress *@
                            <div class="progress-section">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <span class="fw-bold" style="font-size: 12px; color: #ff6600;">@course.ProgressPercentage% Complete</span>
                                    
                                    @* rating (UI only) *@
                                    <div class="text-warning" style="font-size: 10px;">
                                        <i class="bi bi-star-fill"></i>
                                        <i class="bi bi-star-fill"></i>
                                        <i class="bi bi-star-fill"></i>
                                        <i class="bi bi-star-fill"></i>
                                        <i class="bi bi-star-half opacity-50"></i>
                                    </div>
                                </div>
                                <div class="progress" style="height: 6px; background-color: #f1f3f5; border-radius: 0;">
                                    <div class="progress-bar" role="progressbar" 
                                         style="width: @course.ProgressPercentage%; background-color: #ff6600;" 
                                         aria-valuenow="@course.ProgressPercentage" aria-valuemin="0" aria-valuemax="100"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
</div>

<style>
    /* landscape card styles */
    .course-card-horizontal {
        border-color: #d1d7dc !important;
        transition: background-color 0.2s;
    }
    .course-card-horizontal:hover {
        background-color: #f7f9fa !important;
    }
    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .btn-orange {
        background-color: #ff6600;
        color: white;
        border: none;
    }
    .btn-orange:hover {
        background-color: #e65c00;
        color: white;
    }

    /* mobile responsive */
    @@media (max-width: 576px) {
        .course-card-horizontal {
            flex-direction: column;
        }
        .thumbnail-container {
            width: 100% !important;
            height: 160px !important;
        }
    }
</style>
