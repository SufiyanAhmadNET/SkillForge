<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SkillForge</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@500;700;800&display=swap" rel="stylesheet">

    <link href="/css/index.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/courses.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/User.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/alert.css" rel="stylesheet" asp-append-version="true" />
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</head>

<body class="student-layout">

    <!-- ── HEADER ── -->
    <header class="sf-header">

        <!-- Left: Brand -->
        <div class="d-flex align-items-center gap-3">
            <a class="sf-brand" asp-area="User" asp-controller="Home" asp-action="Courses">
                <i class="bi bi-mortarboard-fill"></i> SkillForge
            </a>
            <div class="d-none d-lg-flex align-items-center gap-3">
                <a asp-area="User" asp-controller="Home" asp-action="Dashboard" class="sf-explore">
                    Dashboard
                </a>
                <a asp-area="User" asp-controller="Home" asp-action="Courses" class="sf-explore">
                    Explore
                </a>
            </div>
        </div>

        <!-- Center: search — hidden on mobile, shown on md+ -->
        <div class="sf-search d-none d-md-flex" style="max-width:380px; width:100%;">
            <i class="bi bi-search" style="font-size:13px;"></i>
            <input type="text" placeholder="Search courses..." style="font-size:13px;" />
        </div>

        <!-- Right: links + bell + apps + avatar -->
        <div class="sf-header-right">

            <div class="sf-header-links d-none d-xl-flex">
                <a href="#" class="sf-hlink">FAQ</a>
                <a href="#" class="sf-hlink">Help</a>
                <a href="#" class="sf-hlink">Community</a>
            </div>

            <!-- Cart Icon (Shown on all) -->
            <a asp-area="User" asp-controller="Home" asp-action="Cart" class="sf-bell me-1" style="text-decoration:none; position:relative;">
                <i class="bi bi-cart3"></i>
                @if (ViewBag.CartCount > 0)
                {
                    <span class="sf-cart-badge">@ViewBag.CartCount</span>
                }
            </a>

            <!-- Bell (Hidden on small mobile) -->
            <button class="sf-bell d-none d-sm-flex">
                <i class="bi bi-bell"></i>
                <span class="sf-bell-dot"></span>
            </button>

            <!-- Apps grid popup (Hidden on mobile) -->
            <div class="sf-apps-wrap d-none d-md-block">
                <button class="sf-apps-btn" id="appsBtn">
                    <div class="sf-dot-grid">
                        <i></i><i></i><i></i>
                        <i></i><i></i><i></i>
                        <i></i><i></i><i></i>
                    </div>
                </button>

                <div class="sf-apps-popup" id="appsMenu">
                    <div class="sf-apps-grid">
                        <a asp-area="User" asp-controller="Home" asp-action="Dashboard" class="sf-app-item">
                            <i class="bi bi-grid-1x2"></i> Dashboard
                        </a>
                        <a asp-area="User" asp-controller="Home" asp-action="EnrolledCourses" class="sf-app-item">
                            <i class="bi bi-play-btn"></i> My Courses
                        </a>
                        <a asp-area="User" asp-controller="Home" asp-action="Cart" class="sf-app-item">
                            <i class="bi bi-cart3"></i> Cart
                        </a>
                        <a asp-area="User" asp-controller="Home" asp-action="Wishlist" class="sf-app-item">
                            <i class="bi bi-heart"></i> Wishlist
                        </a>
                        <a asp-area="User" asp-controller="Home" asp-action="Certificates" class="sf-app-item">
                            <i class="bi bi-award"></i> Certificates
                        </a>
                        <a asp-area="User" asp-controller="Home" asp-action="Orders" class="sf-app-item">
                            <i class="bi bi-receipt"></i> Orders
                        </a>
                    </div>
                </div>
            </div>

            <!-- Avatar + profile dropdown (Hidden on mobile) -->
            <div class="sf-profile d-none d-md-block" id="profileBtn">
                <button class="sf-avatar-btn">
                    <img class="sf-avatar-img" src="@((ViewBag.PhotoPath ?? "/images/DefaultProfilePhoto.jfif") + "?t=" + DateTime.Now.Ticks)" alt="Profile" />
                </button>

                <div class="sf-profile-menu" id="profileMenu">

                    <!-- User Profile Info -->
                    <div class="sf-profile-head">
                        <img src="@(ViewBag.PhotoPath ?? "/images/DefaultProfilePhoto.jfif")" class="sf-profile-thumb" alt="Profile" />
                        <div>
                            <div class="sf-profile-name">@(string.IsNullOrEmpty(ViewBag.FirstName) ? "Guest User" : $"{ViewBag.FirstName} {ViewBag.LastName}")</div>
                            <div class="sf-profile-meta" style="font-size:11px;color:#666">@ViewBag.Email</div>
                        </div>
                    </div>

                    <a class="sf-menu-item" asp-area="User" asp-controller="Home" asp-action="Profile">
                        <i class="bi bi-person"></i> My Profile
                    </a>
                    <a class="sf-menu-item" asp-area="User" asp-controller="Home" asp-action="Dashboard">
                        <i class="bi bi-house"></i> Home
                    </a>

                    <div style="height:1px;background:#eee;margin:8px 0;"></div>

                    <!-- icon-only actions row -->
                    <div class="sf-icon-row">
                        <a asp-area="User" asp-controller="Profile" asp-action="ChangePassword" class="sf-icon-btn">
                            <i class="bi bi-key"></i>
                        </a>
                        <form asp-area="User" asp-controller="Auth" asp-action="Logout" method="post"
                              style="flex:1;display:flex;margin:0">
                            <button type="submit" class="sf-icon-btn sf-icon-danger" style="width:100%;border:none">
                                <i class="bi bi-box-arrow-right"></i>
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Mobile Menu Toggle -->
            <button class="btn d-md-none p-2" type="button" data-bs-toggle="offcanvas" data-bs-target="#sfMobileMenu" aria-controls="sfMobileMenu">
                <i class="bi bi-list fs-3"></i>
            </button>

        </div>
    </header>
    <!-- ── /HEADER ── -->

    <!-- ── MOBILE OFFCANVAS ── -->
    <div class="offcanvas offcanvas-end" tabindex="-1" id="sfMobileMenu" aria-labelledby="sfMobileMenuLabel">
        <div class="offcanvas-header border-bottom">
            <h5 class="offcanvas-title fw-bold" id="sfMobileMenuLabel">
                <i class="bi bi-mortarboard-fill text-orange"></i> SkillForge
            </h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body p-0">
            <!-- User Info in Mobile Menu -->
            <div class="p-3 bg-light border-bottom d-flex align-items-center gap-3">
                <img src="@(ViewBag.PhotoPath ?? "/images/DefaultProfilePhoto.jfif")" class="sf-avatar-img" style="width:50px; height:50px;" alt="Profile" />
                <div>
                    <div class="fw-bold">@(string.IsNullOrEmpty(ViewBag.FirstName) ? "Guest User" : $"{ViewBag.FirstName} {ViewBag.LastName}")</div>
                    <div class="text-muted small">@ViewBag.Email</div>
                </div>
            </div>

            <div class="list-group list-group-flush">
                <a asp-area="User" asp-controller="Home" asp-action="Dashboard" class="list-group-item list-group-item-action py-3">
                    <i class="bi bi-grid-1x2 me-2"></i> Dashboard
                </a>
                <a asp-area="User" asp-controller="Home" asp-action="Courses" class="list-group-item list-group-item-action py-3">
                    <i class="bi bi-compass me-2"></i> Explore Courses
                </a>
                <a asp-area="User" asp-controller="Home" asp-action="EnrolledCourses" class="list-group-item list-group-item-action py-3">
                    <i class="bi bi-play-btn me-2"></i> My Enrolled Courses
                </a>
                <a asp-area="User" asp-controller="Home" asp-action="Wishlist" class="list-group-item list-group-item-action py-3">
                    <i class="bi bi-heart me-2"></i> My Wishlist
                </a>
                <a asp-area="User" asp-controller="Home" asp-action="Cart" class="list-group-item list-group-item-action py-3 d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-cart3 me-2"></i> My Cart</span>
                    @if (ViewBag.CartCount > 0)
                    {
                        <span class="badge bg-orange rounded-pill">@ViewBag.CartCount</span>
                    }
                </a>
                <a asp-area="User" asp-controller="Home" asp-action="Profile" class="list-group-item list-group-item-action py-3">
                    <i class="bi bi-person me-2"></i> My Profile
                </a>
                <a asp-area="User" asp-controller="Home" asp-action="Orders" class="list-group-item list-group-item-action py-3">
                    <i class="bi bi-receipt me-2"></i> Order History
                </a>
                <a asp-area="User" asp-controller="Home" asp-action="Certificates" class="list-group-item list-group-item-action py-3">
                    <i class="bi bi-award me-2"></i> Certificates
                </a>
                <div class="p-3 mt-2">
                    <form asp-area="User" asp-controller="Auth" asp-action="Logout" method="post">
                        <button type="submit" class="btn btn-outline-danger w-100">
                            <i class="bi bi-box-arrow-right me-2"></i> Logout
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- ── PAGE TITLE BANNER ── -->
    <div class="sf-page-title-banner">
        <div class="sf-page-title-content">
            <h1>@ViewData["Title"]</h1>
        </div>
    </div>

    <partial name="_Alert_Message_Partial" />

    <!-- ── PAGE BODY  ── -->
    <main class="sf-page-body">
        @RenderBody()
    </main>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const appsBtn    = document.getElementById('appsBtn');
            const appsMenu   = document.getElementById('appsMenu');
            const profileBtn = document.getElementById('profileBtn');
            const profileMenu = document.getElementById('profileMenu');

            function closeAll() {
                appsMenu?.classList.remove('open');
                appsBtn?.classList.remove('active-btn');
                profileMenu?.classList.remove('open');
                profileBtn?.classList.remove('active-btn');
            }

            function toggle(menu, btn, e) {
                e.stopPropagation();
                const wasOpen = menu.classList.contains('open');
                closeAll();
                if (!wasOpen) {
                    menu.classList.add('open');
                    btn.classList.add('active-btn');
                }
            }

            appsBtn?.addEventListener('click', e => toggle(appsMenu, appsBtn, e));

            profileBtn.querySelector('.sf-avatar-btn')
                      ?.addEventListener('click', e => toggle(profileMenu, profileBtn, e));

            // clicks inside popups shouldn't close them
            appsMenu?.addEventListener('click',    e => e.stopPropagation());
            profileMenu?.addEventListener('click', e => e.stopPropagation());

            document.addEventListener('click',   closeAll);
            document.addEventListener('keydown', e => { if (e.key === 'Escape') closeAll(); });
        });

    </script>
    <script src="~/js/Alert.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
