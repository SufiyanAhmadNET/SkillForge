                                <span class="ms-auto text-muted fw-normal small me-3">12 lectures · 10h</span>
                            </button>
                        </h2>
                        <div id="sec3" class="accordion-collapse collapse">
                            <div class="accordion-body pt-0">
                                <div class="lecture-row">
                                    <span><i class="bi bi-play-circle me-2 text-muted"></i>React Setup & JSX</span>
                                    <span class="text-muted small">42:00</span>
                                </div>
                                <div class="lecture-row">
                                    <span><i class="bi bi-play-circle me-2 text-muted"></i>Components & Props</span>
                                    <span class="text-muted small">58:00</span>
                                </div>
                            </div>
                        </div>
                    </div>

                </div><!-- /accordion -->
            </div><!-- /curriculum -->
            <!-- REVIEWS TAB (hidden by default) -->
