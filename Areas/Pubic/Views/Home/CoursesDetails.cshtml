@model SkillForge.Models.CourseDetailsVM

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = Model.Title ?? "Course Details";
}

<link rel="stylesheet" href="~/css/courses.css" />

@* ── helper method to detect youtube vs local video ── *@
@{
    bool isYoutube = !string.IsNullOrEmpty(Model.VideoUrl) &&
                     (Model.VideoUrl.Contains("youtube") || Model.VideoUrl.Contains("youtu.be"));

    string embedUrl = isYoutube
        ? Model.VideoUrl!
              .Replace("watch?v=", "embed/")
              .Replace("youtu.be/", "www.youtube.com/embed/")
              .Split('?')[0]
        : Model.VideoUrl ?? "";
}

<div class="container-fluid px-4 px-lg-5 py-5">
    <div class="row g-4 align-items-start">

        @* ── LEFT — video + info ── *@
        <div class="col-lg-8">

            @* video block *@
            <div class="course-video mb-3 rounded-4 overflow-hidden shadow-sm" style="aspect-ratio: 16/9; background: #000;">
                @if (isYoutube)
                {
                    <iframe src="@embedUrl" title="Course preview" allowfullscreen class="w-100 h-100 border-0"></iframe>
                }
                else if (!string.IsNullOrEmpty(Model.VideoUrl))
                {
                    <video controls class="w-100 h-100">
                        <source src="@Model.VideoUrl" type="video/mp4">
                    </video>
                }
                else
                {
                    <div class="d-flex align-items-center justify-content-center h-100 text-white opacity-50">
                        <i class="bi bi-play-circle fs-1 me-2"></i>
                        <span>No preview video available</span>
                    </div>
                }
            </div>

            @* title + subtitle *@
            <h1 class="fw-bold text-dark mb-2" style="font-size: 2.2rem; font-family: 'Outfit', sans-serif;">@Model.Title</h1>
            <div class="text-muted fs-5 mb-4" style="font-weight: 400; line-height: 1.4;">@Model.SubTitle</div>

            @* what you'll learn *@
            <div class="card border-0 shadow-sm rounded-4 mb-4" style="background: #fdfdfd; border: 1px solid #f0f0f0 !important;">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3 d-flex align-items-center"><i class="bi bi-bullseye text-orange me-2"></i> What you'll learn</h5>
                    <div class="row g-3">
                        @if (Model.outcomes != null && Model.outcomes.Any())
                        {
                            @foreach (var o in Model.outcomes)
                            {
                                <div class="col-md-6">
                                    <div class="d-flex gap-2">
                                        <i class="bi bi-check2 text-success fw-bold"></i>
                                        <span class="text-muted small">@o.Outcome</span>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="col-12 text-muted small">Learning outcomes coming soon.</div>
                        }
                    </div>
                </div>
            </div>

            @* course description *@
            @if (!string.IsNullOrEmpty(Model.Desciption))
            {
                <div class="mb-4">
                    <h5 class="fw-bold mb-3 d-flex align-items-center"><i class="bi bi-info-circle text-orange me-2"></i> About this course</h5>
                    <p class="text-muted" style="line-height: 1.8; font-size: 15px;">@Model.Desciption</p>
                </div>
            }

            @* dynamic modules (curriculum) *@
            <div class="course-box mb-4 p-4 border rounded-4 bg-white shadow-sm">
                <div class="cat-title mb-3 fw-bold fs-5"><i>📚</i> Course Curriculum · @(Model.modules?.Count ?? 0) Modules</div>

                <div class="accordion accordion-flush border rounded-3 overflow-hidden" id="moduleAccordion">
                    @if (Model.modules != null && Model.modules.Any())
                    {
                        @for (int i = 0; i < Model.modules.Count; i++)
                        {
                            var module = Model.modules[i];
                            <div class="accordion-item border-bottom">
                                <h2 class="accordion-header">
                                    <button class="accordion-button @(i == 0 ? "" : "collapsed") bg-light py-3" type="button"
                                            data-bs-toggle="collapse"
                                            data-bs-target="#mod-@module.Id">
                                        <span class="mod-num me-3">@(i + 1)</span>
                                        <span class="fw-bold text-dark" style="font-size: 14px;">@module.ModuleName</span>
                                    </button>
                                </h2>
                                <div id="mod-@module.Id" class="accordion-collapse collapse @(i == 0 ? "show" : "")"
                                     data-bs-parent="#moduleAccordion">
                                    <div class="accordion-body p-0">
                                        <div class="list-group list-group-flush">
                                            @foreach (var lesson in module.Lessons)
                                            {
                                                <div class="list-group-item border-0 d-flex align-items-center gap-2 py-2 ps-5 bg-white">
                                                    <i class="bi bi-play-circle text-muted" style="font-size: 13px;"></i>
                                                    <span class="text-muted small">@lesson.Title</span>
                                                </div>
                                            }
                                            @if (!module.Lessons.Any())
                                            {
                                                <div class="p-3 text-center text-muted small">Lessons coming soon.</div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="p-4 text-center text-muted small bg-light">Curriculum details are being updated.</div>
                    }
                </div>
                <p class="mt-3 mb-0 text-end small">
                    <span class="c-off fw-semibold">✨ Full lifetime access included</span>
                </p>
            </div>

        </div>


        @* ── RIGHT — enroll card ── *@
        <div class="col-lg-4">
            <div class="card border-0 shadow rounded-4 p-4 sticky-top" style="top: 100px;">

                @* price *@
                <div class="mb-1">
                    <div class="d-flex align-items-center flex-wrap gap-2">
                        <span class="fs-2 fw-bold text-dark">₹@Model.TotalPrice</span>
                        <span class="text-muted text-decoration-line-through">₹@Model.ActualPrice</span>
                        @if (Model.DiscountPercent > 0)
                        {
                            <span class="badge bg-orange-soft text-orange fw-bold">@Model.DiscountPercent% OFF</span>
                        }
                    </div>
                </div>

                <div class="text-muted small mb-4"><i class="bi bi-lightning-fill text-warning"></i> Limited time offer</div>

                <div class="d-flex flex-column gap-2 mb-4">
                    <button onclick="requireLogin('enroll in this course')" class="btn btn-orange btn-lg w-100 py-3 fw-bold">
                        Enroll Now
                    </button>

                    <div class="d-flex align-items-center gap-2">
                        <button onclick="requireLogin('add this course to cart')" class="btn btn-outline-orange flex-grow-1 py-2 fw-semibold">
                            🛒 Add to Cart
                        </button>
                        <button onclick="toggleWishlist(event, this, @Model.CourseId)" class="btn btn-outline-secondary py-2 px-3 wish-btn position-static" style="box-shadow: none;">
                            <i class="bi bi-heart"></i>
                        </button>
                    </div>
                </div>

                @* trust points *@
                <ul class="list-unstyled small mb-4">
                    <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i> Lifetime access, anywhere</li>
                    <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i> Certificate of completion</li>
                    <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i> 30-day money-back guarantee</li>
                    <li class="mb-0"><i class="bi bi-check-circle-fill text-success me-2"></i> 24x7 doubt clearing</li>
                </ul>

                <hr class="mb-4">

                <div class="d-flex justify-content-between align-items-center small">
                    <span class="text-muted">🗣️ Course language</span>
                    <strong class="text-dark">@Model.languange (@Model.supportLanguage)</strong>
                </div>
            </div>
        </div>

    </div>
</div>

<style>
    .bg-orange-soft { background: rgba(255, 122, 0, 0.1); }
    .text-orange { color: var(--orange); }
    .btn-outline-orange {
        color: var(--orange);
        border: 2px solid var(--orange);
        transition: .2s;
    }
    .btn-outline-orange:hover {
        background: var(--orange);
        color: #fff;
    }
    .mod-num {
        width: 26px; height: 26px; background: var(--orange); color: #fff;
        border-radius: 50%; font-size: 12px; font-weight: 700;
        display: inline-flex; align-items: center; justify-content: center;
    }
</style>
