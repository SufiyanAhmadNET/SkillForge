                    <div class="row align-items-center g-4">
                        <div class="col-md-3 text-center">
                            <div class="fw-bold" style="font-size:3.5rem;color:var(--orange);line-height:1">4.9</div>
                            <div class="rating-stars fs-5">★★★★★</div>
                            <div class="text-muted small mt-1">Course Rating</div>
                        </div>
                        <div class="col-md-9">
                            <!-- rating bars -->
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <span class="small text-muted" style="width:16px">5</span>
                                <div class="rating-bar-track"><div class="rating-bar-fill" style="width:85%"></div></div>
                                <span class="small text-muted">85%</span>
                            </div>
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <span class="small text-muted" style="width:16px">4</span>
                                <div class="rating-bar-track"><div class="rating-bar-fill" style="width:10%"></div></div>
                                <span class="small text-muted">10%</span>
                            </div>
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <span class="small text-muted" style="width:16px">3</span>
                                <div class="rating-bar-track"><div class="rating-bar-fill" style="width:3%"></div></div>
                                <span class="small text-muted">3%</span>
                            </div>
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <span class="small text-muted" style="width:16px">2</span>
                                <div class="rating-bar-track"><div class="rating-bar-fill" style="width:1%"></div></div>
                                <span class="small text-muted">1%</span>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                <span class="small text-muted" style="width:16px">1</span>
                                <div class="rating-bar-track"><div class="rating-bar-fill" style="width:1%"></div></div>
                                <span class="small text-muted">1%</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Individual reviews -->
                <div class="bg-white border rounded-3 p-4 mb-3">
                    <div class="d-flex gap-3 mb-2">
                        <img src="https://randomuser.me/api/portraits/men/21.jpg"
                             width="40" height="40" class="rounded-circle object-fit-cover" alt="">
                        <div>
                            <div class="fw-semibold small">Rahul Joshi</div>
                            <div class="rating-stars small">★★★★★</div>
