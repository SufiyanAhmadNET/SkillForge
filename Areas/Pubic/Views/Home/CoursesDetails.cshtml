                                        <span class="text-muted small">12:30</span>
                                    </div>
                                </div>
                                <div class="lecture-row">
                                    <span><i class="bi bi-play-circle me-2 text-muted"></i>HTML Structure & Semantic Tags</span>
                                    <span class="text-muted small">45:00</span>
                                </div>
                                <div class="lecture-row">
                                    <span><i class="bi bi-play-circle me-2 text-muted"></i>CSS Selectors & Box Model</span>
                                    <span class="text-muted small">52:00</span>
                                </div>
                                <div class="lecture-row">
                                    <span><i class="bi bi-play-circle me-2 text-muted"></i>Flexbox & Grid Layout</span>
                                    <div class="d-flex gap-2 align-items-center">
                                        <span class="badge-preview">Free Preview</span>
                                        <span class="text-muted small">1:04:00</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Section 2 -->
                    <div class="accordion-item border rounded-3 mb-2">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed fw-semibold" type="button"
                                    data-bs-toggle="collapse" data-bs-target="#sec2">
                                Section 2: JavaScript Fundamentals
                                <span class="ms-auto text-muted fw-normal small me-3">10 lectures · 8h</span>
                            </button>
                        </h2>
                        <div id="sec2" class="accordion-collapse collapse">
                            <div class="accordion-body pt-0">
                                <div class="lecture-row">
                                    <span><i class="bi bi-play-circle me-2 text-muted"></i>Variables, Types & Operators</span>
                                    <span class="text-muted small">38:00</span>
                                </div>
                                <div class="lecture-row">
                                    <span><i class="bi bi-play-circle me-2 text-muted"></i>Functions & Scope</span>
                                    <span class="text-muted small">55:00</span>
                                </div>
                                <div class="lecture-row">
                                    <span><i class="bi bi-play-circle me-2 text-muted"></i>DOM Manipulation</span>
                                    <span class="text-muted small">1:10:00</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Section 3 -->
                    <div class="accordion-item border rounded-3 mb-2">
