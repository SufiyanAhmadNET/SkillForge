
@{
    ViewData["Title"] = "CoursesDetails";
    Layout = "~/Areas/Pubic/Views/Shared/_HomeLayout.cshtml";
}

<!-- ========================
       COURSE HERO BANNER (dark)
       breadcrumb + title + meta + rating
  ======================== -->
<div class="course-hero">
    <div class="container-fluid px-5">
        <div class="row">
            <!-- left col: all text — right col is empty (card floats over it via sticky) -->
            <div class="col-lg-8">

                <!-- breadcrumb -->
                <nav class="mb-3">
                    <ol class="breadcrumb mb-0" style="--bs-breadcrumb-divider-color:#aaa">
                        <li class="breadcrumb-item">
                            <a href="/" class="text-decoration-none" style="color:#aaa">Home</a>
                        </li>
                        <li class="breadcrumb-item">
                            <a href="/Courses" class="text-decoration-none" style="color:#aaa">Courses</a>
                        </li>
                        <li class="breadcrumb-item active" style="color:#ddd">Full Stack Web Dev</li>
                    </ol>
                </nav>

                <span class="badge-level mb-3 d-inline-block">Web Development</span>

                <h1 class="fw-bold fs-3 mb-3">
                    Full Stack Web Development — HTML to React & Node.js
                </h1>

                <p class="text-white-50 mb-3">
                    Build complete, production-ready web apps from scratch.
                    Frontend to backend, databases to deployment — all in one track.
                </p>

                <!-- rating row -->
                <div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
                    <span class="fw-bold" style="color:#f5a623">4.9</span>
                    <span class="rating-stars">★★★★★</span>
                    <span style="color:#ccc;font-size:.85rem">(3,240 ratings · 8,100 students)</span>
                </div>

                <!-- meta chips -->
                <div class="d-flex gap-3 flex-wrap" style="color:#ccc;font-size:.85rem">
                    <span><i class="bi bi-person me-1"></i> Arjun Mehta</span>
                    <span><i class="bi bi-clock me-1"></i> 12 weeks</span>
                    <span><i class="bi bi-translate me-1"></i> English, Hindi</span>
                    <span><i class="bi bi-calendar me-1"></i> Updated Jan 2026</span>
                    <span><i class="bi bi-award me-1"></i> Certificate included</span>
                </div>

            </div>
        </div>
    </div>
</div>


<!-- ========================
     MAIN CONTENT + ENROLL CARD
======================== -->
<div class="container-fluid px-5 py-5">
    <div class="row g-5">

        <!-- ---- LEFT: Course details ---- -->
        <div class="col-lg-8">

            <!-- Tab nav — Overview / Curriculum / Reviews -->
            <ul class="nav nav-tabs mb-4" id="courseTabs">
                <li class="nav-item">
                    <a class="nav-link active" href="#overview"
                       onclick="switchTab(event,'overview')">Overview</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#curriculum"
                       onclick="switchTab(event,'curriculum')">Curriculum</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#reviews"
                       onclick="switchTab(event,'reviews')">Reviews</a>
                </li>
            </ul>

            <!-- OVERVIEW TAB -->
            <div id="overview">

                <!-- What you'll learn -->
                <div class="bg-white border rounded-3 p-4 mb-4">
                    <h5 class="fw-bold mb-3">What you'll learn</h5>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="learn-item"><i class="bi bi-check-circle-fill"></i><span>Build responsive websites with HTML5 & CSS3</span></div>
                            <div class="learn-item"><i class="bi bi-check-circle-fill"></i><span>Master JavaScript ES6+ and async programming</span></div>
                            <div class="learn-item"><i class="bi bi-check-circle-fill"></i><span>Build React apps with hooks & state management</span></div>
                            <div class="learn-item"><i class="bi bi-check-circle-fill"></i><span>REST APIs with Node.js & Express</span></div>
                        </div>
                        <div class="col-md-6">
                            <div class="learn-item"><i class="bi bi-check-circle-fill"></i><span>MongoDB database design and queries</span></div>
                            <div class="learn-item"><i class="bi bi-check-circle-fill"></i><span>Authentication with JWT & sessions</span></div>
                            <div class="learn-item"><i class="bi bi-check-circle-fill"></i><span>Deploy to cloud (Vercel, Railway, AWS)</span></div>
                            <div class="learn-item"><i class="bi bi-check-circle-fill"></i><span>Git, GitHub, CI/CD workflows</span></div>
                        </div>
                    </div>
                </div>

                <!-- Requirements -->
                <div class="bg-white border rounded-3 p-4 mb-4">
                    <h5 class="fw-bold mb-3">Requirements</h5>
                    <ul class="text-muted small ps-3">
                        <li class="mb-1">Basic computer knowledge — no prior coding experience needed</li>
                        <li class="mb-1">A laptop with internet access</li>
                        <li>Willingness to practice daily for 1–2 hours</li>
                    </ul>
                </div>

                <!-- Course description -->
                <div class="bg-white border rounded-3 p-4 mb-4">
                    <h5 class="fw-bold mb-3">About this course</h5>
                    <p class="text-muted small mb-2">
                        This is the most comprehensive full-stack web development course on SkillForge.
                        You'll go from absolute beginner to a job-ready developer in 12 weeks — building
                        4 real projects along the way that you can add directly to your portfolio.
                    </p>
                    <p class="text-muted small mb-0">
                        Every module ends with a hands-on project. You'll also get access to our
                        private Discord community, weekly live doubt sessions with Arjun, and a
                        dedicated placement support track after completion.
                    </p>
                </div>

                <!-- Instructor -->
                <div class="instructor-mini mb-4">
                    <img src="https://randomuser.me/api/portraits/men/32.jpg" alt="Arjun Mehta">
                    <div>
                        <h6 class="fw-bold mb-0">Arjun Mehta</h6>
                        <p class="text-muted small mb-1">Full Stack Developer · 8 years industry experience</p>
                        <div class="d-flex gap-3 small text-muted">
                            <span><i class="bi bi-star-fill me-1" style="color:#f5a623"></i>4.9 rating</span>
                            <span><i class="bi bi-people me-1"></i>8,400 students</span>
                            <span><i class="bi bi-book me-1"></i>12 courses</span>
                        </div>
                    </div>
                </div>

            </div><!-- /overview -->
