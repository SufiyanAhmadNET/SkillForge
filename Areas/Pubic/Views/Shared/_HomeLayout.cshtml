
<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SkillForge – Learn Skills That Matter</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="~/css/public/HomeLayout.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/alert.css" rel="stylesheet" asp-append-version="true" />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>


</head>

<body>

    <!-- ========================
         NAVBAR
    ======================== -->
    <nav class="navbar navbar-expand-lg bg-white border-bottom sticky-top">
        <div class="container-fluid px-5">

            <!-- Brand -->
            <a class="navbar-brand fw-bold fs-5" href="#">
                <i class="bi bi-mortarboard-fill me-2"></i>SkillForge
            </a>

            <!-- Links — ms-auto pushes to right -->
            <div class="ms-auto d-flex gap-4 align-items-center">
                <a class="nav-link" href="#">Courses</a>

                <!-- Programs toggle — opens dark overlay below -->
                <a class="nav-link d-flex align-items-center gap-1"
                   data-bs-toggle="collapse" href="#programOverlay" role="button">
                    Programs <i class="bi bi-chevron-down small"></i>
                </a>

                <a class="nav-link" href="#">About</a>
                <a asp-area="User" asp-controller="Home" asp-action="Dashboard" class="nav-link" >Contact</a>

                <a asp-area="User" asp-controller="Home" asp-action="StudentLogin">
                    <button class="btn btn-light px-4">Login</button>
                </a>
                <!-- Sign Up goes to StudentRegistration -->
                <a asp-area="User" asp-controller="Home" asp-action="StudentRegistration">
                    <button class="btn-orange">Sign Up</button>
                </a>
            </div>
        </div>
    </nav>

    <!-- ========================
         PROGRAMS OVERLAY
         dark dropdown below navbar
    ======================== -->
    <div class="collapse program-overlay" id="programOverlay">
        <div class="container-fluid px-5 py-5">

            <h6 class="overlay-title mb-4">ONLINE PROGRAMS</h6>

            <div class="row g-3">

                <div class="col-md-6">
                    <a class="program-card" href="#">
                        <div class="program-icon bg-primary text-white">
                            <i class="bi bi-code-slash"></i>
                        </div>
                        <div>
                            <span class="badge badge-popular mb-1">POPULAR</span>
                            <h6>Software Development</h6>
                            <p>with Specialisation in AI</p>
                        </div>
                    </a>
                </div>

                <div class="col-md-6">
                    <a class="program-card" href="#">
                        <div class="program-icon bg-info text-white">
                            <i class="bi bi-bar-chart-fill"></i>
                        </div>
                        <div>
                            <span class="badge badge-popular mb-1">POPULAR</span>
                            <h6>Data Science</h6>
                            <p>with Specialisation in AI</p>
                        </div>
                    </a>
                </div>

                <div class="col-md-6">
                    <a class="program-card" href="#">
                        <div class="program-icon bg-danger text-white">
                            <i class="bi bi-cpu-fill"></i>
                        </div>
                        <div>
                            <h6>Advanced AI & Machine Learning</h6>
                            <p>Deep dive into neural networks</p>
                        </div>
                    </a>
                </div>

                <div class="col-md-6">
                    <a class="program-card" href="#">
                        <div class="program-icon bg-success text-white">
                            <i class="bi bi-cloud-fill"></i>
                        </div>
                        <div>
                            <h6>DevOps & Cloud Computing</h6>
                            <p>AWS, Azure, CI/CD pipelines</p>
                        </div>
                    </a>
                </div>

            </div>
        </div>
    </div>


    <partial name="_Alert_Message_Partial" />


            @RenderBody()
            @RenderSection("Scripts", required: false)

    <!-- ========================
         FOOTER
    ======================== -->
    <footer class="footer border-top py-5">
        <div class="container-fluid px-5">
            <div class="row mb-4 g-4">

                <!-- Brand column -->
                <div class="col-md-4">
                    <a class="navbar-brand fw-bold text-dark text-decoration-none" href="#">
                        <i class="bi bi-mortarboard-fill me-2" style="color:var(--orange)"></i>SkillForge
                    </a>
                    <p class="text-muted small mt-2">
                        Practical, structured learning for real-world careers. Made for India.
                    </p>
                    <div class="d-flex gap-3 mt-3">
                        <i class="bi bi-facebook fs-5" style="cursor:pointer;color:var(--muted)"></i>
                        <i class="bi bi-instagram fs-5" style="cursor:pointer;color:var(--muted)"></i>
                        <i class="bi bi-linkedin fs-5" style="cursor:pointer;color:var(--muted)"></i>
                        <i class="bi bi-youtube fs-5" style="cursor:pointer;color:var(--muted)"></i>
                    </div>
                </div>

                <div class="col">
                    <h6 class="fw-bold mb-3">Company</h6>
                    <a href="#" class="d-block mb-1">Our Story</a>
                    <a href="#" class="d-block mb-1">Careers</a>
                    <a href="#" class="d-block mb-1">Blog</a>
                    <a href="#" class="d-block mb-1">Press</a>
                </div>

                <div class="col">
                    <h6 class="fw-bold mb-3">Courses</h6>
                    <a href="#" class="d-block mb-1">Web Dev</a>
                    <a href="#" class="d-block mb-1">Data Science</a>
                    <a href="#" class="d-block mb-1">AI & ML</a>
                    <a href="#" class="d-block mb-1">Cloud</a>
                </div>

                <div class="col">
                    <h6 class="fw-bold mb-3">Support</h6>
                    <a href="#" class="d-block mb-1">Help Center</a>
                    <a href="#" class="d-block mb-1">Contact Us</a>
                    <a href="#" class="d-block mb-1">Community</a>
                    <a href="#" class="d-block mb-1">Refund Policy</a>
                </div>

            </div>

            <hr>

            <div class="d-flex justify-content-between text-muted small flex-wrap gap-2">
                <span>© 2026 SkillForge. All rights reserved.</span>
                <span>Privacy · Terms · Cookies</span>
            </div>
        </div>
    </footer>


    <!-- ========================
         JS — scroll arrows logic
         each row has an id, we scroll by one card width
    ======================== -->
    <script>
        // scroll left or right in a course row
        // rowId = id of the .course-scroll div
        // dir = 1 (right) or -1 (left)
        function scroll(rowId, dir) {
          const el = document.getElementById(rowId);
          // scroll by ~one card width (roughly 33% of container + gap)
          const cardWidth = el.querySelector('.course-card').offsetWidth + 20;
          el.scrollBy({ left: dir * cardWidth, behavior: 'smooth' });
        }

        // category pill toggle — just visual for now
        // later: wire to filter logic when backend is ready
        function filterCategory(el, cat) {
          document.querySelectorAll('.category-pill').forEach(p => p.classList.remove('active'));
          el.classList.add('active');
          // TODO: filter course rows by category when DB is connected
          console.log('filter:', cat);
        }
    </script>

    <script src="~/js/Alert.js" asp-append-version="true"> </script>
</body>
</html>