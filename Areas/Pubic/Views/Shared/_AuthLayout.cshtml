<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>@ViewData["Title"] – SkillForge</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="/css/index.css" rel="stylesheet">
    <link href="~/css/public/AuthLayout.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://accounts.google.com/gsi/client" async defer></script>
    <style>
        body {
            font-family: 'Inter', system-ui, sans-serif;
        }
    </style>
</head>

<body class="auth-page @ViewData["RoleClass"]">

    <header class="auth-topbar">
        <a class="brand" href="/">
            <i class="bi bi-mortarboard-fill"></i> SkillForge
        </a>
        <a href="/" class="text-muted small text-decoration-none">
            <i class="bi bi-arrow-left me-1"></i> Back to Home
        </a>
    </header>

    @RenderBody()

    <footer class="auth-footer">
        © 2026 SkillForge &nbsp;·&nbsp;
        <a href="#">Privacy</a> &nbsp;·&nbsp;
        <a href="#">Terms</a>
    </footer>

    <script>
        function togglePass(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon  = document.getElementById(iconId);
            input.type  = input.type === 'password' ? 'text' : 'password';
            icon.className = input.type === 'text' ? 'bi bi-eye-slash' : 'bi bi-eye';
        }


    //Google Login 
        function handleGoogleLogin(response) {
            fetch('/User/Auth/GoogleLogin', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    token: response.credential,
                    role: 'Student'
                })
            })
            .then(res => {
                if (res.redirected) {
                    window.location.href = res.url;
                }
            })
            .catch(err => {
                console.error('Google login failed:', err);
            });
        }
    </script>



    @RenderSection("Scripts", required: false)

</body>
</html>