<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] – SkillForge</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Outfit:wght@600;700;800&display=swap" rel="stylesheet">
    <link href="/css/index.css" rel="stylesheet">
    <link href="~/css/public/AuthLayout.css" rel="stylesheet" asp-append-version="true">
    <link href="~/css/alert.css" rel="stylesheet" asp-append-version="true" />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://accounts.google.com/gsi/client" async defer></script>
    <script>
        const isAuthenticated = false; 
    </script>
    <style>
        body {
            font-family: 'Inter', system-ui, sans-serif;
        }
    </style>
</head>

<body class="auth-page @ViewData["RoleClass"]">

    <header class="auth-topbar shadow-sm sticky-top">
        <a class="brand" href="/">
            <i class="bi bi-mortarboard-fill"></i> SkillForge
        </a>
        <a href="/" class="text-muted small text-decoration-none fw-bold">
            <i class="bi bi-arrow-left me-1"></i> Back to Home
        </a>
    </header>

    <partial name="_Alert_Message_Partial" />

    <div class="container-fluid d-flex flex-column flex-grow-1">
        @RenderBody()
    </div>

    <footer class="auth-footer">
        © 2026 SkillForge &nbsp;·&nbsp;
        <a href="#">Privacy</a> &nbsp;·&nbsp;
        <a href="#">Terms</a>
    </footer>

    <script>
        function togglePass(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon  = document.getElementById(iconId);
            input.type  = input.type === 'password' ? 'text' : 'password';
            icon.className = input.type === 'text' ? 'bi bi-eye-slash' : 'bi bi-eye';
        }

        // Global handler for auth button loading states
        function handleAuthSubmit(formId, baseText) {
            const form = document.getElementById(formId);
            if (!form.checkValidity()) {
                return true; // Let browser handle validation
            }

            const btn = form.querySelector('button[type="submit"]');
            if (btn) {
                btn.classList.add('loading');
                btn.disabled = true;
                const textSpan = btn.querySelector('.btn-text');
                if (textSpan) {
                    if (baseText === 'Login') textSpan.innerText = 'Logging in...';
                    else if (baseText === 'Register') textSpan.innerText = 'Creating account...';
                    else textSpan.innerText = 'Processing...';
                }
            }
            return true;
        }


    //Google Login 
        function handleGoogleLogin(response) {
            fetch('/User/Auth/GoogleLogin', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    token: response.credential,
                    role: 'Student'
                })
            })
            .then(res => {
                if (res.redirected) {
                    window.location.href = res.url;
                }
            })
            .catch(err => {
                console.error('Google login failed:', err);
            });
        }
    </script>



    @RenderSection("Scripts", required: false)
    <script src="~/js/Alert.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
</body>
</html>