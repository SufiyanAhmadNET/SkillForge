@{
    Layout = "~/Areas/Pubic/Views/Shared/_AuthLayout.cshtml";
    ViewData["Title"] = "Login";
    ViewData["RoleClass"] = "role-student";
}

<body>
    <section class="d-flex align-items-center justify-content-center py-5 flex-grow-1">

        <div class="card auth-card p-3">
            <form method="post" action="/Student/Login">

                <!-- Title + subtitle -->
                <h2 class="text-center fw-bold">Welcome back</h2>
                <p class="text-center text-muted small mb-4">Log in to continue learning</p>

                <!-- Email -->
                <div class="mb-3">
                    <label class="form-label">Email address</label>
                    <input type="email" class="form-control" name="email"
                           placeholder="you@example.com" autocomplete="email">
                </div>

                <!-- Password + show/hide toggle -->
                <div class="mb-2">
                    <label class="form-label">Password</label>
                    <div class="input-group">
                        <input type="password" class="form-control" name="password"
                               id="loginPass" placeholder="Enter your password" autocomplete="current-password">
                        <!-- toggle visibility — vanilla JS below -->
                        <button class="btn btn-outline-secondary pass-toggle" type="button"
                                onclick="togglePass()">
                            <i class="bi bi-eye" id="eyeIcon"></i>
                        </button>
                    </div>
                </div>

                <!-- Remember me + Forgot password row -->
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="rememberMe" id="remember">
                        <label class="form-check-label small" for="remember">Remember me</label>
                    </div>
                    <!-- forgot password goes to reset flow later -->
                    <a href="/Student/ForgotPassword" class="link-orange small">Forgot password?</a>
                </div>

                <!-- Submit -->
                <button type="submit" class="btn-auth mb-3">
                    Log In
                </button>

                <!-- OR divider -->
                <div class="d-flex align-items-center my-3">
                    <hr class="flex-grow-1">
                    <span class="text-muted small px-2">OR</span>
                    <hr class="flex-grow-1">
                </div>

                <!-- Google social login — same as Register -->
                <div class="border rounded-3 mb-3">
                    <a href="#" class="auth-social d-flex align-items-center px-3 py-3">
                        <img src="https://www.svgrepo.com/show/475656/google-color.svg" alt="Google" width="20">
                        <span class="mx-auto">Continue with Google</span>
                    </a>
                </div>

                <!-- Switch to Register -->
                <p class="text-center text-muted small mt-2 mb-3">
                    Don't have an account?
                    <a href="/Student/Register" class="link-orange">Sign Up</a>
                </p>

                <!-- role switcher  -->
                <div class="role-switcher">
                    <div class="role-switcher-label">LOGIN AS</div>
                    <div class="role-switcher-links">

                        @*   <a asp-area="Pubic" asp-controller="Authentication" asp-action="AdminLogin" class="role-link current">
                            <i class="bi bi-shield-lock"></i> Admin
                        </a>
                        <a asp-area="Pubic" asp-controller="Authentication" asp-action="StudentLogin" class="role-link">
                            <i class="bi bi-mortarboard"></i> Student
                        </a>

                        <a asp-area="Pubic" asp-controller="Authentication" asp-action="InstructorLogin" class="role-link">
                            <i class="bi bi-person-video3"></i> Instructor
                        </a> *@


                        <!-- current page hidden -->
                        <a asp-area="Pubic" asp-controller="Authentication" asp-action="StudentLogin" " class="role-link current">
                            <i class="bi bi-mortarboard"></i> Student
                        </a>
                        <!-- Instructor -->
                        <a asp-area="Pubic" asp-controller="Authentication" asp-action="InstructorLogin" class="role-link">
                            <i class="bi bi-person-video3"></i> Instructor
                        </a>
                        <!-- Admin-->
                        <a asp-area="Pubic" asp-controller="Authentication" asp-action="AdminLogin" class="role-link">
                            <i class="bi bi-shield-lock"></i> Admin
                        </a>
                    </div>
                </div>

            </form>
        </div>

    </section>

</body>