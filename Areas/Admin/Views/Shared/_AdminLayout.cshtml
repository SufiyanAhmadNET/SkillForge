<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">


<title>@ViewData["Title"] - SkillForge_Admin</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
<link href="/css/AdminPage.css" rel="stylesheet">
    <link href="~/css/alert.css" rel="stylesheet" />

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</head>

<body>

<div class="d-flex">

  <!-- ===== SIDEBAR  ===== -->
 
  <aside class="sidebar d-flex flex-column">

    <div class="sidebar-brand px-4 py-3 d-flex align-items-center gap-2 border-bottom border-secondary">
      <i class="bi bi-mortarboard-fill fs-5" style="color:var(--orange);"></i>
      <span class="fw-bold text-white">SkillForge</span>
      <span class="badge admin-badge ms-1">ADMIN</span>
    </div>

    <nav class="flex-grow-1 px-3 py-3">

      <p class="nav-section-label">OVERVIEW</p>
      <ul class="nav flex-column gap-1">
       
        <li>
          <a asp-area="Admin" asp-controller="Home" asp-action="Dashboard"
             class="nav-link sidebar-link active" >
            <i class="bi bi-grid me-2"></i>Dashboard
          </a>
        </li>
      </ul>

      <p class="nav-section-label mt-3">MANAGEMENT</p>
      <ul class="nav flex-column gap-1">
        <li>
          <a asp-area="Admin" asp-controller="Home" asp-action="Pending_Approvals"
             class="nav-link sidebar-link d-flex align-items-center">
            <i class="bi bi-person-check me-2"></i>Pending Approvals
            <span class="badge bg-danger ms-auto">3</span>
          </a>
        </li>

        <li>
          <a asp-area="Admin" asp-controller="Home" asp-action="Students"
             class="nav-link sidebar-link">
            <i class="bi bi-people me-2"></i>Students
          </a>
        </li>
        <li>
          <a asp-area="Admin" asp-controller="Home" asp-action="Instructors"
             class="nav-link sidebar-link">
            <i class="bi bi-person-video3 me-2"></i>Instructors
          </a>
        </li>
        <li>
          <a asp-area="Admin" asp-controller="Home" asp-action="Courses"
             class="nav-link sidebar-link">
            <i class="bi bi-journal-bookmark me-2"></i>Courses
          </a>
        </li>
      </ul>

      <p class="nav-section-label mt-3">SYSTEM</p>
      <ul class="nav flex-column gap-1">
        <li>
          <a asp-area="Admin" asp-controller="Home" asp-action="Reports"
             class="nav-link sidebar-link">
            <i class="bi bi-bar-chart-line me-2"></i>Reports
          </a>
        </li>
      </ul>

    </nav>

    <div class="px-3 pb-3">
      <!-- wire this to Identity logout action when auth is set up -->
      <a asp-area="Pubic" asp-controller="Authentication" asp-action="StudentLogin"
         class="nav-link sidebar-link text-danger">
        <i class="bi bi-box-arrow-left me-2"></i>Logout
      </a>
    </div>

  </aside>
  <!-- ===== /SIDEBAR ===== -->


 
  <div class="flex-grow-1 d-flex flex-column main-wrap">

    <!-- ===== HEADER ===== -->
    <!-- height is controlled by --header-h:60px CSS variable -->


    
    <header class="admin-header d-flex align-items-center justify-content-between px-4 bg-white border-bottom">
      <span class="fw-semibold">@ViewData["Title"]</span>
      <div class="d-flex align-items-center gap-3">
        <div class="input-group input-group-sm" style="width:210px;">
          <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-search"></i></span>
          <input type="text" class="form-control bg-light border-start-0" placeholder="Search…">
        </div>
        <button class="btn btn-light btn-sm position-relative">
          <i class="bi bi-bell"></i>
          <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size:9px;">3</span>
        </button>
        <div class="d-flex align-items-center gap-2">
          <div class="admin-avatar">A</div>
          <div>
            <div class="fw-semibold" style="font-size:13px;">Admin</div>
            <div class="text-muted" style="font-size:11px;">Super Admin</div>
          </div>
        </div>
      </div>
    </header>
    <!-- /HEADER -->
      
             @* PARTIAL VIEW FOR ALERT MESSAGES *@
            <partial name="_Alert_Message_Partial" />
        

          

    <!-- main content is injected here -->
    @RenderBody()

  </div>
</div>

@RenderSection("Scripts", required: false)
    <script src="~/js/Alert.js"></script>
</body>
</html>
