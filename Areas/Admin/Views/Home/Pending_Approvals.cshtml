
@{
    ViewData["Title"] = "Pending_Approvals";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}


<body>
<main class="p-4 flex-grow-1 admin-bg">

    <!-- Page title -->
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div class="page-title-bar">
            <h5 class="fw-bold mb-0">Pending Approvals</h5>
            <p class="text-muted mb-0" style="font-size:14px;">Review and approve new instructor applications.</p>
        </div>
        <span class="badge bg-danger px-3 py-2">3 Pending</span>
    </div>

    <!-- APPROVALS TABLE -->
    <div class="card border-0 admin-card mb-4">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <h6 class="mb-0 fw-bold"><i class="bi bi-person-check me-2 text-success"></i>Instructor Applications</h6>
            <!-- filter tabs using Bootstrap nav pills -->
            <ul class="nav nav-pills nav-sm" style="font-size:13px;">
                <li class="nav-item"><a class="nav-link py-1 px-3 active" href="#">All</a></li>
                <li class="nav-item"><a class="nav-link py-1 px-3" href="#">Pending</a></li>
                <li class="nav-item"><a class="nav-link py-1 px-3" href="#">Approved</a></li>
                <li class="nav-item"><a class="nav-link py-1 px-3" href="#">Rejected</a></li>
            </ul>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Instructor</th>
                        <th>Email</th>
                        <th>Specialisation</th>
                        <th>Experience</th>
                        <th>Applied</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>

                    <tr>
                        <td class="text-muted">01</td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div class="tbl-avatar bg-success bg-opacity-10 text-success">K</div>
                                Karan Mehta
                            </div>
                        </td>
                        <td class="text-muted">karan.mehta@email.com</td>
                        <td>DevOps & Cloud</td>
                        <td>5 years</td>
                        <td><span class="badge bg-warning text-dark">2 days ago</span></td>
                        <td><span class="badge bg-warning text-dark">Pending</span></td>
                        <td>
                            <div class="d-flex gap-2">
                                <a href="admin-instructor-profile.html" class="btn btn-sm btn-outline-secondary">Profile</a>
                                <button class="btn btn-sm btn-success">Approve</button>
                                <button class="btn btn-sm btn-outline-danger">Reject</button>
                            </div>
                        </td>
                    </tr>

                    <tr>
                        <td class="text-muted">02</td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div class="tbl-avatar bg-primary bg-opacity-10 text-primary">T</div>
                                Tanvi Joshi
                            </div>
                        </td>
                        <td class="text-muted">tanvi.joshi@email.com</td>
                        <td>Machine Learning</td>
                        <td>3 years</td>
                        <td><span class="badge bg-warning text-dark">4 days ago</span></td>
                        <td><span class="badge bg-warning text-dark">Pending</span></td>
                        <td>
                            <div class="d-flex gap-2">
                                <a href="admin-instructor-profile.html" class="btn btn-sm btn-outline-secondary">Profile</a>
                                <button class="btn btn-sm btn-success">Approve</button>
                                <button class="btn btn-sm btn-outline-danger">Reject</button>
                            </div>
                        </td>
                    </tr>

                    <tr>
                        <td class="text-muted">03</td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div class="tbl-avatar bg-secondary bg-opacity-10 text-secondary">V</div>
                                Vijay Raut
                            </div>
                        </td>
                        <td class="text-muted">vijay.raut@email.com</td>
                        <td>Cybersecurity</td>
                        <td>7 years</td>
                        <td><span class="badge bg-warning text-dark">1 week ago</span></td>
                        <td><span class="badge bg-warning text-dark">Pending</span></td>
                        <td>
                            <div class="d-flex gap-2">
                                <a href="admin-instructor-profile.html" class="btn btn-sm btn-outline-secondary">Profile</a>
                                <button class="btn btn-sm btn-success">Approve</button>
                                <button class="btn btn-sm btn-outline-danger">Reject</button>
                            </div>
                        </td>
                    </tr>

                    <!-- Already approved — for reference -->
                    <tr>
                        <td class="text-muted">04</td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div class="tbl-avatar" style="background:var(--orange-soft);color:var(--orange);">S</div>
                                Suresh Kumar
                            </div>
                        </td>
                        <td class="text-muted">suresh.k@email.com</td>
                        <td>Full Stack Dev</td>
                        <td>8 years</td>
                        <td><span class="badge bg-light text-muted">2 weeks ago</span></td>
                        <td><span class="badge bg-success">Approved</span></td>
                        <td>
                            <div class="d-flex gap-2">
                                <a href="admin-instructor-profile.html" class="btn btn-sm btn-outline-secondary">Profile</a>
                                <button class="btn btn-sm btn-outline-danger">Revoke</button>
                            </div>
                        </td>
                    </tr>

                </tbody>
            </table>
        </div>

        <!-- pagination — Bootstrap component -->
        <div class="card-footer bg-white d-flex justify-content-between align-items-center">
            <small class="text-muted">Showing 4 of 4 applications</small>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item disabled"><a class="page-link" href="#">Previous</a></li>
                    <li class="page-item active"><a class="page-link" href="#">1</a></li>
                    <li class="page-item"><a class="page-link" href="#">2</a></li>
                    <li class="page-item"><a class="page-link" href="#">Next</a></li>
                </ul>
            </nav>
        </div>

    </div>

</main>

</div>
</div>

</body>