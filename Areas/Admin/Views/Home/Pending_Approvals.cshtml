@using SkillForge.Areas.Admin.Models
@model IEnumerable<MentorApplicationListVM>
@{
    ViewData["Title"] = "Pending Approvals";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<main class="p-3 flex-grow-1 admin-bg">

    <!-- Page title -->
    <div class="d-flex align-items-center justify-content-between mb-3">
        <div class="page-title-bar">
            <h5 class="fw-bold mb-0">Pending Approvals</h5>
            <p class="text-muted mb-0" style="font-size:13px;">Review and approve new instructor applications.</p>
        </div>
        <span class="status-rejected fw-bold" style="font-size: 13px;">@Model.Count(a => a.Status == SkillForge.Services.Instructors.Models.MentorApplicationStatus.Pending) Pending</span>
    </div>

    <!-- APPROVALS TABLE -->
    <div class="card border-0 admin-card mb-4">
        <div class="card-header bg-white d-flex justify-content-between align-items-center py-2">
            <h6 class="mb-0 fw-bold small"><i class="bi bi-person-check me-2 text-success"></i>Instructor Applications</h6>
            <!-- filter tabs using Bootstrap nav pills -->
            <ul class="nav nav-pills nav-sm" style="font-size:11px;" id="applicationFilters">
                <li class="nav-item"><a class="nav-link py-1 px-3 active" href="#" data-filter="all">All</a></li>
                <li class="nav-item"><a class="nav-link py-1 px-3" href="#" data-filter="Pending">Pending</a></li>
                <li class="nav-item"><a class="nav-link py-1 px-3" href="#" data-filter="Approved">Approved</a></li>
                <li class="nav-item"><a class="nav-link py-1 px-3" href="#" data-filter="Rejected">Rejected</a></li>
            </ul>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-sm align-middle mb-0" style="font-size: 13px;">
                    <thead class="table-light text-muted" style="font-size: 11px; letter-spacing: 0.02rem;">
                        <tr>
                            <th class="ps-3">#</th>
                            <th>Instructor</th>
                            <th>Email</th>
                            <th>Specialisation</th>
                            <th>Experience</th>
                            <th>Applied</th>
                            <th>Status</th>
                            <th class="text-center pe-3">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="applicationTableBody">
                        @{
                            int index = ((ViewBag.CurrentPage - 1) * ViewBag.PageSize) + 1;
                        }
                        @foreach (var app in Model)
                        {
                            <tr data-status="@app.Status">
                                <td class="ps-3 text-muted">@(index++.ToString("D2"))</td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="tbl-avatar bg-success bg-opacity-10 text-success fw-bold" style="width: 26px; height: 26px; font-size: 10px;">
                                            @(string.IsNullOrEmpty(app.InstructorName) ? "?" : app.InstructorName.Substring(0, 1).ToUpper())
                                        </div>
                                        <span class="fw-medium text-dark">@app.InstructorName</span>
                                    </div>
                                </td>
                                <td class="text-muted small">@app.Email</td>
                                <td class="fw-medium">@app.Expertise</td>
                                <td class="text-muted small">@app.Experience yrs</td>
                                <td>
                                    <span class="text-muted small">
                                        @app.AppliedDate.ToString("MMM dd, yyyy")
                                    </span>
                                </td>
                                <td>
                                    @if (app.Status == SkillForge.Services.Instructors.Models.MentorApplicationStatus.Pending)
                                    {
                                        <span class="status-pending">Pending</span>
                                    }
                                    else if (app.Status == SkillForge.Services.Instructors.Models.MentorApplicationStatus.Approved)
                                    {
                                        <span class="status-approved">Approved</span>
                                    }
                                    else if (app.Status == SkillForge.Services.Instructors.Models.MentorApplicationStatus.Rejected)
                                    {
                                        <span class="status-rejected">Rejected</span>
                                    }
                                </td>
                                <td class="text-center pe-3">
                                    <div class="d-flex gap-1 justify-content-center">
                                        @if (!string.IsNullOrEmpty(app.ResumePath))
                                        {
                                            <div class="dropdown">
                                                <button class="btn btn-sm btn-outline-info py-0 px-2 dropdown-toggle" style="font-size: 11px;" type="button" data-bs-toggle="dropdown" title="Download CV">
                                                    CV
                                                </button>
                                                <ul class="dropdown-menu border-0 shadow-sm" style="font-size:12px;">
                                                    <li><a class="dropdown-item py-2" href="@app.ResumePath" target="_blank"><i class="bi bi-file-earmark-pdf text-danger me-2"></i>PDF</a></li>
                                                    <li><a class="dropdown-item py-2" href="@app.ResumePath" target="_blank"><i class="bi bi-file-earmark-word text-primary me-2"></i>DOCX</a></li>
                                                </ul>
                                            </div>
                                        }
                                        
                                        @if (app.Status == SkillForge.Services.Instructors.Models.MentorApplicationStatus.Pending)
                                        {
                                            <form asp-action="ApproveApplication" method="post" style="display:inline;">
                                                <input type="hidden" name="id" value="@app.Id" />
                                                <button type="submit" class="btn btn-sm btn-success py-0 px-2" style="font-size: 11px;">Approve</button>
                                            </form>
                                            <button type="button" class="btn btn-sm btn-outline-danger py-0 px-2" style="font-size: 11px;" onclick="openRejectModal(@app.Id)">Reject</button>
                                        }
                                        else if (app.Status == SkillForge.Services.Instructors.Models.MentorApplicationStatus.Approved)
                                        {
                                             <form asp-action="RejectApplication" method="post" style="display:inline;">
                                                <input type="hidden" name="id" value="@app.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger py-0 px-2" style="font-size: 11px;">Revoke</button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="8" class="text-center py-4 text-muted">No applications found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- pagination — Bootstrap component -->
        <div class="card-footer bg-white d-flex justify-content-between align-items-center">
            @{
                int startRange = ((ViewBag.CurrentPage - 1) * ViewBag.PageSize) + 1;
                int endRange = Math.Min(ViewBag.CurrentPage * ViewBag.PageSize, ViewBag.TotalRecords);
                if (ViewBag.TotalRecords == 0) { startRange = 0; endRange = 0; }
            }
            <small class="text-muted">Showing @startRange–@endRange of @ViewBag.TotalRecords applications</small>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                        <a class="page-link" asp-action="Pending_Approvals" asp-route-page="@(ViewBag.CurrentPage - 1)">Previous</a>
                    </li>
                    
                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                            <a class="page-link" asp-action="Pending_Approvals" asp-route-page="@i">@i</a>
                        </li>
                    }

                    <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages || ViewBag.TotalPages == 0 ? "disabled" : "")">
                        <a class="page-link" asp-action="Pending_Approvals" asp-route-page="@(ViewBag.CurrentPage + 1)">Next</a>
                    </li>
                </ul>
            </nav>
        </div>

    </div>

</main>

<!-- Reject Modal -->
<div class="modal fade" id="rejectModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0">
            <div class="modal-header bg-danger text-white">
                <h6 class="modal-title fw-bold">Reject Application</h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="RejectApplication" method="post">
                <div class="modal-body">
                    <input type="hidden" name="id" id="rejectAppId" />
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Reason for Rejection (Optional)</label>
                        <textarea name="comment" class="form-control" rows="3" placeholder="Explain why the application was rejected..."></textarea>
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-sm btn-danger px-4">Confirm Reject</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function openRejectModal(id) {
        document.getElementById('rejectAppId').value = id;
        new bootstrap.Modal(document.getElementById('rejectModal')).show();
    }

    document.querySelectorAll('#applicationFilters .nav-link').forEach(link => {
        link.addEventListener('click', function(e) {
            e.preventDefault();
            
            // UI toggle
            document.querySelectorAll('#applicationFilters .nav-link').forEach(l => l.classList.remove('active'));
            this.classList.add('active');
            
            const filter = this.getAttribute('data-filter');
            const rows = document.querySelectorAll('#applicationTableBody tr');
            
            rows.forEach(row => {
                if (filter === 'all' || row.getAttribute('data-status') === filter) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        });
    });
</script>