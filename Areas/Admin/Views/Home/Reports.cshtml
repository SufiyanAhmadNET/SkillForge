
@{
    ViewData["Title"] = "Reports";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<body>
<main class="p-4 flex-grow-1 admin-bg">

    <!-- Header & Global Filter -->
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div class="page-title-bar">
            <h5 class="fw-bold mb-0">Reports</h5>
            <p class="text-muted mb-0" style="font-size:14px;">Generate and download platform reports and exports.</p>
        </div>
        <div class="d-flex align-items-center gap-2">
            <label class="small fw-bold text-muted mb-0">Date Range:</label>
            <select id="globalDateRange" class="form-select form-select-sm" style="max-width:160px; font-size:12px;">
                <option value="7">Last 7 Days</option>
                <option value="30" selected>Last 30 Days</option>
                <option value="90">Last 90 Days</option>
                <option value="0">All Time</option>
            </select>
        </div>
    </div>

    <div class="row g-4">
        
        <!-- SECTION 1: COURSE REPORTS (Green) -->
        <div class="col-lg-6">
            <div class="card border-0 admin-card border-start border-4 border-success h-100">
                <div class="card-header bg-white py-3 border-0">
                    <h6 class="fw-bold mb-0 text-success"><i class="bi bi-journal-text me-2"></i>Course Reports</h6>
                    <small class="text-muted">Course performance and enrollment data.</small>
                </div>
                <div class="card-body p-0">
                    <!-- Enrollment Report -->
                    <div class="report-row d-flex align-items-center justify-content-between p-3 border-bottom">
                        <div>
                            <h6 class="fw-bold mb-1" style="font-size:14px;">Enrollment Report</h6>
                            <p class="text-muted mb-0 small">Student enrollments by course.</p>
                        </div>
                        <div class="dropdown">
                            <button class="btn btn-sm btn-outline-success dropdown-toggle py-1 px-3" style="font-size:11px;" type="button" data-bs-toggle="dropdown">
                                Download
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end border-0 shadow-sm" style="font-size:12px;">
                                <li><a class="dropdown-item py-2 download-link" data-action="DownloadEnrollmentReport" href="#"><i class="bi bi-file-earmark-pdf text-danger me-2"></i>PDF</a></li>
                                <li><a class="dropdown-item py-2" href="#"><i class="bi bi-file-earmark-word text-primary me-2"></i>DOCX</a></li>
                            </ul>
                        </div>
                    </div>
                    <!-- Sales Report -->
                    <div class="report-row d-flex align-items-center justify-content-between p-3">
                        <div>
                            <h6 class="fw-bold mb-1" style="font-size:14px;">Sales Report</h6>
                            <p class="text-muted mb-0 small">Course purchases and revenue summary.</p>
                        </div>
                        <div class="dropdown">
                            <button class="btn btn-sm btn-outline-success dropdown-toggle py-1 px-3" style="font-size:11px;" type="button" data-bs-toggle="dropdown">
                                Download
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end border-0 shadow-sm" style="font-size:12px;">
                                <li><a class="dropdown-item py-2 download-link" data-action="DownloadSalesReport" href="#"><i class="bi bi-file-earmark-pdf text-danger me-2"></i>PDF</a></li>
                                <li><a class="dropdown-item py-2" href="#"><i class="bi bi-file-earmark-word text-primary me-2"></i>DOCX</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- SECTION 2: USER REPORTS (Blue) -->
        <div class="col-lg-6">
            <div class="card border-0 admin-card border-start border-4 border-primary h-100">
                <div class="card-header bg-white py-3 border-0">
                    <h6 class="fw-bold mb-0 text-primary"><i class="bi bi-people me-2"></i>User Reports</h6>
                    <small class="text-muted">Student and instructor information.</small>
                </div>
                <div class="card-body p-0">
                    <!-- Student Report -->
                    <div class="report-row d-flex align-items-center justify-content-between p-3 border-bottom">
                        <div>
                            <h6 class="fw-bold mb-1" style="font-size:14px;">Student Report</h6>
                            <p class="text-muted mb-0 small">Registered students and enrollment counts.</p>
                        </div>
                        <div class="dropdown">
                            <button class="btn btn-sm btn-outline-primary dropdown-toggle py-1 px-3" style="font-size:11px;" type="button" data-bs-toggle="dropdown">
                                Download
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end border-0 shadow-sm" style="font-size:12px;">
                                <li><a class="dropdown-item py-2 download-link" data-action="DownloadStudentReport" href="#"><i class="bi bi-file-earmark-pdf text-danger me-2"></i>PDF</a></li>
                                <li><a class="dropdown-item py-2" href="#"><i class="bi bi-file-earmark-word text-primary me-2"></i>DOCX</a></li>
                            </ul>
                        </div>
                    </div>
                    <!-- Instructor Report -->
                    <div class="report-row d-flex align-items-center justify-content-between p-3">
                        <div>
                            <h6 class="fw-bold mb-1" style="font-size:14px;">Instructor Report</h6>
                            <p class="text-muted mb-0 small">Approved instructors, courses, and student counts.</p>
                        </div>
                        <div class="dropdown">
                            <button class="btn btn-sm btn-outline-primary dropdown-toggle py-1 px-3" style="font-size:11px;" type="button" data-bs-toggle="dropdown">
                                Download
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end border-0 shadow-sm" style="font-size:12px;">
                                <li><a class="dropdown-item py-2 download-link" data-action="DownloadInstructorReport" href="#"><i class="bi bi-file-earmark-pdf text-danger me-2"></i>PDF</a></li>
                                <li><a class="dropdown-item py-2" href="#"><i class="bi bi-file-earmark-word text-primary me-2"></i>DOCX</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- SECTION 3: FINANCIAL REPORTS (Orange) -->
        <div class="col-lg-6">
            <div class="card border-0 admin-card border-start border-4 h-100" style="border-color: var(--orange) !important;">
                <div class="card-header bg-white py-3 border-0">
                    <h6 class="fw-bold mb-0" style="color: var(--orange);"><i class="bi bi-currency-rupee me-2"></i>Financial Reports</h6>
                    <small class="text-muted">Revenue and payout information.</small>
                </div>
                <div class="card-body p-0">
                    <!-- Revenue Report -->
                    <div class="report-row d-flex align-items-center justify-content-between p-3 border-bottom">
                        <div>
                            <h6 class="fw-bold mb-1" style="font-size:14px;">Revenue Report</h6>
                            <p class="text-muted mb-0 small">Revenue generated during the selected period.</p>
                        </div>
                        <div class="dropdown">
                            <button class="btn btn-sm dropdown-toggle py-1 px-3 btn-outline-warning" style="font-size:11px; color: var(--orange); border-color: var(--orange);" type="button" data-bs-toggle="dropdown">
                                Download
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end border-0 shadow-sm" style="font-size:12px;">
                                <li><a class="dropdown-item py-2 download-link" data-action="DownloadRevenueReport" href="#"><i class="bi bi-file-earmark-pdf text-danger me-2"></i>PDF</a></li>
                                <li><a class="dropdown-item py-2" href="#"><i class="bi bi-file-earmark-word text-primary me-2"></i>DOCX</a></li>
                            </ul>
                        </div>
                    </div>
                    <!-- Instructor Payout Report -->
                    <div class="report-row d-flex align-items-center justify-content-between p-3">
                        <div>
                            <h6 class="fw-bold mb-1" style="font-size:14px;">Instructor Payout Report</h6>
                            <p class="text-muted mb-0 small">Instructor earnings and payout calculations.</p>
                        </div>
                        <div class="dropdown">
                            <button class="btn btn-sm dropdown-toggle py-1 px-3 btn-outline-warning" style="font-size:11px; color: var(--orange); border-color: var(--orange);" type="button" data-bs-toggle="dropdown">
                                Download
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end border-0 shadow-sm" style="font-size:12px;">
                                <li><a class="dropdown-item py-2 download-link" data-action="DownloadPayoutReport" href="#"><i class="bi bi-file-earmark-pdf text-danger me-2"></i>PDF</a></li>
                                <li><a class="dropdown-item py-2" href="#"><i class="bi bi-file-earmark-word text-primary me-2"></i>DOCX</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- SECTION 4: APPLICATION REPORTS (Purple) -->
        <div class="col-lg-6">
            <div class="card border-0 admin-card border-start border-4 border-purple h-100">
                <div class="card-header bg-white py-3 border-0">
                    <h6 class="fw-bold mb-0 text-purple"><i class="bi bi-person-check me-2"></i>Application Reports</h6>
                    <small class="text-muted">Instructor application activity.</small>
                </div>
                <div class="card-body p-0">
                    <!-- Instructor Applications Report -->
                    <div class="report-row d-flex align-items-center justify-content-between p-3">
                        <div>
                            <h6 class="fw-bold mb-1" style="font-size:14px;">Instructor Applications Report</h6>
                            <p class="text-muted mb-0 small">Submitted, approved, pending, and rejected applications.</p>
                        </div>
                        <div class="dropdown">
                            <button class="btn btn-sm btn-outline-purple dropdown-toggle py-1 px-3" style="font-size:11px;" type="button" data-bs-toggle="dropdown">
                                Download
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end border-0 shadow-sm" style="font-size:12px;">
                                <li><a class="dropdown-item py-2 download-link" data-action="DownloadApplicationsReport" href="#"><i class="bi bi-file-earmark-pdf text-danger me-2"></i>PDF</a></li>
                                <li><a class="dropdown-item py-2" href="#"><i class="bi bi-file-earmark-word text-primary me-2"></i>DOCX</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>

</main>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const dateRangeSelect = document.getElementById('globalDateRange');
        const downloadLinks = document.querySelectorAll('.download-link');

        function updateDownloadLinks() {
            const days = dateRangeSelect.value;
            downloadLinks.forEach(link => {
                const action = link.getAttribute('data-action');
                link.href = `/Admin/Home/${action}?days=${days}`;
            });
        }

        dateRangeSelect.addEventListener('change', updateDownloadLinks);
        updateDownloadLinks(); // Initial call to set hrefs
    });
</script>

</body>
