
@{
    ViewData["Title"] = "Reports";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<body>
<main class="p-4 flex-grow-1 admin-bg">

    <div class="mb-4 page-title-bar">
        <h5 class="fw-bold mb-0">Reports & Exports</h5>
        <p class="text-muted mb-0" style="font-size:14px;">Download data exports for any module.</p>
    </div>

    <!-- PLATFORM SUMMARY — quick read before downloading -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 stat-card">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon bg-success bg-opacity-10 text-success"><i class="bi bi-people-fill"></i></div>
                    <div><div class="stat-label">Total Students</div><div class="stat-value">50,240</div></div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 stat-card">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon bg-primary bg-opacity-10 text-primary"><i class="bi bi-person-video3"></i></div>
                    <div><div class="stat-label">Total Instructors</div><div class="stat-value">148</div></div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 stat-card">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background:var(--orange-soft);color:var(--orange);"><i class="bi bi-journal-check"></i></div>
                    <div><div class="stat-label">Active Courses</div><div class="stat-value">183</div></div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 stat-card">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon bg-secondary bg-opacity-10 text-secondary"><i class="bi bi-trophy-fill"></i></div>
                    <div><div class="stat-label">Completed</div><div class="stat-value">94</div></div>
                </div>
            </div>
        </div>
    </div>

    <!-- EXPORT CARDS -->
    <h6 class="fw-bold text-muted mb-3" style="font-size:12px; letter-spacing:1px; text-transform:uppercase;">Available Exports</h6>

    <div class="row g-3">

        <!-- Student report -->
        <div class="col-md-4">
            <div class="card border-0 admin-card h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <div class="stat-icon bg-success bg-opacity-10 text-success"><i class="bi bi-people"></i></div>
                        <div>
                            <h6 class="fw-bold mb-0">Student Report</h6>
                            <small class="text-muted">All students, enrollments & status</small>
                        </div>
                    </div>
                    <!-- date filter — placeholder for controller wiring -->
                    <div class="mb-3">
                        <label class="form-label" style="font-size:12px;">Date Range</label>
                        <div class="d-flex gap-2">
                            <input type="date" class="form-control form-control-sm">
                            <input type="date" class="form-control form-control-sm">
                        </div>
                    </div>
                    <button class="btn btn-sm btn-outline-success w-100">
                        <i class="bi bi-download me-1"></i>Download CSV
                    </button>
                </div>
            </div>
        </div>

        <!-- Instructor report -->
        <div class="col-md-4">
            <div class="card border-0 admin-card h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <div class="stat-icon bg-primary bg-opacity-10 text-primary"><i class="bi bi-person-video3"></i></div>
                        <div>
                            <h6 class="fw-bold mb-0">Instructor Report</h6>
                            <small class="text-muted">Instructors, courses & student count</small>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" style="font-size:12px;">Date Range</label>
                        <div class="d-flex gap-2">
                            <input type="date" class="form-control form-control-sm">
                            <input type="date" class="form-control form-control-sm">
                        </div>
                    </div>
                    <button class="btn btn-sm btn-outline-primary w-100">
                        <i class="bi bi-download me-1"></i>Download CSV
                    </button>
                </div>
            </div>
        </div>

        <!-- Course report -->
        <div class="col-md-4">
            <div class="card border-0 admin-card h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <!-- orange — brand tie-in -->
                        <div class="stat-icon" style="background:var(--orange-soft);color:var(--orange);"><i class="bi bi-journal-bookmark"></i></div>
                        <div>
                            <h6 class="fw-bold mb-0">Course Report</h6>
                            <small class="text-muted">All courses, enrollments & status</small>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" style="font-size:12px;">Date Range</label>
                        <div class="d-flex gap-2">
                            <input type="date" class="form-control form-control-sm">
                            <input type="date" class="form-control form-control-sm">
                        </div>
                    </div>
                    <button class="btn btn-sm w-100" style="background:var(--orange);color:#fff;border:none;">
                        <i class="bi bi-download me-1"></i>Download CSV
                    </button>
                </div>
            </div>
        </div>

    </div>

    <!-- Recent exports log — nice-to-have, useful for admin -->
    <h6 class="fw-bold text-muted mt-4 mb-3" style="font-size:12px; letter-spacing:1px; text-transform:uppercase;">Recent Exports</h6>

    <div class="card border-0 admin-card">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr><th>Report</th><th>Generated</th><th>Records</th><th></th></tr>
                </thead>
                <tbody>
                    <tr>
                        <td><i class="bi bi-file-earmark-spreadsheet me-2 text-success"></i>Student Report</td>
                        <td class="text-muted small">Mar 10, 2026 — 10:42 AM</td>
                        <td>50,240</td>
                        <td><button class="btn btn-sm btn-outline-secondary"><i class="bi bi-download me-1"></i>Re-download</button></td>
                    </tr>
                    <tr>
                        <td><i class="bi bi-file-earmark-spreadsheet me-2 text-primary"></i>Instructor Report</td>
                        <td class="text-muted small">Mar 8, 2026 — 3:15 PM</td>
                        <td>148</td>
                        <td><button class="btn btn-sm btn-outline-secondary"><i class="bi bi-download me-1"></i>Re-download</button></td>
                    </tr>
                    <tr>
                        <td><i class="bi bi-file-earmark-spreadsheet me-2" style="color:var(--orange);"></i>Course Report</td>
                        <td class="text-muted small">Mar 5, 2026 — 9:00 AM</td>
                        <td>289</td>
                        <td><button class="btn btn-sm btn-outline-secondary"><i class="bi bi-download me-1"></i>Re-download</button></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

</main>

</div>
</div>

</body>
