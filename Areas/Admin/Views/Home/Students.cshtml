@using SkillForge.Areas.Admin.Models
@model IEnumerable<StudentListVM>
@{
    ViewData["Title"] = "Students";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<main class="p-3 flex-grow-1 admin-bg">

    <!-- Page title + export button -->
    <div class="d-flex align-items-center justify-content-between mb-3">
        <div class="page-title-bar">
            <h5 class="fw-bold mb-0">Student List</h5>
            <p class="text-muted mb-0" style="font-size:13px;">All registered students on SkillForge.</p>
        </div>
        <div class="dropdown">
            <button class="btn btn-sm btn-outline-success dropdown-toggle" type="button" data-bs-toggle="dropdown">
                <i class="bi bi-download me-1"></i>Download
            </button>
            <ul class="dropdown-menu dropdown-menu-end border-0 shadow-sm" style="font-size:12px;">
                <li><a class="dropdown-item py-2" asp-action="DownloadStudentReport" asp-route-days="0"><i class="bi bi-file-earmark-pdf text-danger me-2"></i>PDF</a></li>
                <li><a class="dropdown-item py-2" href="#"><i class="bi bi-file-earmark-word text-primary me-2"></i>DOCX</a></li>
            </ul>
        </div>
    </div>

    <!-- Filter row -->
    <div class="d-flex align-items-center gap-3 mb-3 flex-wrap">
        <form method="get" asp-action="Students" class="d-flex align-items-center gap-2">
            <div class="input-group input-group-sm" style="max-width:240px;">
                <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
                <input type="text" name="search" class="form-control" id="studentSearch" placeholder="Search by name or email…" value="@ViewBag.SearchTerm">
            </div>
            <button type="submit" class="btn btn-sm btn-success">Search</button>
            @if (!string.IsNullOrEmpty(ViewBag.SearchTerm))
            {
                <a asp-action="Students" class="btn btn-sm btn-outline-secondary">Clear</a>
            }
        </form>
        <select class="form-select form-select-sm" style="max-width:140px;">
            <option>All Status</option>
            <option>Active</option>
            <option>Inactive</option>
        </select>
        <small class="text-muted ms-auto" style="font-size: 12px;">Showing @ViewBag.TotalRecords students</small>
    </div>

    <!-- STUDENTS TABLE -->
    <div class="card border-0 admin-card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-sm align-middle mb-0" style="font-size: 13px;">
                    <thead class="table-light text-muted" style="font-size: 11px; letter-spacing: 0.02rem;">
                        <tr>
                            <th class="ps-3">#</th>
                            <th>Student</th>
                            <th>Email</th>
                            <th>Courses</th>
                            <th>Joined</th>
                            <th>Status</th>
                            <th class="text-center pe-3">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="studentTableBody">
                        @{
                            int index = ((ViewBag.CurrentPage - 1) * ViewBag.PageSize) + 1;
                        }
                        @foreach (var student in Model)
                        {
                            <tr>
                                <td class="ps-3 text-muted">@index++</td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="tbl-avatar bg-success bg-opacity-10 text-success fw-bold" style="width: 26px; height: 26px; font-size: 10px;">
                                            @student.Name.Substring(0, 1).ToUpper()
                                        </div>
                                        <span class="fw-medium text-dark">@student.Name</span>
                                    </div>
                                </td>
                                <td class="text-muted small">@student.Email</td>
                                <td class="text-muted small">
                                    <span class="badge bg-light text-dark border fw-normal">@student.CourseCount Courses</span>
                                </td>
                                <td class="text-muted small">@student.JoinedDate.ToString("MMM dd, yyyy")</td>
                                <td>
                                    @{
                                        var statusClass = student.Status == "Active" ? "status-active" : "status-inactive";
                                    }
                                    <span class="@statusClass">@student.Status</span>
                                </td>
                                <td class="text-center pe-3">
                                    <div class="d-flex gap-1 justify-content-center">
                                        <button class="btn btn-sm btn-outline-secondary py-0 px-2" style="font-size: 11px;" 
                                                data-bs-toggle="modal" data-bs-target="#studentDetailsModal"
                                                data-name="@student.Name" data-email="@student.Email"
                                                data-courses="@string.Join("||", student.EnrolledCoursesList)">
                                            View
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center py-4 text-muted">No students found matching your search.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card-footer bg-white d-flex justify-content-between align-items-center">
            @{
                int startRange = ((ViewBag.CurrentPage - 1) * ViewBag.PageSize) + 1;
                int endRange = Math.Min(ViewBag.CurrentPage * ViewBag.PageSize, ViewBag.TotalRecords);
                if (ViewBag.TotalRecords == 0) { startRange = 0; endRange = 0; }
            }
            <small class="text-muted">Showing @startRange–@endRange of @ViewBag.TotalRecords students</small>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                        <a class="page-link" asp-action="Students" asp-route-search="@ViewBag.SearchTerm" asp-route-page="@(ViewBag.CurrentPage - 1)">Previous</a>
                    </li>
                    
                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                            <a class="page-link" asp-action="Students" asp-route-search="@ViewBag.SearchTerm" asp-route-page="@i">@i</a>
                        </li>
                    }

                    <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages || ViewBag.TotalPages == 0 ? "disabled" : "")">
                        <a class="page-link" asp-action="Students" asp-route-search="@ViewBag.SearchTerm" asp-route-page="@(ViewBag.CurrentPage + 1)">Next</a>
                    </li>
                </ul>
            </nav>
        </div>

    </div>

</main>

<!-- Student Details Modal -->
<div class="modal fade" id="studentDetailsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0 pb-0">
                <h6 class="modal-title fw-bold">Student Details</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" style="font-size: 10px;"></button>
            </div>
            <div class="modal-body">
                <div class="d-flex align-items-center gap-3 mb-4">
                    <div id="modalAvatar" class="rounded-circle bg-success bg-opacity-10 text-success d-flex align-items-center justify-content-center fw-bold" style="width: 48px; height: 48px; font-size: 18px;"></div>
                    <div>
                        <h6 id="modalName" class="mb-0 fw-bold"></h6>
                        <small id="modalEmail" class="text-muted"></small>
                    </div>
                </div>
                
                <h6 class="fw-bold mb-2 small text-uppercase" style="letter-spacing: 0.5px; font-size: 10px;">Enrolled Courses</h6>
                <div id="modalCourseList" class="list-group list-group-flush border rounded overflow-hidden" style="max-height: 200px; overflow-y: auto; font-size: 13px;">
                    <!-- Courses will be injected here -->
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-sm btn-secondary px-3" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const studentDetailsModal = document.getElementById('studentDetailsModal');
        studentDetailsModal.addEventListener('show.bs.modal', function(event) {
            const button = event.relatedTarget;
            const name = button.getAttribute('data-name');
            const email = button.getAttribute('data-email');
            const courses = button.getAttribute('data-courses').split('||').filter(c => c.length > 0);

            document.getElementById('modalName').textContent = name;
            document.getElementById('modalEmail').textContent = email;
            document.getElementById('modalAvatar').textContent = name.charAt(0).toUpperCase();

            const courseList = document.getElementById('modalCourseList');
            courseList.innerHTML = '';

            if (courses.length === 0) {
                courseList.innerHTML = '<div class="list-group-item text-muted text-center py-3">No enrolled courses</div>';
            } else {
                courses.forEach(course => {
                    const item = document.createElement('div');
                    item.className = 'list-group-item py-2 border-0 border-bottom';
                    item.innerHTML = `<i class="bi bi-journal-bookmark me-2 text-success"></i> ${course}`;
                    courseList.appendChild(item);
                });
            }
        });
    });
</script>
