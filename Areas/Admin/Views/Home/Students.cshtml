                    <tr>
                        <td class="text-muted">5</td>
                        <td><div class="d-flex align-items-center gap-2"><div class="tbl-avatar bg-info bg-opacity-10 text-info">S</div>Sneha Desai</div></td>
                        <td class="text-muted">sneha.d@email.com</td>
                        <td>Full Stack Dev</td>
                        <td class="text-muted small">Feb 20, 2026</td>
                        <td><span class="badge bg-success">Active</span></td>
                        <td>
                            <div class="d-flex gap-2">
                                <button class="btn btn-sm btn-outline-secondary">View</button>
                                <button class="btn btn-sm btn-outline-danger">Deactivate</button>
                            </div>
                        </td>
                    </tr>

                    <tr>
                        <td class="text-muted">6</td>
                        <td><div class="d-flex align-items-center gap-2"><div class="tbl-avatar bg-warning bg-opacity-10 text-warning">D</div>Dev Patel</div></td>
                        <td class="text-muted">dev.p@email.com</td>
                        <td>Advanced AI</td>
                        <td class="text-muted small">Jan 28, 2026</td>
                        <td><span class="badge bg-success">Active</span></td>
