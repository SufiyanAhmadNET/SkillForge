                    </tr>

                    <tr>
                        <td class="text-muted">4</td>
                        <td><div class="d-flex align-items-center gap-2"><div class="tbl-avatar bg-success bg-opacity-10 text-success">M</div>Meera Iyer</div></td>
                        <td class="text-muted">meera.i@email.com</td>
                        <td>ML & AI</td>
                        <td class="text-muted small">Mar 1, 2026</td>
                        <td><span class="badge bg-success">Active</span></td>
                        <td>
                            <div class="d-flex gap-2">
                                <button class="btn btn-sm btn-outline-secondary">View</button>
                                <button class="btn btn-sm btn-outline-danger">Deactivate</button>
                            </div>
