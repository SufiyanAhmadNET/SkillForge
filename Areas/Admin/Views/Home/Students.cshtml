@using SkillForge.Areas.Admin.Models
@model IEnumerable<StudentListVM>
@{
    ViewData["Title"] = "Students";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<main class="p-4 flex-grow-1 admin-bg">

    <!-- Page title + export button -->
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div class="page-title-bar">
            <h5 class="fw-bold mb-0">Student List</h5>
            <p class="text-muted mb-0" style="font-size:14px;">All registered students on SkillForge.</p>
        </div>
        <a href="#" class="btn btn-sm btn-outline-success">
            <i class="bi bi-download me-1"></i>Export CSV
        </a>
    </div>

    <!-- Filter row -->
    <div class="d-flex align-items-center gap-3 mb-3 flex-wrap">
        <div class="input-group input-group-sm" style="max-width:260px;">
            <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
            <input type="text" class="form-control" id="studentSearch" placeholder="Search by name or email…">
        </div>
        <select class="form-select form-select-sm" style="max-width:150px;">
            <option>All Status</option>
            <option>Active</option>
            <option>Inactive</option>
        </select>
        <small class="text-muted ms-auto">Showing @Model.Count() students</small>
    </div>

    <!-- STUDENTS TABLE -->
    <div class="card border-0 admin-card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-sm align-middle mb-0" style="font-size: 14px;">
                    <thead class="table-light text-muted" style="font-size: 12px; text-transform: uppercase; letter-spacing: 0.03rem;">
                        <tr>
                            <th class="ps-3">#</th>
                            <th>Student</th>
                            <th>Email</th>
                            <th>Enrolled Courses</th>
                            <th>Joined</th>
                            <th>Status</th>
                            <th class="pe-3">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="studentTableBody">
                        @{
                            int index = 1;
                        }
                        @foreach (var student in Model)
                        {
                            <tr data-name="@student.Name.ToLower()" data-email="@student.Email.ToLower()">
                                <td class="ps-3 text-muted">@index++</td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="tbl-avatar bg-success bg-opacity-10 text-success fw-bold" style="width: 28px; height: 28px; font-size: 11px;">
                                            @student.Name.Substring(0, 1).ToUpper()
                                        </div>
                                        <span class="fw-medium text-dark">@student.Name</span>
                                    </div>
                                </td>
                                <td class="text-muted small">@student.Email</td>
                                <td class="text-muted small">
                                    <div class="text-truncate" style="max-width: 200px;" title="@student.EnrolledCourses">
                                        @(string.IsNullOrEmpty(student.EnrolledCourses) ? "—" : student.EnrolledCourses)
                                    </div>
                                </td>
                                <td class="text-muted small">@student.JoinedDate.ToString("MMM dd, yyyy")</td>
                                <td><span class="badge rounded-pill bg-success-subtle text-success border border-success-subtle px-2">@student.Status</span></td>
                                <td class="pe-3">
                                    <div class="d-flex gap-1">
                                        <button class="btn btn-sm btn-outline-secondary py-0 px-2" style="font-size: 12px;">View</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card-footer bg-white d-flex justify-content-between align-items-center">
            <small class="text-muted">Showing 1–@Model.Count() of @Model.Count() students</small>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item disabled"><a class="page-link" href="#">Previous</a></li>
                    <li class="page-item active"><a class="page-link" href="#">1</a></li>
                    <li class="page-item disabled"><a class="page-link" href="#">Next</a></li>
                </ul>
            </nav>
        </div>

    </div>

</main>

<script>
    document.getElementById('studentSearch').addEventListener('input', function() {
        const searchTerm = this.value.toLowerCase();
        const rows = document.querySelectorAll('#studentTableBody tr');
        
        rows.forEach(row => {
            const name = row.getAttribute('data-name');
            const email = row.getAttribute('data-email');
            if (name.includes(searchTerm) || email.includes(searchTerm)) {
                row.style.display = '';
            } else {
                row.style.display = 'none';
            }
        });
    });
</script>
