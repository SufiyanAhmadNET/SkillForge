@using SkillForge.Areas.Admin.Models
@model AdminDashboardVM
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}


@* ALert Box for Admin Login Success Message *@
@if (TempData["LoginSuccess"] != null)
{
    <div class="success-alert" id="successAlert">
        ✅ @TempData["LoginSuccess"]
        <span onclick="document.getElementById('successAlert').style.display='none'"
              style="margin-left:20px; cursor:pointer; font-weight:bold; font-size:16px; opacity:0.7;">
            ✕
        </span>
    </div>
}

<style>
    .success-alert {
        position: fixed;
        top: 30px;
        left: 50%;
        transform: translateX(-50%);
        background-color: #d4edda;
        color: #155724;
        border: 1px solid #c3e6cb;
        padding: 14px 28px;
        border-radius: 10px;
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15);
        z-index: 9999;
        font-weight: 500;
        font-size: 15px;
        display: flex;
        align-items: center;
        gap: 10px;
        min-width: 280px;
        justify-content: space-between;
        animation: fadeOut 0.5s ease 2.5s forwards;
    }

    @@keyframes fadeOut {
        to {
            opacity: 0;
            visibility: hidden;
        }
    }
</style>

<main class="p-4 flex-grow-1 admin-bg">

    <!-- Welcome row -->
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div class="page-title-bar">
            <h5 class="fw-bold mb-0">Welcome back, Admin 👋</h5>
            <p class="text-muted mb-0" style="font-size:14px;">Here's what's happening on SkillForge today.</p>
        </div>

        <span class="badge rounded-pill px-3 py-2" style="background:var(--orange);font-size:12px;">
            <i class="bi bi-circle-fill me-1" style="font-size:8px;"></i>Live
        </span>
    </div>

    <!-- STAT CARDS -->
    <div class="row g-3 mb-4">

        <div class="col-md-3">
            <div class="card border-0 stat-card">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon bg-success bg-opacity-10 text-success"><i class="bi bi-people-fill"></i></div>
                    <div>
                        <div class="stat-label">Total Students</div>
                        <div class="stat-value">@Model.TotalStudents.ToString("N0")</div>
                        <small class="text-success">↑ Fresh data</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 stat-card">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon bg-primary bg-opacity-10 text-primary"><i class="bi bi-person-video3"></i></div>
                    <div>
                        <div class="stat-label">Total Instructors</div>
                        <div class="stat-value">@Model.TotalInstructors</div>
                        <small class="text-success">↑ Real-time</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 stat-card">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background:var(--orange-soft);color:var(--orange);"><i class="bi bi-journal-check"></i></div>
                    <div>
                        <div class="stat-label">Active Courses</div>
                        <div class="stat-value">@Model.ActiveCourses</div>
                        <small class="text-success">↑ Published</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 stat-card">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon bg-secondary bg-opacity-10 text-secondary"><i class="bi bi-trophy-fill"></i></div>
                    <div>
                        <div class="stat-label">Completed Courses</div>
                        <div class="stat-value">@Model.CompletedCourses</div>
                        <small class="text-muted">All time</small>
                    </div>
                </div>
            </div>
        </div>

    </div>
    <!-- /STAT CARDS -->

    <!-- PENDING APPROVALS preview -->
    <div class="card border-0 admin-card mb-4">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <h6 class="mb-0 fw-bold"><i class="bi bi-person-check me-2 text-success"></i>Instructor Approvals</h6>
            <div class="d-flex align-items-center gap-2">
                <span class="badge bg-danger">@Model.RecentApplications.Count(a => a.Status == SkillForge.Services.Instructors.Models.MentorApplicationStatus.Pending) Pending</span>
                <a asp-action="Pending_Approvals" class="small" style="color:var(--orange);">View All →</a>
            </div>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr><th>Instructor</th><th>Specialisation</th><th>Applied</th><th>Actions</th></tr>
                </thead>
                <tbody>
                    @foreach (var app in Model.RecentApplications.Where(a => a.Status == SkillForge.Services.Instructors.Models.MentorApplicationStatus.Pending).Take(3))
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="tbl-avatar bg-success bg-opacity-10 text-success">
                                        @app.InstructorName.Substring(0, 1).ToUpper()
                                    </div>
                                    @app.InstructorName
                                </div>
                            </td>
                            <td class="text-muted">@app.Expertise</td>
                            <td><span class="badge bg-warning text-dark">@app.AppliedDate.ToString("MMM dd")</span></td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a asp-action="Pending_Approvals" class="btn btn-sm btn-outline-secondary">Review</a>
                                    <form asp-action="ApproveApplication" method="post" style="display:inline;">
                                        <input type="hidden" name="id" value="@app.Id" />
                                        <button type="submit" class="btn btn-sm btn-success">Approve</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.RecentApplications.Any(a => a.Status == SkillForge.Services.Instructors.Models.MentorApplicationStatus.Pending))
                    {
                        <tr>
                            <td colspan="4" class="text-center py-3 text-muted">No pending applications</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>


    <!-- INSTRUCTOR LIST preview -->
    <div class="row g-3">
        <div class="col-lg-12">
            <div class="card border-0 admin-card h-100">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-person-video3 me-2 text-success"></i>Instructor Overview</h6>
                    <a asp-action="Instructors" class="small" style="color:var(--orange);">View All →</a>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr><th>Instructor</th><th>Courses</th><th>Students</th><th>Status</th><th></th></tr>
                        </thead>
                        <tbody>
                            @foreach (var ins in Model.RecentInstructors)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="tbl-avatar" style="background:var(--orange-soft);color:var(--orange);">@ins.Name.Substring(0, 1).ToUpper()</div>
                                            @ins.Name
                                        </div>
                                    </td>
                                    <td class="text-muted small">@ins.TotalCourses</td>
                                    <td class="text-muted small">@ins.TotalStudents</td>
                                    <td>
                                        @if (ins.Status == "Approved")
                                        {
                                            <span class="badge bg-success">Approved</span>
                                        }
                                        else if (ins.Status == "Pending")
                                        {
                                            <span class="badge bg-warning text-dark">Pending</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">@ins.Status</span>
                                        }
                                    </td>
                                    <td><a asp-action="Instructors" class="btn btn-sm btn-outline-secondary">View</a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

</main>
