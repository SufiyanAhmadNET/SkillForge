@model List<SkillForge.Areas.Admin.Models.AdminCourseReviewVM>
@using SkillForge.Services.Courses.Models
@{
    ViewData["Title"] = "Courses";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<body>
<main class="p-4 flex-grow-1 admin-bg">

    <div class="d-flex align-items-center justify-content-between mb-4">
        <div class="page-title-bar">
            <h5 class="fw-bold mb-0">Course Management</h5>
            <p class="text-muted mb-0" style="font-size:14px;">Monitor all courses across the platform.</p>
        </div>
        <a href="#" class="btn btn-sm btn-outline-success">
            <i class="bi bi-download me-1"></i>Export CSV
        </a>
    </div>

    <!-- Quick stat pills — fast overview -->
    <div class="d-flex gap-3 mb-4 flex-wrap">
        <div class="card border-0 admin-card px-4 py-2 d-flex flex-row align-items-center gap-2">
            <span class="badge bg-success">@Model.Count(c => c.Status == CourseStatus.Approved || c.Status == CourseStatus.Published)</span><span style="font-size:13px;">Active</span>
        </div>
        <div class="card border-0 admin-card px-4 py-2 d-flex flex-row align-items-center gap-2">
            <span class="badge bg-secondary">@Model.Count(c => c.Status == CourseStatus.Completed)</span><span style="font-size:13px;">Completed</span>
        </div>
        <div class="card border-0 admin-card px-4 py-2 d-flex flex-row align-items-center gap-2">
            <span class="badge bg-warning text-dark">@Model.Count(c => c.Status == CourseStatus.PendingReview)</span><span style="font-size:13px;">Pending Review</span>
        </div>
    </div>

    <!-- Filter row -->
    <div class="d-flex align-items-center gap-3 mb-3 flex-wrap">
        <div class="input-group input-group-sm" style="max-width:260px;">
            <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
            <input type="text" class="form-control" placeholder="Search courses…">
        </div>
        <select class="form-select form-select-sm" style="max-width:160px;">
            <option>All Categories</option>
            @foreach (var cat in Model.Select(c => c.Category).Distinct())
            {
                <option>@cat</option>
            }
        </select>
        <select class="form-select form-select-sm" style="max-width:140px;">
            <option>All Status</option>
            <option>Active</option>
            <option>Completed</option>
            <option>Pending</option>
        </select>
        <small class="text-muted ms-auto">Showing @Model.Count courses</small>
    </div>

    <!-- COURSES TABLE -->
    <div class="card border-0 admin-card">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Course</th>
                        <th>Instructor</th>
                        <th>Category</th>
                        <th>Content</th>
                        <th>Price</th>
                        <th>Duration</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        int index = 1;
                        foreach (var course in Model)
                        {
                            <tr>
                                <td class="text-muted">@(index++)</td>
                                <td class="fw-semibold">@course.Title</td>
                                <td><a href="#" class="text-decoration-none" style="color:var(--orange);">@course.InstructorName</a></td>
                                <td><span class="badge bg-light text-dark border">@course.Category</span></td>
                                <td>
                                    <small class="d-block text-muted">@course.ModuleCount Modules</small>
                                    <small class="d-block text-muted">@course.LessonCount Lessons</small>
                                </td>
                                <td>₹@course.Price</td>
                                <td>@course.DurationWeeks weeks</td>
                                <td>
                                    @if (course.Status == CourseStatus.Approved || course.Status == CourseStatus.Published)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else if (course.Status == CourseStatus.PendingReview)
                                    {
                                        <span class="badge bg-warning text-dark">Pending</span>
                                    }
                                    else if (course.Status == CourseStatus.Rejected)
                                    {
                                        <span class="badge bg-danger">Rejected</span>
                                    }
                                    else if (course.Status == CourseStatus.Draft)
                                    {
                                        <span class="badge bg-secondary">Draft</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-info">@course.Status</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex gap-2">
                                        @if (course.Status == CourseStatus.PendingReview)
                                        {
                                            <form asp-action="ApproveCourse" method="post" onsubmit="return confirm('Are you sure you want to approve this course?');">
                                                <input type="hidden" name="id" value="@course.Id" />
                                                <button type="submit" class="btn btn-sm btn-success">Approve</button>
                                            </form>
                                            <button class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#rejectModal-@course.Id">Reject</button>

                                            <!-- Reject Modal -->
                                            <div class="modal fade" id="rejectModal-@course.Id" tabindex="-1" aria-hidden="true">
                                                <div class="modal-dialog">
                                                    <div class="modal-content">
                                                        <form asp-action="RejectCourse" method="post">
                                                            <div class="modal-header">
                                                                <h5 class="modal-title">Reject Course</h5>
                                                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                            </div>
                                                            <div class="modal-body">
                                                                <input type="hidden" name="id" value="@course.Id" />
                                                                <div class="mb-3">
                                                                    <label class="form-label">Reason for Rejection</label>
                                                                    <textarea class="form-control" name="reason" rows="3" required placeholder="Tell the instructor what needs to be changed..."></textarea>
                                                                </div>
                                                            </div>
                                                            <div class="modal-footer">
                                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                                                <button type="submit" class="btn btn-danger">Confirm Reject</button>
                                                            </div>
                                                        </form>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                        <a href="/User/Home/CourseDetails/@course.Id" target="_blank" class="btn btn-sm btn-outline-secondary">View</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center py-4 text-muted">No courses found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="card-footer bg-white d-flex justify-content-between align-items-center">
            <small class="text-muted">Showing @Model.Count courses</small>
        </div>

    </div>

</main>
</body>
