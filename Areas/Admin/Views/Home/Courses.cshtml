@model List<SkillForge.Areas.Admin.Models.AdminCourseReviewVM>
@using SkillForge.Services.Courses.Models
@{
    ViewData["Title"] = "Courses";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<body>
<main class="p-4 flex-grow-1 admin-bg">

    <div class="d-flex align-items-center justify-content-between mb-4">
        <div class="page-title-bar">
            <h5 class="fw-bold mb-0">Course Management</h5>
            <p class="text-muted mb-0" style="font-size:14px;">Monitor all courses across the platform.</p>
        </div>
        <a href="#" class="btn btn-sm btn-outline-success">
            <i class="bi bi-download me-1"></i>Export CSV
        </a>
    </div>

    <!-- Quick stat pills — fast overview -->
    <div class="d-flex gap-3 mb-4 flex-wrap">
        <div class="card border-0 admin-card px-4 py-2 d-flex flex-row align-items-center gap-2">
            <span class="badge bg-success">@Model.Count(c => c.Status == CourseStatus.Approved || c.Status == CourseStatus.Published)</span><span style="font-size:13px;">Active</span>
        </div>
        <div class="card border-0 admin-card px-4 py-2 d-flex flex-row align-items-center gap-2">
            <span class="badge bg-secondary">@Model.Count(c => c.Status == CourseStatus.Completed)</span><span style="font-size:13px;">Completed</span>
        </div>
        <div class="card border-0 admin-card px-4 py-2 d-flex flex-row align-items-center gap-2">
            <span class="badge bg-warning text-dark">@Model.Count(c => c.Status == CourseStatus.PendingReview)</span><span style="font-size:13px;">Pending Review</span>
        </div>
    </div>

    <!-- Filter row -->
    <div class="d-flex align-items-center gap-3 mb-3 flex-wrap">
        <div class="input-group input-group-sm" style="max-width:260px;">
            <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
            <input type="text" class="form-control" placeholder="Search courses…">
        </div>
        <select class="form-select form-select-sm" style="max-width:160px;">
            <option>All Categories</option>
            @foreach (var cat in Model.Select(c => c.Category).Distinct())
            {
                <option>@cat</option>
            }
        </select>
        <select class="form-select form-select-sm" style="max-width:140px;">
            <option>All Status</option>
            <option>Active</option>
            <option>Completed</option>
            <option>Pending</option>
        </select>
        <small class="text-muted ms-auto">Showing @Model.Count courses</small>
    </div>

    <!-- COURSES TABLE -->
    <div class="card border-0 admin-card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-sm align-middle mb-0" style="font-size: 14px;">
                    <thead class="table-light text-muted" style="font-size: 12px; text-transform: uppercase; letter-spacing: 0.03rem;">
                        <tr>
                            <th class="ps-3">#</th>
                            <th>Course</th>
                            <th>Instructor</th>
                            <th>Category</th>
                            <th>Content</th>
                            <th>Price</th>
                            <th>Duration</th>
                            <th>Status</th>
                            <th class="pe-3">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            int index = 1;
                            foreach (var course in Model)
                            {
                                <tr>
                                    <td class="ps-3 text-muted">@(index++)</td>
                                    <td class="fw-semibold text-dark" style="max-width: 200px;">
                                        <div class="text-truncate" title="@course.Title">@course.Title</div>
                                    </td>
                                    <td>
                                        <a href="#" class="text-decoration-none fw-medium" style="color:var(--orange);">@course.InstructorName</a>
                                    </td>
                                    <td><span class="badge rounded-pill bg-light text-dark border fw-normal">@course.Category</span></td>
                                    <td>
                                        <div class="small text-muted">@course.ModuleCount Modules</div>
                                        <div class="small text-muted" style="font-size: 11px;">@course.LessonCount Lessons</div>
                                    </td>
                                    <td class="fw-medium">₹@course.Price</td>
                                    <td class="text-muted">@course.DurationWeeks wks</td>
                                    <td>
                                        @if (course.Status == CourseStatus.Approved || course.Status == CourseStatus.Published)
                                        {
                                            <span class="badge rounded-pill bg-success-subtle text-success border border-success-subtle px-2">Active</span>
                                        }
                                        else if (course.Status == CourseStatus.PendingReview)
                                        {
                                            <span class="badge rounded-pill bg-warning-subtle text-warning-emphasis border border-warning-subtle px-2">Pending</span>
                                        }
                                        else if (course.Status == CourseStatus.Rejected)
                                        {
                                            <span class="badge rounded-pill bg-danger-subtle text-danger border border-danger-subtle px-2">Rejected</span>
                                        }
                                        else if (course.Status == CourseStatus.Draft)
                                        {
                                            <span class="badge rounded-pill bg-secondary-subtle text-secondary border border-secondary-subtle px-2">Draft</span>
                                        }
                                        else
                                        {
                                            <span class="badge rounded-pill bg-info-subtle text-info border border-info-subtle px-2">@course.Status</span>
                                        }
                                    </td>
                                    <td class="pe-3">
                                        <div class="d-flex gap-1">
                                            @if (course.Status == CourseStatus.PendingReview)
                                            {
                                                <form asp-action="ApproveCourse" method="post" onsubmit="return confirm('Are you sure you want to approve this course?');" style="display:inline;">
                                                    <input type="hidden" name="id" value="@course.Id" />
                                                    <button type="submit" class="btn btn-sm btn-success py-0 px-2" style="font-size: 12px;">Approve</button>
                                                </form>
                                                <button class="btn btn-sm btn-outline-danger py-0 px-2" style="font-size: 12px;" data-bs-toggle="modal" data-bs-target="#rejectModal-@course.Id">Reject</button>

                                                <!-- Reject Modal -->
                                                <div class="modal fade" id="rejectModal-@course.Id" tabindex="-1" aria-hidden="true">
                                                    <div class="modal-dialog modal-sm">
                                                        <div class="modal-content">
                                                            <form asp-action="RejectCourse" method="post">
                                                                <div class="modal-header py-2">
                                                                    <h6 class="modal-title fw-bold">Reject Course</h6>
                                                                    <button type="button" class="btn-close" style="font-size: 10px;" data-bs-dismiss="modal" aria-label="Close"></button>
                                                                </div>
                                                                <div class="modal-body">
                                                                    <input type="hidden" name="id" value="@course.Id" />
                                                                    <div class="mb-2">
                                                                        <label class="form-label small fw-semibold">Reason for Rejection</label>
                                                                        <textarea class="form-control form-control-sm" name="reason" rows="3" required placeholder="Feedback for instructor..."></textarea>
                                                                    </div>
                                                                </div>
                                                                <div class="modal-footer py-1">
                                                                    <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                                    <button type="submit" class="btn btn-sm btn-danger">Reject</button>
                                                                </div>
                                                            </form>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                            <a href="/User/Home/CourseDetails/@course.Id" target="_blank" class="btn btn-sm btn-outline-secondary py-0 px-2" style="font-size: 12px;">View</a>
                                        </div>
                                    </td>
                                </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center py-4 text-muted">No courses found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="card-footer bg-white d-flex justify-content-between align-items-center">
            <small class="text-muted">Showing @Model.Count courses</small>
        </div>

    </div>

</main>
</body>
