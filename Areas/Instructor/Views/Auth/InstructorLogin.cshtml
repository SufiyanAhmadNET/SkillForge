@{
    Layout = "~/Areas/Pubic/Views/Shared/_AuthLayout.cshtml";
    ViewData["Title"] = "Login";
    ViewData["RoleClass"] = "role-instructor";
}


@* ================= Login Section ================= *@

<section class="d-flex align-items-center justify-content-center py-4 bg-light flex-grow-1">
    <div class="card auth-card shadow-sm">

        <form asp-area="Instructor" asp-controller="Auth" asp-action="InstructorLogin" method="post" id="instructorLoginForm" onsubmit="return handleAuthSubmit('instructorLoginForm', 'Login')">
            @Html.AntiForgeryToken()

            <input type="hidden" name="role" value="Instructor" />

            <!-- role badge — indigo for instructor -->
            <div class="text-center mb-1">
                <span class="role-badge">
                    <i class="bi bi-person-video3"></i> INSTRUCTOR PORTAL
                </span>
            </div>
            <h2 class="text-center fw-bold mb-1">Welcome back</h2>
            <p class="text-center text-muted small mb-3">Log in to manage your professional courses</p>
            <div id="instructor-login-alert" class="alert-container alert-inline"></div>


            @* otp trigger *@
            @if (TempData["VerifyEmail"] != null)
            {
                <script>
                    window.addEventListener("load", function () {
                        openOtpModal("@TempData["VerifyEmail"]");
                    });
                </script>
            }

            <!-- Email -->
            <div class="mb-2">
                <label class="form-label">Email address</label>
                <input type="email" class="form-control" name="email"
                       placeholder="you@example.com" autocomplete="email" value="@ViewBag.Email" required>
            </div>

            <!-- Password -->
            <div class="mb-2">
                <label class="form-label">Password</label>
                <div class="input-group">
                    <input type="password" class="form-control" name="password"
                           id="instrPass" placeholder="Enter your password" autocomplete="current-password" required>
                    <button class="btn btn-outline-secondary pass-toggle" style="border: 1px solid #e0e0e0; border-left: none; border-radius: 0 10px 10px 0;" type="button"
                            onclick="togglePass('instrPass','instrEye')">
                        <i class="bi bi-eye" id="instrEye"></i>
                    </button>
                </div>
            </div>

            <!-- remember + forgot -->
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="remember" style="width: 0.9em; height: 0.9em;">
                    <label class="form-check-label" for="remember" style="font-size: 0.75rem;">Remember me</label>
                </div>
                <a asp-action="ForgotPassword"
                   class="fw-bold text-decoration-none" style="color:var(--role-color); font-size: 0.75rem;">
                    Forgot?
                </a>
            </div>

            @*  login button *@
            <button type="submit" class="btn-auth mb-2">
                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                <span class="btn-text">Instructor Login</span>
            </button>


            <!-- Divider -->
            <div class="auth-divider">
                <hr>
                <span>OR</span>
                <hr>
            </div>

            <!-- Google button -->
            <div class="google-auth-container text-center">
                <div id="g_id_onload"
                     data-client_id="@Configuration["GoogleAuth:ClientId"]"
                     data-login_uri="/Instructor/Auth/GoogleLogin"
                     data-auto_prompt="false">
                </div>

                <div class="g_id_signin"
                     data-type="standard"
                     data-shape="rectangular"
                     data-theme="outline"
                     data-text="signin_with"
                     data-size="large"
                     data-width="100%">
                </div>
            </div>

            <!-- switch to register -->
            <p class="text-center text-muted small mt-3 mb-0">
                New instructor?
                <a asp-area="Instructor" asp-controller="Auth" asp-action="InstructorRegistration"
                   class="text-decoration-none fw-bold ms-1" style="color:var(--role-color);">Apply here</a>
            </p>

            <!-- role switcher -->
            <div class="role-switcher">
                <div class="role-switcher-label">LOGIN AS</div>
                <div class="role-switcher-links">
                    <a asp-area="Pubic" asp-controller="Authentication" asp-action="AdminLogin" class="role-link">
                        <i class="bi bi-shield-lock"></i> Admin
                    </a>
                    <a asp-area="User" asp-controller="Auth" asp-action="StudentLogin" class="role-link">
                        <i class="bi bi-mortarboard"></i> Student
                    </a>
                </div>
            </div>
        </form>
        @await Html.PartialAsync("_OtpModal")
    </div>
</section>



