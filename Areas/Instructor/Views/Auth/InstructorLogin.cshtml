@{
    Layout = "~/Areas/Pubic/Views/Shared/_AuthLayout.cshtml";
    ViewData["Title"] = "Login";
    ViewData["RoleClass"] = "role-instructor";
}


<body class="auth-page role-instructor">
    <section class="d-flex align-items-center justify-content-center py-5 flex-grow-1">
        <div class="auth-card">

            <form asp-area="Instructor" asp-controller="Auth" asp-action="InstructorLogin" method="post">
                @Html.AntiForgeryToken();

                <input type="hidden" name="role" value="Instructor" />

                <!-- role badge — indigo for instructor -->
                <div class="text-center mb-1">
                    <span class="role-badge">
                        <i class="bi bi-person-video3"></i> INSTRUCTOR PORTAL
                    </span>
                </div>
                <h2 class="text-center fw-bold mb-1" style="font-size:1.5rem">Welcome back</h2>
                <p class="text-center text-muted small mb-4">Log in to manage your courses</p>

                @*  Alert Messages *@ 
                @if (TempData["Alert"] != null)
                {
                    <div class="alert alert-danger d-flex align-items-center justify-content-between py-2 px-3 mb-3 rounded-2 small shadow-sm">
                        <span>@TempData["Alert"]</span>
                        <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
                    </div>
                }

                @if (TempData["Email"] != null)
                {
                    <div class="alert alert-success d-flex align-items-center justify-content-between py-2 px-3 mb-3 rounded-2 small shadow-sm">
                        <div>
                            @TempData["Email"]
                            <div class="text-muted" style="font-size:11px;">check inbox or spam folder</div>
                        </div>
                        <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
                    </div>
                }

                @if (TempData["Verify"] != null)
                {
                    <div class="alert alert-warning d-flex flex-column py-2 px-3 mb-3 rounded-2 small shadow-sm">

                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                @TempData["Verify"]
                                <div class="text-muted" style="font-size:11px;">verify email to continue</div>
                            </div>

                            <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
                        </div>

                        @* resend verification *@
                        @if (TempData["UnverifiedEmail"] != null)
                        {
                            <form method="post" asp-area="User" asp-controller="Auth" asp-action="SendVerificationEmail" class="mt-2">
                                <input type="hidden" name="Email" value="@TempData["UnverifiedEmail"]" />

                                <button type="submit" class="btn btn-sm btn-warning w-100">
                                    Resend Verification Email
                                </button>
                            </form>
                        }
                    </div>
                }

                @if (TempData["Sent"] != null)
                {
                    <div class="alert alert-info d-flex align-items-center justify-content-between py-2 px-3 mb-3 rounded-2 small shadow-sm">
                        <span>@TempData["Sent"]</span>
                        <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
                    </div>
                }
   @*  Alert Messages *@


                <!-- Email -->
                <div class="mb-3">
                    <label class="form-label">Email address</label>
                    <input type="email" class="form-control" name="email"
                           placeholder="you@example.com" autocomplete="email">
                </div>

                <!-- Password -->
                <div class="mb-2">
                    <label class="form-label">Password</label>
                    <div class="input-group">
                        <input type="password" class="form-control" name="password"
                               id="instrPass" placeholder="Enter your password" autocomplete="current-password">
                        <button class="btn btn-outline-secondary pass-toggle" type="button"
                                onclick="togglePass('instrPass','instrEye')">
                            <i class="bi bi-eye" id="instrEye"></i>
                        </button>
                    </div>
                </div>

                <!-- remember + forgot -->
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="remember">
                        <label class="form-check-label small" for="remember">Remember me</label>
                    </div>
                    <a href="/Instructor/ForgotPassword"
                       class="small text-decoration-none" style="color:var(--role-color)">
                        Forgot password?
                    </a>
                </div>

                @*    //login button *@
                <button type="submit" class="btn-auth mb-3">
                    <i class="bi bi-person-video3 me-2"></i> Login as Instructor
                </button>

                <!-- Google Sign In -->
                <div id="g_id_onload"
                     data-client_id="@ViewBag.GoogleClientId"
                     data-callback="handleGoogleLogin"
                     data-auto_prompt="false">
                </div>

                <!-- Google button -->
                <div class="g_id_signin"
                     data-type="standard"
                     data-shape="rectangular"
                     data-theme="outline"
                     data-text="signin_with"
                     data-size="large"
                     data-width="100%">
                </div>

                <!-- switch to register -->
                <p class="text-center text-muted small mb-3">
                    New instructor?
                    <a asp-area="Instructor" asp-controller="Auth" asp-action="InstructorRegistration"
                       class="text-decoration-none fw-500" style="color:var(--role-color)">
                        Apply as New Instructor
                    </a>
                </p>

                <!-- role switcher -->
                <div class="role-switcher">
                    <div class="role-switcher-label">LOGIN AS</div>
                    <div class="role-switcher-links">

                        <!--Admin Login-->
                        <a asp-area="Pubic" asp-controller="Authentication" asp-action="AdminLogin" class="role-link current">
                            <i class="bi bi-shield-lock"></i> Admin
                        </a>


                        <!--STudent Login-->
                        <a asp-area="User" asp-controller="Account" asp-action="StudentLogin" class="role-link">
                            <i class="bi bi-mortarboard"></i> Student
                        </a>

                    </div>
            </form>
        </div>
    </section>

    <script>
        // Google Identity Services callback
        // Called by data-callback="handleGoogleLogin"
        async function handleGoogleLogin(response) {
            try {
                if (!response || !response.credential) {
                    alert('Google login failed: no credential.');
                    return;
                }

                const token = response.credential;

                const res = await fetch('/Instructor/Auth/GoogleLogin', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                    },
                    body: JSON.stringify({ token: token })
                });

                // If server redirected, follow that redirection
                if (res.redirected) {
                    window.location = res.url;
                    return;
                }

                if (res.ok) {
                    // on success redirect to dashboard
                    window.location = '/Instructor/Home/Dashboard';
                    return;
                }

                // failure: show message and stay on page
                const text = await res.text();
                console.error('Google login failed:', text);
                alert('Google login failed. Check console for details.');
            } catch (err) {
                console.error('Google login error:', err);
                alert('Google login error. See console.');
            }
        }
    </script>
</body>



