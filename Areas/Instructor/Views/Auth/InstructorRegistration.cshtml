@{
    Layout = "~/Areas/Pubic/Views/Shared/_AuthLayout.cshtml";
    ViewData["Title"] = "Login";
    ViewData["RoleClass"] = "role-instructor";
}


<section class="d-flex align-items-center justify-content-center py-4 flex-grow-1">
    <div class="auth-card">
        <form method="post"
            asp-area="Instructor" asp-controller="Auth" asp-action="InstructorRegistration">

            @Html.AntiForgeryToken()
            <input type="hidden" name="role" value="Instructor" />
            <div class="text-center mb-3">
                <span class="role-badge">
                    <i class="bi bi-person-video3"></i> INSTRUCTOR PORTAL
                </span>
                <h2 class="fw-bold mt-2 mb-0" style="font-size:1.3rem;">Start Teaching</h2>
                <p class="text-muted mb-0" style="font-size:12px;">
                    Contribute in Building SKill Based Nation </p>
            </div>
                
            <div class="inst-steps-top">

                <div class="inst-step-top active">
                    <div class="inst-step-circle">1</div>
                    <div>Account</div>
                </div>

                <div class="inst-step-top">
                    <div class="inst-step-circle">2</div>
                    <div>Profile</div>
                </div>

                <div class="inst-step-top">
                    <div class="inst-step-circle">3</div>
                    <div>Approval</div>
                </div>

            </div>

            <!-- Title -->
            <h2 class="text-center fw-bold mb-3">Create Account</h2>

            @* --- Alert Messages --- *@
            @if (TempData["Alert"] != null)
            {
                <div class="alert alert-danger d-flex align-items-center justify-content-between py-2 px-3 mb-3 rounded-2 small shadow-sm">
                    <span>@TempData["Alert"]</span>
                    <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["Email"] != null)
            {
                <div class="alert alert-success d-flex align-items-center justify-content-between py-2 px-3 mb-3 rounded-2 small shadow-sm">
                    <div>
                        @TempData["Email"]
                        <div class="text-muted" style="font-size:11px;">check inbox or spam folder</div>
                    </div>
                    <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["Sent"] != null)
            {
                <div class="alert alert-info d-flex align-items-center justify-content-between py-2 px-3 mb-3 rounded-2 small shadow-sm">
                    <span>@TempData["Sent"]</span>
                    <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
                </div>
            }
  @* --- Alert Messages --- *@
                 


    <!-- Email -->
    <div class="mb-2">
        <label class="form-label mb-1" style="font-size:13px;">Email address</label>
        <input type="email" class="form-control form-control-sm" name="email"
               placeholder="you@example.com" autocomplete="email">
    </div>

    <!-- Password -->
    <div class="mb-2">
        <label class="form-label mb-1" style="font-size:13px;">Password</label>
        <div class="input-group input-group-sm">
            <input type="password" class="form-control" name="password"
                   id="instrPass" placeholder="Create a password">
            <button class="btn btn-outline-secondary pass-toggle" type="button"
                    onclick="togglePass('instrPass','instrEye')">
                <i class="bi bi-eye" id="instrEye"></i>
            </button>
        </div>
    </div>

    <!-- Confirm Password -->
    <div class="mb-3">
        <label class="form-label mb-1" style="font-size:13px;">Confirm Password</label>
        <input type="password" class="form-control form-control-sm" name="confirmpassword"
               placeholder="Repeat password">
    </div>

    <!-- submit -->
    <button type="submit" class="btn-auth mb-2">
        <i class="bi bi-arrow-right me-2"></i> Create Account & Continue
    </button>

    <!-- OR divider -->
    <div class="d-flex align-items-center my-2">
        <hr class="flex-grow-1 m-0"><span class="text-muted small px-2">OR</span><hr class="flex-grow-1 m-0">
    </div>

            <!-- Google Sign In -->
            <div id="g_id_onload"
                 data-client_id="@ViewBag.GoogleClientId"
                 data-callback="handleGoogleLogin"
                 data-auto_prompt="false">
            </div>

            <!-- Google button -->
            <div class="g_id_signin"
                 data-type="standard"
                 data-shape="rectangular"
                 data-theme="outline"
                 data-text="signin_with"
                 data-size="large"
                 data-width="100%">
            </div>

    <!-- already registered -->
    <p class="text-center text-muted mb-2" style="font-size:12px;">
        Already registered?
        <a asp-area="Instructor" asp-controller="Auth" asp-action="InstructorLogin"
        class="text-decoration-none fw-semibold" style="color:var(--role-color);">Log in</a>
    </p>

    <!-- role switcher — Student / Instructor (current) / Admin Login -->
    <div class="role-switcher">
        <div class="role-switcher-label">REGISTER AS</div>
        <div class="role-switcher-links">
            <a href="/Student/Register" class="role-link">
                <i class="bi bi-mortarboard"></i> Student
            </a>
            <a href="/Instructor/Register" class="role-link current">
                <i class="bi bi-person-video3"></i> Instructor
            </a>
            <!-- admin has no self-register -->
            <a href="/Admin/Login" class="role-link">
                <i class="bi bi-shield-lock"></i> Admin Login
            </a>
        </div>
    </div>

    </form>
    </div>
</section>

<script>
    function togglePass(inputId, iconId) {
      const input = document.getElementById(inputId);
      const icon  = document.getElementById(iconId);
      input.type  = input.type === 'password' ? 'text' : 'password';
      icon.className = input.type === 'text' ? 'bi bi-eye-slash' : 'bi bi-eye';
    }
</script>


@*    CSS  *@
<style>
    /* ===== Horizontal Step Bar ===== */
    .inst-steps-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 18px;
        position: relative;
    }

        /* connecting line */
        .inst-steps-top::before {
            content: '';
            position: absolute;
            top: 10px;
            left: 0;
            right: 0;
            height: 2px;
            background: #e5e7eb;
            z-index: 0;
        }

    .inst-step-top {
        position: relative;
        z-index: 1;
        text-align: center;
        flex: 1;
        font-size: 11px;
        color: #999;
    }

    /* circle */
    .inst-step-circle {
        width: 20px;
        height: 20px;
        border-radius: 50%;
        background: #e5e7eb;
        margin: 0 auto 4px;
        font-size: 11px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* active */
    .inst-step-top.active .inst-step-circle {
        background: var(--role-color);
        color: #fff;
    }

    .inst-step-top.active {
        color: var(--role-color);
        font-weight: 600;
    }

    /* done */
    .inst-step-top.done .inst-step-circle {
        background: var(--role-color);
        color: #fff;
    }

    /* tighten spacing inside card */
    .auth-card.inst-register {
        padding-top: 1.6rem;
    }
</style>