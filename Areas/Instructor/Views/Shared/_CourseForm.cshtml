
@model CourseVM


<div class="row g-3">
    @*  LEFT COLUMN ─ *@
    <div class="col-lg-8">
        @* Basic Info *@
        <div class="card border-0 inst-card mb-3">
            <div class="card-header bg-white border-bottom-0 pt-3 pb-2">
                <h6 class="fw-bold mb-0">
                    <i class="bi bi-journal-text me-2" style="color:var(--orange)"></i>Basic Information
                </h6>
            </div>

            <div class="card-body pt-2">
               @*  title *@
                <div class="mb-3">
                    <label class="form-label fw-semibold" style="font-size:13px;">
                        Course Title <span class="text-danger">*</span>
                    </label>
                    <input type="text" class="form-control"
                           placeholder="Enter Course Title " name="title">
                    <span class="text-danger small"></span>
                </div>
              @*  decription *@
                <div class="mb-3">
                    <label class="form-label fw-semibold" style="font-size:13px;">
                        Short Description <span class="text-danger">*</span>
                    </label>
                    <textarea class="form-control" rows="3"
                              placeholder="What will students learn in this course?" name="description"></textarea>
                    <span class="text-danger small"></span>
                </div>
             @* category *@
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold" style="font-size:13px;">
                            Category <span class="text-danger">*</span>
                        </label>

                        @* categories from DB - in future*@
                        <select class="form-select" name="category_id">
                            <option value="">Select category</option>
                            <option value="1">Software Development</option>
                            <option value="2">Data Science</option>
                            <option value="3">AI / Machine Learning</option>
                            <option value="4">DevOps & Cloud</option>
                            <option value="5">Cybersecurity</option>
                        </select>
                        <span class="text-danger small"></span>
                    </div>

                    @* Difficulty *@
                    <div class="col-md-6">
                        <label class="form-label fw-semibold" style="font-size:13px;">
                            Difficulty Level <span class="text-danger">*</span>
                        </label>
                        <select class="form-select" name="Difficulty">
                            <option value="">Select level</option>
                            <option value="Beginner">Beginner</option>
                            <option value="Intermediate">Intermediate</option>
                            <option value="Advanced">Advanced</option>
                        </select>
                    </div>
                </div>

               
                <div class="row g-3 mb-3">
                    @* Duration *@
                    <div class="col-md-4">
                        <label class="form-label fw-semibold" style="font-size:13px;">Duration (weeks)</label>
                        <input type="number" class="form-control" name="Duration_Weeks" placeholder="e.g. 12" min="1">
                    </div>
                    @* Price *@
                    <div class="col-md-4">
                        <label class="form-label fw-semibold" style="font-size:13px;">
                            Price (₹) <span class="text-danger">*</span>
                        </label>
                        <div class="input-group">
                            <span class="input-group-text bg-light">₹</span>
                            <input type="number" class="form-control" name="Actual_Price"
                                   id="originalPrice" placeholder="0 = Free" min="0">
                        </div>
                        <span class="text-danger small"></span>
                    </div>

                    @* dicount Percent *@
                    <div class="col-md-4">
                        <label class="form-label fw-semibold" style="font-size:13px;">Discount (%)</label>
                        <div class="input-group">
                            <input type="number" class="form-control"
                                   id="discountPct" placeholder="0" min="0" max="100" name="Discount_Percent">
                            <span class="input-group-text bg-light">%</span>
                        </div>
                    </div>
                </div>

                @* live price preview — shown by JS *@
                <div class="mb-3 p-3 rounded-3 border" id="pricePreview" style="display:none; background:#fff8f2;">
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <div class="text-center">
                            <div class="text-muted" style="font-size:11px; letter-spacing:.5px;">ORIGINAL</div>
                            <div class="fw-semibold" id="displayOriginal">₹0</div>
                        </div>
                        <i class="bi bi-dash text-muted"></i>
                        <div class="text-center">
                            <div class="text-muted" style="font-size:11px; letter-spacing:.5px;">DISCOUNT</div>
                            <div class="fw-semibold" id="displayDiscount" style="color:var(--orange);">₹0</div>
                        </div>
                        <i class="bi bi-equals text-muted"></i>
                        <div class="text-center">
                            <div class="text-muted" style="font-size:11px; letter-spacing:.5px;">FINAL</div>
                            <div class="fw-bold fs-5" id="displayFinal" style="color:var(--orange);">₹0</div>
                        </div>
                        <span class="badge bg-success" id="displayBadge"></span>
                    </div>
                </div>

                @* what students will learn *@
                @* Ouctcomes *@
                <div class="mb-0">
                    <label class="form-label fw-semibold" style="font-size:13px;">What Students Will Learn</label>
                    <textarea class="form-control" rows="4" name="OutcomesRaw"
                              placeholder="One outcome per line…"></textarea>
                    <small class="text-muted">Each line = one bullet on the course page</small>
                </div>

            </div>
        </div>

        @* Intro Video *@
        <div class="card border-0 inst-card mb-3">
            <div class="card-header bg-white border-bottom-0 pt-3 pb-2">
                <h6 class="fw-bold mb-0">
                    <i class="bi bi-play-circle me-2" style="color:var(--orange)"></i>Intro / Demo Video
                </h6>
            </div>
            <div class="card-body pt-2">

                @* toggle — only one active *@
                <div class="d-flex gap-2 mb-3">
                    <input type="radio" class="btn-check" name="videoType" id="ytOption" value="youtube" checked>
                    <label class="btn btn-outline-secondary btn-sm px-3" for="ytOption">
                        <i class="bi bi-youtube me-1 text-danger"></i>YouTube Link
                    </label>

                    <input type="radio" class="btn-check" name="videoType" id="uploadOption" value="upload">
                    <label class="btn btn-outline-secondary btn-sm px-3" for="uploadOption">
                        <i class="bi bi-upload me-1"></i>Upload Video
                    </label>
                </div>

                @* youtube panel *@
                <div id="ytPanel">
                    <input type="url" class="form-control" name="YouTubeUrl"
                           placeholder="https://youtube.com/watch?v=...">
                    <small class="text-muted">Paste YouTube URL — students see this as preview</small>
                </div>

                @* upload panel *@
                <div id="uploadPanel" style="display:none;">
                    <input type="file" class="form-control" accept="video/*" name="Video_File">
                    <small class="text-muted">MP4 recommended, max 200MB</small>
                </div>

            </div>
        </div>

    </div>

    @* ── RIGHT COLUMN ── *@
    <div class="col-lg-4">

        @* Thumbnail *@
        <div class="card border-0 inst-card mb-3">
            <div class="card-header bg-white border-bottom-0 pt-3 pb-2">
                <h6 class="fw-bold mb-0">
                    <i class="bi bi-image me-2" style="color:var(--orange)"></i>Course Thumbnail
                </h6>
            </div>
            <div class="card-body pt-2">

                @* preview box — JS swaps img src on file pick *@
                <div id="thumbPreview" class="rounded-3 mb-3 d-flex align-items-center justify-content-center border"
                     style="height:150px; background:#fafafa; cursor:pointer;"
                     onclick="document.getElementById('thumbInput').click()">
                    <div class="text-center text-muted" id="thumbPlaceholder">
                        <i class="bi bi-cloud-upload fs-2"></i>
                        <p class="small mb-0 mt-1">Click to upload</p>
                        <p style="font-size:11px;" class="mb-0">PNG, JPG · max 2MB</p>
                    </div>
                    @* replaced by actual img tag via JS *@
                </div>

                <input type="file" id="thumbInput" name="thumbnail_url"
                       class="form-control form-control-sm" accept="image/*" style="display:none;">
                <small class="text-muted d-block mt-1">16:9 ratio works best</small>

            </div>
        </div>

        @* Tips *@
        <div class="card border-0 inst-card">
            <div class="card-header bg-white border-bottom-0 pt-3 pb-2">
                <h6 class="fw-bold mb-0">
                    <i class="bi bi-lightbulb me-2 text-warning"></i>Quick Tips
                </h6>
            </div>
            <div class="card-body pt-0">
                <ul class="list-unstyled mb-0" style="font-size:13px;">
                    <li class="mb-2"><i class="bi bi-check2-circle text-success me-2"></i>Specific title = more clicks</li>
                    <li class="mb-2"><i class="bi bi-check2-circle text-success me-2"></i>List at least 4 learning outcomes</li>
                    <li class="mb-2"><i class="bi bi-check2-circle text-success me-2"></i>Good thumbnail boosts enrollment</li>
                    <li class="mb-2"><i class="bi bi-check2-circle text-success me-2"></i>Add intro video to build trust</li>
                    <li class="text-muted"><i class="bi bi-info-circle me-2"></i>Admin reviews before publishing</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@* video toggle — simple, no lib needed *@
<script>
    document.querySelectorAll('input[name="videoType"]').forEach(r => {
        r.addEventListener('change', () => {
            document.getElementById('ytPanel').style.display     = r.value === 'youtube' ? '' : 'none';
            document.getElementById('uploadPanel').style.display = r.value === 'upload'  ? '' : 'none';
        });
    });

    // thumbnail click-to-preview
    document.getElementById('thumbInput').addEventListener('change', function () {
        const file = this.files[0];
        if (!file) return;
        const url = URL.createObjectURL(file);
        const box = document.getElementById('thumbPreview');
        box.innerHTML = `<img src="${url}" style="width:100%;height:150px;object-fit:cover;border-radius:10px;">`;
    });
</script>