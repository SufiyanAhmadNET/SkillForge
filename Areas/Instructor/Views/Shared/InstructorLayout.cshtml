<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SkillForge – Instructor Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link href="/css/Instructor.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</head>
<body>

    <div class="d-flex">

        <!-- ===== SIDEBAR ===== -->
        <aside class="sidebar d-flex flex-column">

            <div class="sidebar-brand px-4 py-3 d-flex align-items-center gap-2 border-bottom border-secondary">
                <i class="bi bi-mortarboard-fill fs-5" style="color:var(--orange);"></i>
                <span class="fw-bold text-white">SkillForge</span>
                <span class="badge inst-badge ms-1">INSTRUCTOR</span>
            </div>

            <nav class="flex-grow-1 px-3 py-3">

                <p class="nav-section-label">OVERVIEW</p>
                <ul class="nav flex-column gap-1">
                    <li>
                        <a asp-area="Instructor" asp-controller="Home" asp-action="Dashboard" class="nav-link sidebar-link">
                            <i class="bi bi-grid me-2"></i>Dashboard
                        </a>
                    </li>
                </ul>

                <p class="nav-section-label mt-3">MY COURSES</p>
                <ul class="nav flex-column gap-1">
                    <li>
                        <a asp-area="Instructor" asp-controller="Home" asp-action="MyCourses" class="nav-link sidebar-link">
                            <i class="bi bi-journal-bookmark me-2"></i>My Courses
                        </a>
                    </li>

                    <li>
                        <a asp-area="Instructor" asp-controller="Home" asp-action="AddCourse" class="nav-link sidebar-link">
                            <i class="bi bi-plus-circle me-2"></i>Add Course
                        </a>
                    </li>
                </ul>

                <p class="nav-section-label mt-3">FINANCE</p>
                <ul class="nav flex-column gap-1">
                    <li>
                        <a asp-area="Instructor" asp-controller="Home" asp-action="Earning" class="nav-link sidebar-link">
                        <i class="bi bi-cash-stack me-2"></i>Earnings
                        </a>
                        </li>
                </ul>

                <p class="nav-section-label mt-3">ACCOUNT</p>
                <ul class="nav flex-column gap-1">
                    <li>
                        <a asp-area="Instructor" asp-controller="Home" asp-action="Profile" class="nav-link sidebar-link">
                        <i class="bi bi-person me-2"></i>Profile
                        </a>
                        </li>
                </ul>

            </nav>

            <div class="px-3 pb-3">
                <a asp-area="User" asp-controller="Account" asp-action="StudentRegistration" class="nav-link sidebar-link text-danger">
                    <i class="bi bi-box-arrow-left me-2"></i>Logout
                </a>
            </div>

        </aside>
        <!-- ===== /SIDEBAR ===== -->


        <div class="flex-grow-1 d-flex flex-column main-wrap">

            <!-- HEADER -->
            <header class="inst-header d-flex align-items-center justify-content-between px-4 bg-white border-bottom">
                <span class="fw-semibold">Dashboard</span>
                <div class="d-flex align-items-center gap-3">
                    <div class="input-group input-group-sm" style="width:210px;">
                        <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-search"></i></span>
                        <input type="text" class="form-control bg-light border-start-0" placeholder="Search…">
                    </div>
                    <button class="btn btn-light btn-sm position-relative">
                        <i class="bi bi-bell"></i>
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size:9px;">2</span>
                    </button>
                    <div class="d-flex align-items-center gap-2">
                        <div class="inst-avatar">S</div>
                        <div>
                            <div class="fw-semibold" style="font-size:13px;">Suresh Kumar</div>
                            <div class="text-muted" style="font-size:11px;">Instructor</div>
                        </div>
                    </div>
                </div>
            </header>
            <!-- /HEADER -->
            @RenderBody()
            @RenderSection("Scripts", required: false)
</body>
</html>
