@model List<SkillForge.Models.ModuleVM>
@{
    var bindingPrefix = ViewData["BindingPrefix"] as string ?? "Syllabus";
    var isAjax = ViewData["IsAjax"] != null && (bool)ViewData["IsAjax"];
}

@* Include the shared confirmation modal *@
@await Html.PartialAsync("_ConfirmModal")

<div class="syllabus-editor">
    <div id="syllabus-container">
        @if (Model != null && Model.Any())
        {
            for (int mIdx = 0; mIdx < Model.Count; mIdx++)
            {
                <div class="module-item @(mIdx == 0 ? "is-open" : "")" id="module-@mIdx">
                    <div class="module-header" onclick="toggleModule(@mIdx, event)">
                        <i class="bi bi-grid-3x3-gap module-drag-handle"></i>
                        <input type="text" name="@(bindingPrefix)[@mIdx].ModuleName" value="@Model[mIdx].ModuleName" 
                               class="module-title-input" placeholder="Module Name" required onclick="event.stopPropagation()">
                        
                        <span class="lesson-count-badge me-2" id="lesson-count-badge-@mIdx">@(Model[mIdx].Lessons?.Count ?? 0) lessons</span>
                        <i class="bi bi-chevron-down module-chevron me-3 d-none"></i>
                        
                        <button type="button" class="btn-remove-module" onclick="removeSyllabusElement('module-@mIdx'); event.stopPropagation();">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                    
                    <div class="module-body" id="module-body-@mIdx">
                        <div class="lesson-list" id="lesson-list-@mIdx">
                            @if (Model[mIdx].Lessons != null)
                            {
                                for (int lIdx = 0; lIdx < Model[mIdx].Lessons.Count; lIdx++)
                                {
                                    <div class="lesson-item" id="module-@mIdx-lesson-@lIdx">
                                        <div class="lesson-index">@(lIdx + 1)</div>
                                        <div class="yt-pill"><i class="bi bi-play-fill"></i></div>
                                        <div class="lesson-inputs">
                                            <input type="text" name="@(bindingPrefix)[@mIdx].Lessons[@lIdx].Title" value="@Model[mIdx].Lessons[lIdx].Title" 
                                                   class="form-control form-control-sm lesson-title-input" 
                                                   placeholder="Lesson title" required>
                                            <input type="url" name="@(bindingPrefix)[@mIdx].Lessons[@lIdx].VideoUrl" value="@Model[mIdx].Lessons[lIdx].VideoUrl" 
                                                   class="form-control form-control-sm lesson-url-input" 
                                                   placeholder="YouTube / video URL" required>
                                        </div>
                                        <button type="button" class="btn-remove-lesson" onclick="removeSyllabusElement('module-@mIdx-lesson-@lIdx')">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    </div>
                                }
                            }
                        </div>
                        <button type="button" class="btn-add-lesson" onclick="addSyllabusLesson(@mIdx)">
                            Add Lesson</button>
                    </div>
                    <input type="hidden" id="lesson-count-@mIdx" value="@(Model[mIdx].Lessons?.Count ?? 0)">
                </div>
            }
        }
    </div>

    @* Dynamic Add Module Button Area *@
    <div id="add-module-bottom-area" class="@(Model != null && Model.Any() ? "" : "d-none")">
        <div class="add-module-divider">
            <button type="button" class="btn-add-module-inline" onclick="addSyllabusModule()">
                <i class="bi bi-plus-lg me-1"></i>Add Module
            </button>
        </div>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div id="empty-syllabus-state" class="text-center py-5 border rounded-4 bg-light mb-4" style="cursor:pointer" onclick="addSyllabusModule()">
            <i class="bi bi-journal-plus display-4 text-muted opacity-25 mb-3 d-block"></i>
            <p class="text-muted small mb-0">No modules added yet. Click to start building your course content.</p>
        </div>
    }
</div>

<script>
    let syllabusModuleCount = @(Model?.Count ?? 0);
    const syllabusBindingPrefix = "@bindingPrefix";

    function toggleModule(mIdx, event) {
        const moduleItem = document.getElementById(`module-${mIdx}`);
        if (moduleItem) {
            moduleItem.classList.toggle('is-open');
        }
    }

    function updateLessonCountBadge(mIdx) {
        const container = document.getElementById(`lesson-list-${mIdx}`);
        const badge = document.getElementById(`lesson-count-badge-${mIdx}`);
        if (container && badge) {
            const count = container.children.length;
            badge.innerText = `${count} lesson${count !== 1 ? 's' : ''}`;
        }
    }

    function applyTruncation() {
        const container = document.getElementById('syllabus-container');
        const modules = container.querySelectorAll('.module-item');
        let truncationBtn = document.getElementById('truncation-btn');
        
        if (modules.length > 3) {
            if (!truncationBtn) {
                container.insertAdjacentHTML('afterend', `<button type="button" id="truncation-btn" class="truncation-btn" onclick="toggleTruncation()">Show all ${modules.length} modules ▼</button>`);
                truncationBtn = document.getElementById('truncation-btn');
            }
            
            const isExpanded = truncationBtn.getAttribute('data-expanded') === 'true';
            modules.forEach((mod, idx) => {
                if (idx >= 3) {
                    mod.style.display = isExpanded ? 'block' : 'none';
                }
            });
            
            truncationBtn.innerText = isExpanded ? 'Show less ▲' : `Show all ${modules.length} modules ▼`;
        } else if (truncationBtn) {
            truncationBtn.remove();
        }
    }

    function toggleTruncation() {
        const truncationBtn = document.getElementById('truncation-btn');
        const isExpanded = truncationBtn.getAttribute('data-expanded') === 'true';
        truncationBtn.setAttribute('data-expanded', !isExpanded);
        applyTruncation();
        
        if (isExpanded) {
            const container = document.getElementById('syllabus-container');
            container.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
    }

    function addSyllabusModule() {
        const container = document.getElementById('syllabus-container');
        const emptyState = document.getElementById('empty-syllabus-state');
        const addModuleArea = document.getElementById('add-module-bottom-area');

        if (emptyState) emptyState.remove();
        if (addModuleArea) addModuleArea.classList.remove('d-none');
        
        const mIdx = syllabusModuleCount++;
        const modHtml = `
            <div class="module-item is-open" id="module-${mIdx}">
                <div class="module-header" onclick="toggleModule(${mIdx}, event)">
                    <i class="bi bi-grid-3x3-gap module-drag-handle"></i>
                    <input type="text" name="${syllabusBindingPrefix}[${mIdx}].ModuleName" class="module-title-input" 
                           placeholder="Module Name" required onclick="event.stopPropagation()">
                    <span class="lesson-count-badge me-2" id="lesson-count-badge-${mIdx}">0 lessons</span>
                    <i class="bi bi-chevron-down module-chevron me-3"></i>
                    <button type="button" class="btn-remove-module" onclick="removeSyllabusElement('module-${mIdx}'); event.stopPropagation();">
                        <i class="bi bi-trash"></i>
                    </button>
                </div>
                
                <div class="module-body" id="module-body-${mIdx}">
                    <div class="lesson-list" id="lesson-list-${mIdx}"></div>
                    <button type="button" class="btn-add-lesson" onclick="addSyllabusLesson(${mIdx})">
                        Add Lesson</button>
                </div>
                <input type="hidden" id="lesson-count-${mIdx}" value="0">
            </div>
        `;
        
        container.insertAdjacentHTML('beforeend', modHtml);
        applyTruncation();
    }

    function addSyllabusLesson(mIdx) {
        const container = document.getElementById(`lesson-list-${mIdx}`);
        const countInput = document.getElementById(`lesson-count-${mIdx}`);
        const lIdx = parseInt(countInput.value);
        
        const lessonHtml = `
            <div class="lesson-item" id="module-${mIdx}-lesson-${lIdx}">
                <div class="lesson-index">${lIdx + 1}</div>
                <div class="yt-pill"><i class="bi bi-play-fill"></i></div>
                <div class="lesson-inputs">
                    <input type="text" name="${syllabusBindingPrefix}[${mIdx}].Lessons[${lIdx}].Title" 
                           class="form-control form-control-sm lesson-title-input" 
                           placeholder="Lesson title" required>
                    <input type="url" name="${syllabusBindingPrefix}[${mIdx}].Lessons[${lIdx}].VideoUrl" 
                           class="form-control form-control-sm lesson-url-input" 
                           placeholder="YouTube / video URL" required>
                </div>
                <button type="button" class="btn-remove-lesson" onclick="removeSyllabusElement('module-${mIdx}-lesson-${lIdx}')">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
        `;
        
        container.insertAdjacentHTML('beforeend', lessonHtml);
        countInput.value = lIdx + 1;
        updateLessonCountBadge(mIdx);
    }

    function removeSyllabusElement(id) {
        const msg = id.includes('-lesson-') ? "Delete this lesson?" : "Delete this entire module?";
        
        SkillForge.confirm({
            message: msg,
            confirmText: "Yes, Delete",
            onConfirm: () => executeRemoval(id)
        });
    }

    function executeRemoval(id) {
        const el = document.getElementById(id);
        if (el) {
            const mIdxMatch = id.match(/module-(\d+)/);
            el.remove();
            
            if (mIdxMatch && !id.includes('-lesson-')) {
                applyTruncation();
            } else if (mIdxMatch) {
                updateLessonCountBadge(mIdxMatch[1]);
            }
            
            const container = document.getElementById('syllabus-container');
            const addModuleArea = document.getElementById('add-module-bottom-area');
            if (container && container.children.length === 0) {
                 if (addModuleArea) addModuleArea.classList.add('d-none');
                 location.reload(); 
            }
        }
    }

    document.addEventListener('DOMContentLoaded', function() {
        applyTruncation();
    });
</script>
