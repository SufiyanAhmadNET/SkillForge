@model SkillForge.Areas.Instructor.Models.InstructorDashboardVM
@{
    ViewData["Title"] = "Profile";
    Layout = "~/Areas/Instructor/Views/Shared/InstructorLayout.cshtml";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-0">My Profile</h4>
        <span class="text-muted small">Update your public profile and professional settings</span>
    </div>
</div>

<div class="row g-4">

    <!-- LEFT SIDE: Profile Summary & Section Toggles -->
    <div class="col-lg-3">
        <div class="section-card text-center p-3 shadow-sm" style="background:#fff; border-radius:12px; border: 1px solid #e9ecef;">

            <!-- PROFILE PHOTO -->
            <img src="@((Model?.PhotoPath ?? "/images/DefaultProfilePhoto.jfif") + "?t=" + DateTime.Now.Ticks)"
                 id="avatarPreview"
                 class="rounded-circle mb-2"
                 style="width:100px;height:100px;object-fit:cover; border: 3px solid #f8f9fa;">

            <label for="PhotoFile" style="cursor:pointer;" class="d-block">
                <i class="bi bi-camera-fill text-muted"></i>
                <span class="small text-muted ms-1">Change Photo</span>
            </label>
            
            <input type="file" id="PhotoFile" name="PhotoFile" accept="image/*" class="d-none" onchange="previewAvatar(this)" form="profileForm">

            @* Photo Save Button *@
            <div id="photoSaveContainer" style="display:none;" class="mt-2">
                <button type="submit" class="btn btn-sm btn-purple w-100 py-2 shadow-sm rounded-pill" style="font-size:12px; font-weight:600;" form="profileForm">
                    <i class="bi bi-check-circle me-1"></i>Save Photo
                </button>
            </div>

            <h6 class="fw-bold mt-2 mb-0">@(string.IsNullOrEmpty(Model?.FirstName) ? "Guest" : Model.FirstName) @Model?.LastName</h6>
            <p class="text-muted small mb-2">@Model?.Email</p>
            <span class="badge bg-purple bg-opacity-10 text-purple px-3 mb-3" style="font-size:11px;">Active Instructor</span>

            <!-- SECTION TOGGLE BUTTONS -->
            <div class="d-flex flex-column gap-2 mt-2">
                <button type="button" data-section="basicSection" class="btn btn-sm w-100 py-2 btn-section btn-sidebar-nav active">
                    <i class="bi bi-person me-2"></i>Personal Info
                </button>

                <button type="button" data-section="professionalSection" class="btn btn-sm w-100 py-2 btn-section btn-sidebar-nav">
                    <i class="bi bi-briefcase me-2"></i>Professional
                </button>

                <button type="button" data-section="socialSection" class="btn btn-sm w-100 py-2 btn-section btn-sidebar-nav">
                    <i class="bi bi-link-45deg me-2"></i>Social Links
                </button>

                <button type="button" data-section="applicationSection" class="btn btn-sm w-100 py-2 btn-section btn-sidebar-nav">
                    <i class="bi bi-file-earmark-text me-2"></i>My Application
                </button>

                <button type="button" data-section="passwordSection" class="btn btn-sm w-100 py-2 btn-section btn-sidebar-nav">
                    <i class="bi bi-lock me-2"></i>Security
                </button>
            </div>

            <!-- STATS PREVIEW -->
            <div class="mt-4 pt-3 border-top">
                <div class="row g-2">
                    <div class="col-6">
                        <div class="stat-mini">
                            <div class="fw-bold text-purple">@Model.TotalCourses</div>
                            <div class="text-muted" style="font-size:10px;">Courses</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="stat-mini">
                            <div class="fw-bold text-purple">@Model.TotalStudents</div>
                            <div class="text-muted" style="font-size:10px;">Students</div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!-- RIGHT SIDE: Dynamic Sections -->
    <div class="col-lg-9">
        
        <form asp-area="Instructor" asp-controller="Home" asp-action="Profile" method="post" enctype="multipart/form-data" id="profileForm">
            @Html.AntiForgeryToken()
            
            <!-- BASIC INFO SECTION -->
            <div id="basicSection" class="profile-content-section active">
                <div class="section-card shadow-sm p-4 border-purple-soft" style="background:#fff; border-radius:12px;">
                    <div class="form-section-title">Personal Information</div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label small fw-medium">First Name</label>
                            <input type="text" name="FirstName" class="form-control" value="@Model.FirstName">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-medium">Last Name</label>
                            <input type="text" name="LastName" class="form-control" value="@Model.LastName">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-medium">Email Address</label>
                            <input type="email" class="form-control bg-light" value="@Model.Email" readonly>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-medium">Phone Number</label>
                            <input type="tel" name="Mobile" class="form-control" value="@Model.Mobile">
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-medium">Location</label>
                            <input type="text" name="Location" class="form-control" value="@Model.Location" placeholder="City, Country">
                        </div>
                        <div class="col-12 text-end mt-4">
                            <button type="submit" class="btn btn-purple-save px-5 py-2 shadow-sm">
                                Save Info
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- PROFESSIONAL SECTION -->
            <div id="professionalSection" class="profile-content-section">
                <div class="section-card shadow-sm p-4 border-purple-soft" style="background:#fff; border-radius:12px;">
                    <div class="form-section-title">Professional Details</div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label small fw-medium">Current Role</label>
                            <input type="text" name="CurrentRole" class="form-control" value="@Model.CurrentRole" placeholder="e.g. Senior Software Engineer">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-medium">Expertise</label>
                            <input type="text" name="Expertise" class="form-control" value="@Model.Expertise" placeholder="e.g. Java Developer & Technical Lead">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-medium">Years of Experience</label>
                            <input type="number" name="YearsExperience" class="form-control" value="@Model.YearsExperience" placeholder="e.g. 5">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-medium">Skills (Comma separated)</label>
                            <input type="text" name="Skills" class="form-control" value="@Model.Skills" placeholder="React, Node.js, C#, System Design">
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-medium">About You</label>
                            <textarea name="AboutYou" class="form-control" rows="5" placeholder="Share your experience and teaching style...">@Model.AboutYou</textarea>
                        </div>
                        <div class="col-12 text-end mt-4">
                            <button type="submit" class="btn btn-purple-save px-5 py-2 shadow-sm">
                                Save Professional
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- SOCIAL LINKS SECTION -->
            <div id="socialSection" class="profile-content-section">
                <div class="section-card shadow-sm p-4 border-purple-soft" style="background:#fff; border-radius:12px;">
                    <div class="form-section-title">Social & Professional Presence</div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label small fw-medium"><i class="bi bi-linkedin me-2 text-primary"></i>LinkedIn URL</label>
                            <input type="url" name="LinkedinUrl" class="form-control" value="@Model.LinkedinUrl" placeholder="https://linkedin.com/in/...">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-medium"><i class="bi bi-github me-2 text-dark"></i>GitHub URL</label>
                            <input type="url" name="GithubUrl" class="form-control" value="@Model.GithubUrl" placeholder="https://github.com/...">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-medium"><i class="bi bi-globe me-2 text-info"></i>Personal Website</label>
                            <input type="url" name="WebsiteUrl" class="form-control" value="@Model.WebsiteUrl" placeholder="https://yourportfolio.com">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-medium"><i class="bi bi-twitter-x me-2 text-dark"></i>Twitter / X</label>
                            <input type="url" name="TwitterUrl" class="form-control" value="@Model.TwitterUrl" placeholder="https://twitter.com/...">
                        </div>
                        <div class="col-12 text-end mt-4">
                            <button type="submit" class="btn btn-purple-save px-5 py-2 shadow-sm">
                                Save Social Links
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </form>

        <!-- MY APPLICATION SECTION -->
        <div id="applicationSection" class="profile-content-section">
            <div class="section-card shadow-sm p-4 border-purple-soft" style="background:#fff; border-radius:12px;">
                <div class="form-section-title">Mentor Application</div>

                @if (Model.ApplicationStatus == SkillForge.Services.Instructors.Models.MentorApplicationStatus.NotApplied || Model.ApplicationStatus == SkillForge.Services.Instructors.Models.MentorApplicationStatus.Rejected)
                {
                    <div id="appCtaView">
                        <div class="text-center py-4">
                            <div class="mb-4">
                                <div class="bg-purple bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                                    <i class="bi bi-mortarboard text-purple fs-1"></i>
                                </div>
                            </div>
                            <h4 class="fw-bold">Teach on SkillForge</h4>
                            <p class="text-muted mx-auto mb-4" style="max-width: 500px;">
                                Apply as a verified mentor and start creating courses that matter. 
                                Share your expertise with students around the globe.
                            </p>

                            @if (Model.ApplicationStatus == SkillForge.Services.Instructors.Models.MentorApplicationStatus.Rejected)
                            {
                                <div class="alert alert-danger mb-4 mx-auto" style="max-width: 600px;">
                                    <div class="fw-bold"><i class="bi bi-exclamation-triangle me-2"></i>Application Rejected</div>
                                    <p class="small mb-1">@Model.ApplicationComment</p>
                                    <span class="small opacity-75">You can reapply by addressing the feedback above.</span>
                                </div>
                            }

                            <button type="button" class="btn btn-purple px-5 py-2 shadow-sm rounded-pill" onclick="toggleApplicationView('form')">
                                @(Model.ApplicationStatus == SkillForge.Services.Instructors.Models.MentorApplicationStatus.Rejected ? "Reapply as Mentor" : "Apply as Mentor")
                            </button>
                        </div>
                    </div>

                    <div id="appFormView" style="display:none;">
                        <div class="d-flex align-items-center mb-4 pb-2 border-bottom">
                            <button type="button" class="btn btn-sm btn-light me-2 rounded-pill px-3" onclick="toggleApplicationView('cta')">
                                <i class="bi bi-arrow-left"></i> Back
                            </button>
                            <h5 class="fw-bold mb-0">Apply as Mentor</h5>
                        </div>

                        <form asp-area="Instructor" asp-controller="Home" asp-action="ApplyMentor" method="post" enctype="multipart/form-data">
                            @Html.AntiForgeryToken()
                            <div class="row g-4">
                                <div class="col-12">
                                    <label class="form-label small fw-medium">Upload Resume (PDF only)</label>
                                    <input type="file" name="ResumeFile" class="form-control" accept=".pdf" required>
                                </div>
                                <div class="col-12">
                                    <label class="form-label small fw-medium">Why do you want to teach on SkillForge?</label>
                                    <textarea name="WhyTeach" class="form-control" rows="4" placeholder="Share your motivation and goals..." required></textarea>
                                </div>
                                <div class="col-12">
                                    <label class="form-label small fw-medium">What topics can you teach?</label>
                                    <input type="text" name="Topics" class="form-control" placeholder="e.g. Web Development, AI, Business Strategy" required>
                                </div>
                                <div class="col-12">
                                    <label class="form-label small fw-medium">Portfolio / Course Sample Link (Optional)</label>
                                    <input type="url" name="PortfolioUrl" class="form-control" placeholder="https://yourportfolio.com or YouTube link">
                                </div>
                                
                                <div class="col-12">
                                    <div class="p-3 rounded-3 bg-light border">
                                        <div class="d-flex align-items-center gap-2 mb-2">
                                            <i class="bi bi-info-circle text-purple"></i>
                                            <span class="small fw-bold">Professional Auto-Sync</span>
                                        </div>
                                        <p class="small text-muted mb-0">
                                            Your Role (@Model.CurrentRole), Expertise (@Model.Expertise), and Experience (@Model.YearsExperience years) 
                                            will be included in your application from your professional profile.
                                        </p>
                                    </div>
                                </div>

                                <div class="col-12 text-end">
                                    <button type="submit" class="btn btn-purple px-5 py-2 shadow-sm rounded-pill">
                                        Submit Application
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                }
                else if (Model.ApplicationStatus == SkillForge.Services.Instructors.Models.MentorApplicationStatus.Pending)
                {
                    <div class="text-center py-5">
                        <div class="mb-4">
                            <div class="bg-primary bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                                <i class="bi bi-clock-history text-primary fs-1"></i>
                            </div>
                        </div>
                        <h4 class="fw-bold">Application Pending</h4>
                        <p class="text-muted mx-auto mb-4" style="max-width: 500px;">
                            We have received your mentor application! Our team is currently reviewing your profile and professional details.
                            We'll notify you via email once a decision is made.
                        </p>
                        <div class="badge bg-primary px-4 py-2 rounded-pill shadow-sm">Review in Progress</div>
                    </div>
                }
                else if (Model.ApplicationStatus == SkillForge.Services.Instructors.Models.MentorApplicationStatus.Approved)
                {
                    <div class="text-center py-5">
                        <div class="mb-4">
                            <div class="bg-success bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                                <i class="bi bi-patch-check-fill text-success fs-1"></i>
                            </div>
                        </div>
                        <h4 class="fw-bold">Verified Mentor</h4>
                        <p class="text-muted mx-auto mb-4" style="max-width: 500px;">
                            Congratulations! Your mentor application has been approved. 
                            You now have full access to create courses and manage your teaching dashboard.
                        </p>
                        <div class="badge bg-success px-4 py-2 rounded-pill shadow-sm">Approved & Verified</div>
                        
                        <div class="mt-5 pt-4 border-top">
                            <a asp-area="Instructor" asp-controller="Home" asp-action="AddCourse" class="btn btn-purple px-4 py-2 rounded-pill shadow-sm">
                                <i class="bi bi-plus-circle me-2"></i>Create New Course
                            </a>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- SECURITY SECTION (OUTSIDE MAIN FORM TO AVOID NESTING) -->
        <div id="passwordSection" class="profile-content-section">
            
            <!-- OPTIONS VIEW -->
            <div id="securityOptionsView">
                <div class="row g-3">
                    <div class="col-sm-6">
                        <div class="section-card shadow-sm p-4 text-center security-option-card border-purple-soft" 
                             style="background:#fff; border-radius:12px; cursor:pointer; height: 100%; transition: all 0.3s;" 
                             onclick="toggleSecurityView('change')">
                            <i class="bi bi-shield-lock text-purple mb-2 d-block" style="font-size: 2rem;"></i>
                            <h6 class="fw-bold mb-2">Change Password</h6>
                            <p class="text-muted mb-0" style="font-size: 0.75rem;">Update current password</p>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="section-card shadow-sm p-4 text-center security-option-card border-purple-soft" 
                             style="background:#fff; border-radius:12px; cursor:pointer; height: 100%; transition: all 0.3s;" 
                             onclick="toggleSecurityView('forgot')">
                            <i class="bi bi-shield-exclamation text-purple mb-2 d-block" style="font-size: 2rem;"></i>
                            <h6 class="fw-bold mb-2">Forgot Password</h6>
                            <p class="text-muted mb-0" style="font-size: 0.75rem;">Recover via email OTP</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- CHANGE PASSWORD FORM -->
            <div id="changePasswordView" style="display:none;">
                <div class="section-card shadow-sm p-4 border-purple-soft" style="background:#fff; border-radius:12px;">
                    <div class="d-flex align-items-center mb-3 pb-2 border-bottom">
                        <button type="button" class="btn btn-sm btn-light me-2 rounded-pill px-3" style="font-size: 0.75rem;" onclick="toggleSecurityView('options')">
                            <i class="bi bi-arrow-left"></i> Back
                        </button>
                        <span class="fw-bold text-purple small text-uppercase" style="letter-spacing: 0.5px;">Change Password</span>
                    </div>
                    
                    <div style="max-width: 450px; margin: 0 auto;">
                        <form action="/Instructor/Home/UpdatePassword" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="role" value="Instructor">
                            <input type="hidden" name="source" value="change">
                            
                            <div class="mb-3">
                                <label class="form-label small fw-medium">Current Password</label>
                                <input type="password" name="currentPassword" class="form-control form-control-sm" placeholder="Enter current password" required>
                            </div>
                            
                            <div class="mb-3">
                                <label class="form-label small fw-medium">New Password</label>
                                <input type="password" name="newPassword" class="form-control form-control-sm" placeholder="Minimum 6 characters" required minlength="6">
                            </div>
                            
                            <div class="mb-4">
                                <label class="form-label small fw-medium">Confirm New Password</label>
                                <input type="password" name="confirmPassword" class="form-control form-control-sm" placeholder="Repeat new password" required>
                            </div>
                            
                            <div class="text-end">
                                <button type="submit" class="btn btn-purple-save btn-sm w-100 py-2 shadow-sm rounded-pill">
                                    <i class="bi bi-check-circle me-2"></i>Update Password
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- FORGOT PASSWORD FORM -->
            <div id="forgotPasswordView" style="display:none;">
                <div class="section-card shadow-sm p-4 border-purple-soft" style="background:#fff; border-radius:12px;">
                    <div class="d-flex align-items-center mb-3 pb-2 border-bottom">
                        <button type="button" class="btn btn-sm btn-light me-2 rounded-pill px-3" style="font-size: 0.75rem;" onclick="toggleSecurityView('options')">
                            <i class="bi bi-arrow-left"></i> Back
                        </button>
                        <span class="fw-bold text-purple small text-uppercase" style="letter-spacing: 0.5px;">Recovery Flow</span>
                    </div>

                    @await Html.PartialAsync("_ForgotPasswordPartial", Model.Email)
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --purple: #7c3aed;
        --purple-soft: rgba(124,58,237,.10);
        --purple-dark: #6d28d9;
    }

    .section-card {
        padding: 20px;
        background: #fff;
        border-radius: 12px;
    }

    .form-section-title {
        font-size: .75rem;
        font-weight: 700;
        letter-spacing: 1px;
        color: var(--purple);
        text-transform: uppercase;
        margin-bottom: 20px;
        padding-bottom: 10px;
        border-bottom: 1px solid #f1f3f5;
    }

    .btn-section {
        border: 1px solid #e9ecef;
        background: #fff;
        color: #495057;
        text-align: left;
        font-weight: 500;
        transition: all 0.2s;
        border-radius: 8px;
    }

    .btn-section:hover {
        background: var(--purple-soft);
        color: var(--purple);
    }

    .btn-sidebar-nav.active {
        background-color: var(--purple) !important;
        color: #fff !important;
        border: none !important;
        box-shadow: 0 4px 10px rgba(124, 58, 237, 0.2);
    }

    .btn-purple-save {
        background-color: var(--purple);
        color: #fff;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .btn-purple-save:hover {
        background-color: var(--purple-dark);
        color: #fff;
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(124, 58, 237, 0.25);
    }

    .btn-purple {
        background-color: var(--purple);
        color: #fff;
    }

    .stat-mini {
        background: var(--purple-soft);
        padding: 8px;
        border-radius: 8px;
    }

    .text-purple { color: var(--purple); }
    .bg-purple { background-color: var(--purple); }
    .border-purple-soft { border: 1px solid var(--purple-soft) !important; }

    .profile-content-section {
        display: none;
    }
    .profile-content-section.active {
        display: block;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const navBtns = document.querySelectorAll('.btn-sidebar-nav');
        const sections = document.querySelectorAll('.profile-content-section');

        navBtns.forEach(btn => {
            btn.addEventListener('click', function() {
                const targetId = this.getAttribute('data-section');
                
                // Update nav buttons
                navBtns.forEach(b => b.classList.remove('active'));
                this.classList.add('active');
                
                // Update sections
                sections.forEach(s => s.classList.remove('active'));
                document.getElementById(targetId).classList.add('active');
            });
        });

        // Tab and View persistence from URL
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get('tab') === 'security') {
            const secBtn = document.querySelector('[data-section="passwordSection"]');
            if (secBtn) {
                secBtn.click();
                const view = urlParams.get('view');
                if (view) toggleSecurityView(view);
            }
        } else if (urlParams.get('tab') === 'application') {
            const appBtn = document.querySelector('[data-section="applicationSection"]');
            if (appBtn) appBtn.click();
        }
    });

    function previewAvatar(input) {
        if (input.files && input.files[0]) {
            var reader = new FileReader();
            reader.onload = function (e) {
                document.getElementById('avatarPreview').src = e.target.result;
                document.getElementById('photoSaveContainer').style.display = 'block';
            };
            reader.readAsDataURL(input.files[0]);
        }
    }

    function toggleSecurityView(view) {
        // hide all sub-views
        const subviews = ['securityOptionsView', 'changePasswordView', 'forgotPasswordView'];
        subviews.forEach(id => {
            const el = document.getElementById(id);
            if (el) el.style.display = 'none';
        });
        
        // show target
        let targetId = 'securityOptionsView';
        if (view === 'change') targetId = 'changePasswordView';
        else if (view === 'forgot') targetId = 'forgotPasswordView';
        
        const target = document.getElementById(targetId);
        if (target) {
            target.style.display = 'block';
            $(target).hide().fadeIn(300);
        }
    }

    function toggleApplicationView(view) {
        const ctaView = document.getElementById('appCtaView');
        const formView = document.getElementById('appFormView');
        
        if (view === 'form') {
            if (ctaView) ctaView.style.display = 'none';
            if (formView) {
                formView.style.display = 'block';
                $(formView).hide().fadeIn(300);
            }
        } else {
            if (formView) formView.style.display = 'none';
            if (ctaView) {
                ctaView.style.display = 'block';
                $(ctaView).hide().fadeIn(300);
            }
        }
    }
</script>
