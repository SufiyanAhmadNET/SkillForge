@model SkillForge.Areas.Instructor.Models.InstructorDashboardVM
@{
    ViewData["Title"] = "Profile";
    Layout = "~/Areas/Instructor/Views/Shared/InstructorLayout.cshtml";
}

<div class="container-fluid px-0" style="max-width: 1200px;">
    
    <!-- Header Row -->
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div class="page-title-bar">
            <h4 class="fw-bold mb-0">My Profile</h4>
            <span class="text-muted small">Update your public profile and professional settings</span>
        </div>
    </div>

    <div class="row g-4">

        <!-- LEFT SIDE: Profile Summary -->
        <div class="col-lg-3">
            <div class="section-card text-center p-4">

                <!-- Profile Photo Section -->
                <div class="position-relative d-inline-block mb-3">
                    <img src="@((Model?.PhotoPath ?? "/images/DefaultProfilePhoto.jfif") + "?t=" + DateTime.Now.Ticks)"
                         id="avatarPreview"
                         class="rounded-circle border border-3 border-light shadow-sm"
                         style="width:110px; height:110px; object-fit:cover;">
                    
                    <label for="PhotoFile" class="position-absolute bottom-0 end-0 bg-white shadow-sm rounded-circle d-flex align-items-center justify-content-center" 
                           style="width: 32px; height: 32px; cursor:pointer; border: 1px solid #eee;">
                        <i class="bi bi-camera-fill text-purple small"></i>
                    </label>
                </div>
                
                <input type="file" id="PhotoFile" name="PhotoFile" accept="image/*" class="d-none" onchange="previewAvatar(this)" form="profileForm">

                @* Photo Save Button — appears on change *@
                <div id="photoSaveContainer" style="display:none;" class="mb-3">
                    <button type="submit" class="btn btn-sm btn-purple w-100 py-2 rounded-pill fw-semibold" style="font-size:12px;" form="profileForm">
                        <i class="bi bi-check-circle me-1"></i>Save Photo
                    </button>
                </div>

                <h6 class="fw-bold mb-1">@(string.IsNullOrEmpty(Model?.FirstName) ? "Guest" : Model.FirstName) @Model?.LastName</h6>
                <p class="text-muted small mb-3">@Model?.Email</p>
                <div class="mb-4">
                    <span class="badge bg-purple-soft text-purple px-3 py-2 rounded-pill" style="font-size:11px; font-weight: 600;">Active Instructor</span>
                </div>

                <!-- Section Navigation -->
                <div class="nav flex-column gap-2 text-start">
                    <button type="button" data-section="basicSection" class="btn btn-section active">
                        <i class="bi bi-person me-2"></i>Personal Info
                    </button>

                    <button type="button" data-section="professionalSection" class="btn btn-section">
                        <i class="bi bi-briefcase me-2"></i>Professional
                    </button>

                    <button type="button" data-section="socialSection" class="btn btn-section">
                        <i class="bi bi-link-45deg me-2"></i>Social Presence
                    </button>

                    <button type="button" data-section="applicationSection" class="btn btn-section">
                        <i class="bi bi-file-earmark-text me-2"></i>Instructor Application
                    </button>

                    <button type="button" data-section="passwordSection" class="btn btn-section">
                        <i class="bi bi-lock me-2"></i>Security Settings
                    </button>
                </div>

                <!-- Miniature Stats -->
                <div class="mt-4 pt-3 border-top">
                    <div class="row g-2">
                        <div class="col-6">
                            <div class="stat-mini p-2 rounded-3 text-center">
                                <div class="fw-bold text-purple h6 mb-0">@Model.TotalCourses</div>
                                <div class="text-muted" style="font-size:10px; font-weight: 500;">Courses</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="stat-mini p-2 rounded-3 text-center">
                                <div class="fw-bold text-purple h6 mb-0">@Model.TotalStudents</div>
                                <div class="text-muted" style="font-size:10px; font-weight: 500;">Students</div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>

        <!-- RIGHT SIDE: Dynamic Sections -->
        <div class="col-lg-9">
            
            <form asp-area="Instructor" asp-controller="Home" asp-action="Profile" method="post" enctype="multipart/form-data" id="profileForm">
                @Html.AntiForgeryToken()
                
                <!-- BASIC INFO SECTION -->
                <div id="basicSection" class="profile-content-section active">
                    <div class="section-card shadow-sm p-4 border-purple-soft">
                        <div class="form-section-title">Personal Information</div>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label small fw-medium">First Name</label>
                                <input type="text" name="FirstName" class="form-control" value="@Model.FirstName" placeholder="Your first name">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-medium">Last Name</label>
                                <input type="text" name="LastName" class="form-control" value="@Model.LastName" placeholder="Your last name">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-medium">Email Address (Primary)</label>
                                <input type="email" class="form-control bg-light" value="@Model.Email" readonly>
                                <div class="form-text small opacity-75">Email cannot be changed from profile.</div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-medium">Phone Number</label>
                                <input type="tel" name="Mobile" class="form-control" value="@Model.Mobile" placeholder="+91 00000 00000">
                            </div>
                            <div class="col-12">
                                <label class="form-label small fw-medium">Location / City</label>
                                <input type="text" name="Location" class="form-control" value="@Model.Location" placeholder="e.g. Mumbai, India">
                            </div>
                            <div class="col-12 text-end mt-4 pt-2 border-top">
                                <button type="submit" class="btn btn-purple-save px-5 shadow-sm">
                                    <i class="bi bi-save2 me-2"></i>Save Basic Info
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- PROFESSIONAL SECTION -->
                <div id="professionalSection" class="profile-content-section">
                    <div class="section-card shadow-sm p-4 border-purple-soft">
                        <div class="form-section-title">Professional Background</div>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label small fw-medium">Professional Title / Headline</label>
                                <input type="text" name="CurrentRole" class="form-control" value="@Model.CurrentRole" placeholder="e.g. Senior Software Architect">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-medium">Primary Expertise</label>
                                <input type="text" name="Expertise" class="form-control" value="@Model.Expertise" placeholder="e.g. Full Stack Web Development">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-medium">Years of Experience</label>
                                <input type="number" name="YearsExperience" class="form-control" value="@Model.YearsExperience" placeholder="e.g. 8">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-medium">Key Skills (Comma separated)</label>
                                <input type="text" name="Skills" class="form-control" value="@Model.Skills" placeholder="React, .NET, AWS, Docker">
                            </div>
                            <div class="col-12">
                                <label class="form-label small fw-medium">Professional Biography</label>
                                <textarea name="AboutYou" class="form-control" rows="6" placeholder="Describe your professional journey and teaching philosophy...">@Model.AboutYou</textarea>
                            </div>
                            <div class="col-12 text-end mt-4 pt-2 border-top">
                                <button type="submit" class="btn btn-purple-save px-5 shadow-sm">
                                    <i class="bi bi-save2 me-2"></i>Save Professional Details
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- SOCIAL LINKS SECTION -->
                <div id="socialSection" class="profile-content-section">
                    <div class="section-card shadow-sm p-4 border-purple-soft">
                        <div class="form-section-title">Social & Professional Channels</div>
                        <div class="row g-4">
                            <div class="col-md-6">
                                <label class="form-label small fw-medium text-primary"><i class="bi bi-linkedin me-1"></i>LinkedIn Profile</label>
                                <input type="url" name="LinkedinUrl" class="form-control" value="@Model.LinkedinUrl" placeholder="https://linkedin.com/in/username">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-medium text-dark"><i class="bi bi-github me-1"></i>GitHub Profile</label>
                                <input type="url" name="GithubUrl" class="form-control" value="@Model.GithubUrl" placeholder="https://github.com/username">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-medium text-info"><i class="bi bi-globe me-1"></i>Personal Portfolio / Website</label>
                                <input type="url" name="WebsiteUrl" class="form-control" value="@Model.WebsiteUrl" placeholder="https://yourwebsite.com">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-medium text-dark"><i class="bi bi-twitter-x me-1"></i>Twitter / X</label>
                                <input type="url" name="TwitterUrl" class="form-control" value="@Model.TwitterUrl" placeholder="https://twitter.com/username">
                            </div>
                            <div class="col-12 text-end mt-4 pt-2 border-top">
                                <button type="submit" class="btn btn-purple-save px-5 shadow-sm">
                                    <i class="bi bi-save2 me-2"></i>Save Social Channels
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </form>

            <!-- APPLICATION SECTION -->
            <div id="applicationSection" class="profile-content-section">
                <div class="section-card shadow-sm p-4 border-purple-soft">
                    <div class="form-section-title">Mentor Certification</div>

                    @if (Model.ApplicationStatus == SkillForge.Services.Instructors.Models.MentorApplicationStatus.NotApplied || Model.ApplicationStatus == SkillForge.Services.Instructors.Models.MentorApplicationStatus.Rejected)
                    {
                        <div id="appCtaView">
                            <div class="text-center py-5">
                                <div class="mb-4">
                                    <div class="bg-purple bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                                        <i class="bi bi-mortarboard text-purple fs-1"></i>
                                    </div>
                                </div>
                                <h4 class="fw-bold">Ready to Teach?</h4>
                                <p class="text-muted mx-auto mb-4" style="max-width: 500px;">
                                    Become a verified instructor to start creating courses and sharing your knowledge with students globally.
                                </p>

                                @if (Model.ApplicationStatus == SkillForge.Services.Instructors.Models.MentorApplicationStatus.Rejected)
                                {
                                    <div class="alert alert-danger mb-4 mx-auto text-start" style="max-width: 600px; border-radius: 12px;">
                                        <div class="fw-bold mb-1"><i class="bi bi-exclamation-triangle-fill me-2"></i>Application Feedback</div>
                                        <p class="small mb-2">@Model.ApplicationComment</p>
                                        <span class="small opacity-75">Update your professional details and reapply to proceed.</span>
                                    </div>
                                }

                                <button type="button" class="btn btn-purple px-5 py-2 shadow-sm rounded-pill fw-bold" onclick="toggleApplicationView('form')">
                                    @(Model.ApplicationStatus == SkillForge.Services.Instructors.Models.MentorApplicationStatus.Rejected ? "Reapply Now" : "Apply to Teach")
                                </button>
                            </div>
                        </div>

                        <div id="appFormView" style="display:none;">
                            <div class="d-flex align-items-center mb-4 pb-2 border-bottom">
                                <button type="button" class="btn btn-sm btn-light me-3 rounded-pill px-3 shadow-sm border" onclick="toggleApplicationView('cta')">
                                    <i class="bi bi-arrow-left"></i> Back
                                </button>
                                <h5 class="fw-bold mb-0">Instructor Application</h5>
                            </div>

                            <form asp-area="Instructor" asp-controller="Home" asp-action="ApplyMentor" method="post" enctype="multipart/form-data">
                                @Html.AntiForgeryToken()
                                <div class="row g-4">
                                    <div class="col-12">
                                        <label class="form-label small fw-bold">Professional Resume (PDF)</label>
                                        <input type="file" name="ResumeFile" class="form-control shadow-none" accept=".pdf" required>
                                        <div class="form-text small">Upload your CV to verify your experience.</div>
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label small fw-bold">Why do you want to teach on SkillForge?</label>
                                        <textarea name="WhyTeach" class="form-control shadow-none" rows="4" placeholder="Your teaching goals and motivation..." required></textarea>
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label small fw-bold">Teaching Topics</label>
                                        <input type="text" name="Topics" class="form-control shadow-none" placeholder="e.g. Java, Python, Machine Learning" required>
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label small fw-bold">Portfolio / Link (Optional)</label>
                                        <input type="url" name="PortfolioUrl" class="form-control shadow-none" placeholder="Link to existing courses, YouTube, or portfolio">
                                    </div>
                                    
                                    <div class="col-12">
                                        <div class="p-3 rounded-4 bg-purple-soft border border-purple-soft">
                                            <div class="d-flex align-items-center gap-2 mb-2">
                                                <i class="bi bi-info-circle-fill text-purple"></i>
                                                <span class="small fw-bold text-purple">Profile Synchronization</span>
                                            </div>
                                            <p class="small text-muted mb-0">
                                                Your current role (@(Model.CurrentRole ?? "N/A")) and expertise will be automatically attached to this application.
                                            </p>
                                        </div>
                                    </div>

                                    <div class="col-12 text-end mt-4">
                                        <button type="submit" class="btn btn-purple px-5 py-2 shadow-sm rounded-pill fw-bold">
                                            Submit Final Application
                                        </button>
                                    </div>
                                </div>
                            </form>
                        </div>
                    }
                    else if (Model.ApplicationStatus == SkillForge.Services.Instructors.Models.MentorApplicationStatus.Pending)
                    {
                        <div class="text-center py-5">
                            <div class="mb-4">
                                <div class="bg-primary bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                                    <i class="bi bi-hourglass-split text-primary fs-1"></i>
                                </div>
                            </div>
                            <h4 class="fw-bold">Verification in Progress</h4>
                            <p class="text-muted mx-auto mb-4" style="max-width: 500px;">
                                Your application is under review. Our team will verify your credentials and get back to you within 48-72 hours.
                            </p>
                            <div class="badge bg-primary px-4 py-2 rounded-pill shadow-sm">Awaiting Review</div>
                        </div>
                    }
                    else if (Model.ApplicationStatus == SkillForge.Services.Instructors.Models.MentorApplicationStatus.Approved)
                    {
                        <div class="text-center py-5">
                            <div class="mb-4">
                                <div class="bg-success bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                                    <i class="bi bi-check-all text-success fs-1"></i>
                                </div>
                            </div>
                            <h4 class="fw-bold text-success">Verification Complete</h4>
                            <p class="text-muted mx-auto mb-4" style="max-width: 500px;">
                                Your mentor profile is verified! You can now start creating courses and building your student base.
                            </p>
                            <div class="badge bg-success px-4 py-2 rounded-pill shadow-sm">Verified Instructor</div>
                            
                            <div class="mt-5 pt-4 border-top">
                                <a asp-area="Instructor" asp-controller="Home" asp-action="AddCourse" class="btn btn-purple px-4 py-2 rounded-pill shadow-sm fw-bold">
                                    <i class="bi bi-plus-circle me-2"></i>Launch Your Course
                                </a>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- SECURITY SECTION -->
            <div id="passwordSection" class="profile-content-section">
                
                <!-- Security Options -->
                <div id="securityOptionsView">
                    <div class="row g-3">
                        <div class="col-sm-6">
                            <div class="section-card shadow-sm p-4 text-center security-option-card h-100" 
                                 onclick="toggleSecurityView('change')">
                                <i class="bi bi-key-fill text-purple mb-2 d-block" style="font-size: 2.2rem;"></i>
                                <h6 class="fw-bold mb-1">Update Password</h6>
                                <p class="text-muted mb-0 small">Change your account password</p>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="section-card shadow-sm p-4 text-center security-option-card h-100" 
                                 onclick="toggleSecurityView('forgot')">
                                <i class="bi bi-envelope-check text-purple mb-2 d-block" style="font-size: 2.2rem;"></i>
                                <h6 class="fw-bold mb-1">Recovery Access</h6>
                                <p class="text-muted mb-0 small">Reset access via Email OTP</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Change Password Form -->
                <div id="changePasswordView" style="display:none;">
                    <div class="section-card shadow-sm p-4 border-purple-soft">
                        <div class="d-flex align-items-center mb-4 pb-2 border-bottom">
                            <button type="button" class="btn btn-sm btn-light me-3 rounded-pill px-3 shadow-sm border" onclick="toggleSecurityView('options')">
                                <i class="bi bi-arrow-left"></i> Back
                            </button>
                            <h5 class="fw-bold mb-0 text-purple">Update Security Credentials</h5>
                        </div>
                        
                        <div style="max-width: 500px; margin: 0 auto;" class="py-2">
                            <form action="/Instructor/Home/UpdatePassword" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="role" value="Instructor">
                                <input type="hidden" name="source" value="change">
                                
                                <div class="mb-3">
                                    <label class="form-label small fw-bold">Current Password</label>
                                    <input type="password" name="currentPassword" class="form-control py-2 shadow-none" placeholder="Enter existing password" required>
                                </div>
                                
                                <div class="mb-3">
                                    <label class="form-label small fw-bold">New Password</label>
                                    <input type="password" name="newPassword" class="form-control py-2 shadow-none" placeholder="Create strong password (min. 6 chars)" required minlength="6">
                                </div>
                                
                                <div class="mb-4">
                                    <label class="form-label small fw-bold">Confirm New Password</label>
                                    <input type="password" name="confirmPassword" class="form-control py-2 shadow-none" placeholder="Confirm password" required>
                                </div>
                                
                                <div class="text-end">
                                    <button type="submit" class="btn btn-purple-save w-100 py-2 shadow-sm rounded-pill fw-bold">
                                        Confirm Password Update
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- Forgot Password Recovery -->
                <div id="forgotPasswordView" style="display:none;">
                    <div class="section-card shadow-sm p-4 border-purple-soft">
                        <div class="d-flex align-items-center mb-4 pb-2 border-bottom">
                            <button type="button" class="btn btn-sm btn-light me-3 rounded-pill px-3 shadow-sm border" onclick="toggleSecurityView('options')">
                                <i class="bi bi-arrow-left"></i> Back
                            </button>
                            <h5 class="fw-bold mb-0 text-purple">Account Recovery Channel</h5>
                        </div>

                        <div class="recovery-wrapper py-2">
                            @await Html.PartialAsync("_ForgotPasswordPartial", Model.Email)
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Scoped refinements for Profile Page */
    .form-section-title {
        font-size: .85rem;
        font-weight: 800;
        letter-spacing: 1.2px;
        color: var(--purple);
        text-transform: uppercase;
        margin-bottom: 24px;
        padding-bottom: 12px;
        border-bottom: 2px solid var(--purple-soft);
    }

    .btn-section {
        border: 1px solid #f1f3f5;
        background: #fff;
        color: #555;
        text-align: left;
        font-weight: 600;
        font-size: 0.85rem;
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        border-radius: 10px;
        width: 100%;
        padding: 12px 16px !important;
    }

    .btn-section:hover {
        background: var(--purple-soft);
        color: var(--purple);
        border-color: var(--purple-soft);
    }

    .btn-section.active {
        background-color: var(--purple) !important;
        color: #fff !important;
        border-color: var(--purple) !important;
        box-shadow: 0 6px 15px rgba(124, 58, 237, 0.15);
    }

    .stat-mini {
        background: var(--purple-soft);
        transition: transform 0.2s;
    }
    .stat-mini:hover {
        transform: translateY(-2px);
    }

    .security-option-card {
        cursor: pointer;
        transition: all 0.25s ease;
        border: 1px solid #f1f3f5;
    }
    .security-option-card:hover {
        background: var(--purple-soft);
        border-color: var(--purple-soft);
        transform: translateY(-3px);
        box-shadow: 0 8px 20px rgba(124, 58, 237, 0.08);
    }

    .profile-content-section {
        display: none;
        animation: slideUpFade 0.4s ease-out;
    }
    .profile-content-section.active {
        display: block;
    }

    @@keyframes slideUpFade {
        from { opacity: 0; transform: translateY(12px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* Form control polish */
    .form-control {
        border: 1px solid #e9ecef;
        border-radius: 8px;
        font-size: 0.9rem;
    }
    .form-label {
        color: #334155;
        margin-bottom: 0.4rem;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const navBtns = document.querySelectorAll('.btn-section');
        const sections = document.querySelectorAll('.profile-content-section');

        navBtns.forEach(btn => {
            btn.addEventListener('click', function() {
                const targetId = this.getAttribute('data-section');
                
                // Update nav buttons
                navBtns.forEach(b => b.classList.remove('active'));
                this.classList.add('active');
                
                // Update sections
                sections.forEach(s => s.classList.remove('active'));
                const targetSection = document.getElementById(targetId);
                if(targetSection) targetSection.classList.add('active');
            });
        });

        // Tab Persistence
        const urlParams = new URLSearchParams(window.location.search);
        const tab = urlParams.get('tab');
        if (tab === 'security') {
            const btn = document.querySelector('[data-section="passwordSection"]');
            if (btn) btn.click();
            const view = urlParams.get('view');
            if (view) toggleSecurityView(view);
        } else if (tab === 'application') {
            const btn = document.querySelector('[data-section="applicationSection"]');
            if (btn) btn.click();
        }
    });

    function previewAvatar(input) {
        if (input.files && input.files[0]) {
            var reader = new FileReader();
            reader.onload = function (e) {
                document.getElementById('avatarPreview').src = e.target.result;
                document.getElementById('photoSaveContainer').style.display = 'block';
            };
            reader.readAsDataURL(input.files[0]);
        }
    }

    function toggleSecurityView(view) {
        const subviews = ['securityOptionsView', 'changePasswordView', 'forgotPasswordView'];
        subviews.forEach(id => {
            const el = document.getElementById(id);
            if (el) el.style.display = 'none';
        });
        
        let targetId = 'securityOptionsView';
        if (view === 'change') targetId = 'changePasswordView';
        else if (view === 'forgot') targetId = 'forgotPasswordView';
        
        const target = document.getElementById(targetId);
        if (target) {
            target.style.display = 'block';
            $(target).hide().fadeIn(300);
        }
    }

    function toggleApplicationView(view) {
        const ctaView = document.getElementById('appCtaView');
        const formView = document.getElementById('appFormView');
        
        if (view === 'form') {
            if (ctaView) ctaView.style.display = 'none';
            if (formView) {
                formView.style.display = 'block';
                $(formView).hide().fadeIn(300);
            }
        } else {
            if (formView) formView.style.display = 'none';
            if (ctaView) {
                ctaView.style.display = 'block';
                $(ctaView).hide().fadeIn(300);
            }
        }
    }
</script>
