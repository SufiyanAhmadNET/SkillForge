@* client-side filter *@
<script>
    // wire up all three filters to same fn
    ['searchInput','catFilter','statusFilter'].forEach(id => {
        document.getElementById(id)?.addEventListener('input', filterCourses);
    });
    function filterCourses() {
        const search = document.getElementById('searchInput').value.toLowerCase();
        const cat    = document.getElementById('catFilter').value;
        const status = document.getElementById('statusFilter').value;
        document.querySelectorAll('.course-item').forEach(el => {
            const matchTitle  = el.dataset.title.includes(search);
            const matchCat    = !cat    || el.dataset.category === cat;
            const matchStatus = !status || el.dataset.status   === status;
            el.style.display  = matchTitle && matchCat && matchStatus ? '' : 'none';
        });
    }
</script>