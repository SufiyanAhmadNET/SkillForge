
@using SkillForge.Areas.Instructor.Models
@model InstructorEarningsVM
@{
    ViewData["Title"] = "Earning";
    Layout = "~/Areas/Instructor/Views/Shared/InstructorLayout.cshtml";
}

<main class="p-4 flex-grow-1 inst-bg">

    <div class="d-flex align-items-center justify-content-between mb-4">
        <div class="page-title-bar">
            <h5 class="fw-bold mb-0">Earnings & Finance</h5>
            <p class="text-muted mb-0" style="font-size:14px;">Track your income across all courses.</p>
        </div>
        
        <!-- Reports Dropdown -->
        <div class="dropdown">
            <button class="btn btn-sm btn-outline-success dropdown-toggle px-3 rounded-pill fw-semibold" type="button" data-bs-toggle="dropdown">
                Download Report
            </button>
            <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0" style="font-size: 13px;">
                <li><a class="dropdown-item py-2" href="javascript:void(0)"><i class="bi bi-file-earmark-bar-graph me-2 text-success"></i>Course Wise Report</a></li>
                <li><a class="dropdown-item py-2" href="javascript:void(0)" data-bs-toggle="modal" data-bs-target="#monthlyReportModal"><i class="bi bi-calendar3 me-2 text-primary"></i>Monthly Report</a></li>
            </ul>
        </div>
    </div>

    <!-- EARNINGS STAT CARDS -->
    <div class="row g-3 mb-4">

        <div class="col-md-3">
            <div class="card border-0 stat-card h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background:var(--purple-soft);color:var(--purple);">
                        <i class="bi bi-cash-stack"></i>
                    </div>
                    <div>
                        <div class="stat-label">Total Earned</div>
                        <div class="stat-value">₹@Model.TotalEarned.ToString("N0")</div>
                        <small class="text-muted">Net Earnings (80%)</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 stat-card h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon bg-success bg-opacity-10 text-success">
                        <i class="bi bi-graph-up-arrow"></i>
                    </div>
                    <div>
                        <div class="stat-label">This Month</div>
                        <div class="stat-value">₹@Model.ThisMonthEarnings.ToString("N0")</div>
                        @if (Model.GrowthPercentage >= 0)
                        {
                            <small class="text-success">↑ @Model.GrowthPercentage% vs last month</small>
                        }
                        else
                        {
                            <small class="text-danger">↓ @Math.Abs(Model.GrowthPercentage)% vs last month</small>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 stat-card h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background:var(--purple-soft);color:var(--purple);">
                        <i class="bi bi-hourglass-split"></i>
                    </div>
                    <div>
                        <div class="stat-label">Pending Payout</div>
                        <div class="stat-value">₹@Model.PendingPayout.ToString("N0")</div>
                        <small class="text-muted">Current Month Processing</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 stat-card h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon bg-primary bg-opacity-10 text-primary">
                        <i class="bi bi-people-fill"></i>
                    </div>
                    <div>
                        <div class="stat-label">Paying Students</div>
                        <div class="stat-value">@Model.PayingStudents.ToString("N0")</div>
                        <small class="text-success">↑ @Model.NewStudentsThisWeek this week</small>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- EARNINGS PER COURSE -->
    <div class="card border-0 inst-card mb-4 shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
            <h6 class="mb-0 fw-bold small"><i class="bi bi-journal-bookmark me-2 text-purple"></i>Earnings by Course</h6>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-sm align-middle mb-0" style="font-size: 14px;">
                    <thead class="table-light text-muted" style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.03rem;">
                        <tr>
                            <th class="ps-3 py-3">Course</th>
                            <th>Avg Price</th>
                            <th>Students</th>
                            <th>Gross</th>
                            <th>Platform Fee (20%)</th>
                            <th class="pe-3">Your Earnings</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.CourseEarnings != null && Model.CourseEarnings.Any())
                        {
                            @foreach (var course in Model.CourseEarnings)
                            {
                                <tr>
                                    <td class="ps-3 fw-semibold text-dark">@course.CourseTitle</td>
                                    <td class="text-muted small">₹@course.PricePerStudent.ToString("N0")</td>
                                    <td>@course.EnrolledStudents</td>
                                    <td class="text-muted small">₹@course.GrossRevenue.ToString("N0")</td>
                                    <td class="text-muted small">₹@course.PlatformFee.ToString("N0")</td>
                                    <td class="pe-3 text-success fw-bold">₹@course.InstructorEarnings.ToString("N0")</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-4 text-muted small">No course earnings data found.</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light" style="font-size: 13px;">
                        <tr>
                            <td colspan="5" class="ps-3 fw-bold text-end py-2">Total Net Earnings</td>
                            <td class="pe-3 fw-bold text-success py-2">₹@Model.TotalEarned.ToString("N0")</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>


    <!-- MONTHLY BREAKDOWN -->
    <div class="card border-0 inst-card shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
            <h6 class="mb-0 fw-bold small"><i class="bi bi-calendar3 me-2 text-purple"></i>Monthly Breakdown</h6>
            
            <form id="filterForm" method="get" class="d-flex gap-2">
                <select name="month" class="form-select form-select-sm" style="max-width:110px; font-size: 12px;" onchange="this.form.submit()">
                    @for (int m = 1; m <= 12; m++)
                    {
                        var monthName = new DateTime(2000, m, 1).ToString("MMMM");
                        if (Model.SelectedMonth == m)
                        {
                            <option value="@m" selected>@monthName</option>
                        }
                        else
                        {
                            <option value="@m">@monthName</option>
                        }
                    }
                </select>
                <select name="year" class="form-select form-select-sm" style="max-width:90px; font-size: 12px;" onchange="this.form.submit()">
                    @foreach (var y in Model.AvailableYears)
                    {
                        if (Model.SelectedYear == y)
                        {
                            <option value="@y" selected>@y</option>
                        }
                        else
                        {
                            <option value="@y">@y</option>
                        }
                    }
                </select>
            </form>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-sm align-middle mb-0" style="font-size: 14px;">
                    <thead class="table-light text-muted" style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.03rem;">
                        <tr>
                            <th class="ps-3 py-3">Month Period</th>
                            <th>New Students</th>
                            <th>Gross Sales</th>
                            <th>Your Share</th>
                            <th class="pe-3">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.MonthlyBreakdown != null && Model.MonthlyBreakdown.Any())
                        {
                            @foreach (var month in Model.MonthlyBreakdown)
                            {
                                <tr>
                                    <td class="ps-3 fw-medium text-dark">@month.MonthName</td>
                                    <td class="text-muted">@month.NewStudents</td>
                                    <td class="text-muted small">₹@month.GrossRevenue.ToString("N0")</td>
                                    <td class="text-success fw-semibold">₹@month.InstructorEarnings.ToString("N0")</td>
                                    <td class="pe-3">
                                        @{
                                            var statusClass = month.PayoutStatus == "Paid" ? "bg-success-subtle text-success border-success-subtle" : "bg-warning-subtle text-warning-emphasis border-warning-subtle";
                                        }
                                        <span class="badge rounded-pill @statusClass border px-2" style="font-size: 11px;">@month.PayoutStatus</span>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-4 text-muted small">No historical breakdown available for this period.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</main>

<!-- Monthly Report Modal -->
<div class="modal fade" id="monthlyReportModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-bottom-0 pb-0">
                <h6 class="modal-title fw-bold">Select Period</h6>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" aria-label="Close" style="font-size: 10px;"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label small fw-bold">Year</label>
                    <select class="form-select form-select-sm" id="reportYear">
                        @foreach (var y in Model.AvailableYears)
                        {
                            <option value="@y">@y</option>
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label small fw-bold">Month</label>
                    <select class="form-select form-select-sm" id="reportMonth">
                        @for (int m = 1; m <= 12; m++)
                        {
                            var monthName = new DateTime(2000, m, 1).ToString("MMMM");
                            if (DateTime.UtcNow.Month == m)
                            {
                                <option value="@m" selected>@monthName</option>
                            }
                            else
                            {
                                <option value="@m">@monthName</option>
                            }
                        }
                    </select>
                </div>
                <button class="btn btn-purple btn-sm w-100 rounded-pill fw-bold py-2 shadow-sm" onclick="bootstrap.Modal.getInstance(document.getElementById('monthlyReportModal')).hide()">
                    Generate Report
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    .btn-purple { background: var(--purple); color: #fff; border: none; }
    .btn-purple:hover { background: var(--purple-dark); color: #fff; }
    .text-purple { color: var(--purple) !important; }
</style>