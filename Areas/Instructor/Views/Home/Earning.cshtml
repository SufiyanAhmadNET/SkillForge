
@{
    ViewData["Title"] = "Earning";
    Layout = "~/Areas/Instructor/Views/Shared/InstructorLayout.cshtml";
}

<body>
<main class="p-4 flex-grow-1 inst-bg">

    <div class="d-flex align-items-center justify-content-between mb-4">
        <div class="page-title-bar">
            <h5 class="fw-bold mb-0">Earnings & Finance</h5>
            <p class="text-muted mb-0" style="font-size:14px;">Track your income across all courses.</p>
        </div>
        <!-- download full report — wired to controller later via ClosedXML -->
        <button class="btn btn-sm btn-outline-success">
            <i class="bi bi-download me-1"></i>Download Full Report
        </button>
    </div>

    <!-- EARNINGS STAT CARDS -->
    <div class="row g-3 mb-4">

        <div class="col-md-3">
            <div class="card border-0 stat-card">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background:var(--orange-soft);color:var(--orange);">
                        <i class="bi bi-cash-stack"></i>
                    </div>
                    <div>
                        <div class="stat-label">Total Earned</div>
                        <div class="stat-value">₹1,80,000</div>
                        <small class="text-success">All time</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 stat-card">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon bg-success bg-opacity-10 text-success">
                        <i class="bi bi-graph-up-arrow"></i>
                    </div>
                    <div>
                        <div class="stat-label">This Month</div>
                        <div class="stat-value">₹18,000</div>
                        <small class="text-success">↑ 8% vs last month</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 stat-card">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background:var(--purple-soft);color:var(--purple);">
                        <i class="bi bi-hourglass-split"></i>
                    </div>
                    <div>
                        <div class="stat-label">Pending Payout</div>
                        <div class="stat-value">₹4,500</div>
                        <small class="text-muted">Next: Mar 31</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 stat-card">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon bg-primary bg-opacity-10 text-primary">
                        <i class="bi bi-people-fill"></i>
                    </div>
                    <div>
                        <div class="stat-label">Paying Students</div>
                        <div class="stat-value">1,240</div>
                        <small class="text-success">↑ 18 this week</small>
                    </div>
                </div>
            </div>
        </div>

    </div>
    <!-- /STAT CARDS -->
    <!-- EARNINGS PER COURSE -->
    <div class="card border-0 inst-card mb-4">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <h6 class="mb-0 fw-bold"><i class="bi bi-journal-bookmark me-2" style="color:var(--purple);"></i>Earnings by Course</h6>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Course</th>
                        <th>Price/Student</th>
                        <th>Students</th>
                        <th>Gross</th>
                        <th>Platform Fee (20%)</th>
                        <th>Your Earnings</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="fw-semibold">Full Stack Web Development</td>
                        <td>₹1,500</td>
                        <td>840</td>
                        <td>₹12,60,000</td>
                        <td class="text-muted">₹2,52,000</td>
                        <td class="text-success fw-bold">₹1,26,000</td>
                    </tr>
                    <tr>
                        <td class="fw-semibold">React & Node.js Bootcamp</td>
                        <td>₹1,000</td>
                        <td>280</td>
                        <td>₹2,80,000</td>
                        <td class="text-muted">₹56,000</td>
                        <td class="text-success fw-bold">₹42,000</td>
                    </tr>
                    <tr>
                        <td class="fw-semibold">DSA with JavaScript</td>
                        <td>₹800</td>
                        <td>120</td>
                        <td>₹96,000</td>
                        <td class="text-muted">₹19,200</td>
                        <td class="text-success fw-bold">₹12,000</td>
                    </tr>
                </tbody>
                <!-- total row -->
                <tfoot class="table-light">
                    <tr>
                        <td colspan="5" class="fw-bold text-end">Total Earnings</td>
                        <td class="fw-bold text-success">₹1,80,000</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>


    <!-- MONTHLY BREAKDOWN -->
    <div class="card border-0 inst-card">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <h6 class="mb-0 fw-bold"><i class="bi bi-calendar3 me-2" style="color:var(--purple);"></i>Monthly Breakdown</h6>
            <!-- date filter — wired to controller later -->
            <select class="form-select form-select-sm" style="max-width:140px;">
                <option>2026</option>
                <option>2025</option>
            </select>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr><th>Month</th><th>New Students</th><th>Gross</th><th>Your Earnings</th><th>Status</th></tr>
                </thead>
                <tbody>
                    <tr>
                        <td>March 2026</td>
                        <td>42</td>
                        <td>₹54,600</td>
                        <td class="text-success fw-semibold">₹18,000</td>
                        <td><span class="badge bg-warning text-dark">Pending</span></td>
                    </tr>
                    <tr>
                        <td>February 2026</td>
                        <td>58</td>
                        <td>₹67,400</td>
                        <td class="text-success fw-semibold">₹16,700</td>
                        <td><span class="badge bg-success">Paid</span></td>
                    </tr>
                    <tr>
                        <td>January 2026</td>
                        <td>65</td>
                        <td>₹75,200</td>
                        <td class="text-success fw-semibold">₹15,300</td>
                        <td><span class="badge bg-success">Paid</span></td>
                    </tr>
                    <tr>
                        <td>December 2025</td>
                        <td>48</td>
                        <td>₹57,600</td>
                        <td class="text-success fw-semibold">₹12,800</td>
                        <td><span class="badge bg-success">Paid</span></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

</main>

</div>
</div>

</body>