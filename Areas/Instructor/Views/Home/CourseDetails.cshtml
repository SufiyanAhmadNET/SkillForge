@model SkillForge.Models.CourseDetailsVM

@{
    ViewData["Title"] = "Course Details";
    Layout = "~/Areas/Instructor/Views/Shared/InstructorLayout.cshtml";
}
<main class="p-4 flex-grow-1 inst-bg">
    @* top bar *@
    <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
        <a asp-action="MyCourses" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>My Courses
        </a>
        @* navigation and course actions *@
        <div class="d-flex gap-2 flex-wrap">
            <a asp-action="EditCourse" asp-route-id="@Model.CourseId" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-pencil me-1"></i>Edit
            </a>
            @* preview as student with flag *@
            <a asp-action="CourseDetails" asp-area="User" asp-controller="Home" asp-route-id="@Model.CourseId" asp-route-preview="true" target="_blank" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-eye me-1"></i>Preview
            </a>
            @* submit for review *@
            <form asp-action="SubmitForReview" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.CourseId" />
                <button type="submit" class="btn btn-sm fw-semibold px-3"
                        style="background:var(--orange);color:#fff;border:none;">
                    <i class="bi bi-send me-1"></i>Submit for Review
                </button>
            </form>
        </div>
    </div>

    <div class="row g-3">
        @* LEFT: course info card *@
        <div class="col-lg-4">
            <div class="card border-0 inst-card mb-3">
                <div class="card-body">
                    <!-- Course thumbnail -->
                    <img src="@(string.IsNullOrEmpty(Model.ThumbnailUrl) ? "/img/course-placeholder.jpg" : Model.ThumbnailUrl)" 
                         class="w-100 rounded-3 mb-3" style="height:150px; object-fit:cover;">

                    <h6 class="fw-bold mb-1">@Model.Title</h6>

                    <!-- Status badge -->
                    <span class="badge @(Model.Status == "Published" ? "bg-success" : Model.Status == "PendingReview" ? "bg-warning" : "bg-secondary") mb-3">
                        @Model.Status
                    </span>

                    <!-- Course metadata -->
                    <div class="d-flex flex-column gap-2" style="font-size:13px;">
                        <div class="d-flex justify-content-between">
                            <span class="text-muted">Category</span>
                            <span class="fw-semibold">@(Model.CategoryName ?? "Uncategorized")</span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="text-muted">Level</span>
                            <span class="fw-semibold">@(Model.Difficulty ?? "None")</span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="text-muted">Duration</span>
                            <span class="fw-semibold">@Model.Duration weeks</span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="text-muted">Actual Price</span>
                            <span class="fw-semibold text-decoration-line-through text-muted">₹@Model.ActualPrice</span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="text-muted">Discount</span>
                            <span class="fw-semibold text-success">@Model.DiscountPercent% OFF</span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="text-muted">Selling Price</span>
                            <span class="fw-bold fs-5" style="color:var(--orange);">₹@Model.TotalPrice</span>
                        </div>
                    </div>
                </div>
            </div>

            @* Mini stats — real data *@
            <div class="row g-2">
                <div class="col-6">
                    <div class="card border-0 inst-card text-center py-3">
                        <div class="fw-bold fs-5" style="color:var(--orange);">@Model.EnrolledStudents.Count</div>
                        <small class="text-muted">Students</small>
                    </div>
                </div>
                <div class="col-6">
                    <div class="card border-0 inst-card text-center py-3">
                        <div class="fw-bold fs-5" style="color:var(--orange);">4.8 ★</div>
                        <small class="text-muted">Rating</small>
                    </div>
                </div>
                <div class="col-12">
                    <div class="card border-0 inst-card text-center py-3">
                        <div class="fw-bold fs-5 text-success">₹@Model.TotalPrice</div>
                        <small class="text-muted">Total Price</small>
                    </div>
                </div>
            </div>
        </div>
        @* RIGHT: tabs *@
        <div class="col-lg-8">
            <div class="card border-0 inst-card">
                @* tab nav *@
                <div class="card-header bg-white border-bottom">
                    <ul class="nav nav-tabs card-header-tabs" id="courseTabs">
                        <li class="nav-item">
                            <a class="nav-link active" data-bs-toggle="tab" href="#tabOverview">
                                Overview
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-bs-toggle="tab" href="#tabContent">
                                Content
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-bs-toggle="tab" href="#tabStudents">
                                Students
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-muted">
                                Analytics <span class="badge bg-light text-muted border ms-1" style="font-size:10px;">Soon</span>
                            </a>
                        </li>
                    </ul>
                </div>
                <div class="tab-content card-body">
                    @* OVERVIEW tab — real course info *@
                    <div class="tab-pane fade show active" id="tabOverview">
                        <h6 class="fw-semibold mb-2">About this Course</h6>
                        <p class="text-muted" style="font-size:14px;">@Model.Desciption</p>
                        <h6 class="fw-semibold mt-3 mb-2">What Students Will Learn</h6>
                        <ul class="text-muted ps-3" style="font-size:14px;">
                            @if (Model.outcomes != null)
                            {
                                @foreach (var outcome in Model.outcomes)
                                {
                                    <li class="mb-1">@outcome.Outcome</li>
                                }
                            }
                        </ul>
                        <h6 class="fw-semibold mt-3 mb-2">Intro Video</h6>
                        @if (!string.IsNullOrEmpty(Model.VideoUrl))
                        {
                            <a href="@Model.VideoUrl" target="_blank"
                               class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-play-circle me-1 text-danger"></i>Watch Intro Video
                            </a>
                        }
                        else
                        {
                            <span class="text-muted small">No video uploaded.</span>
                        }
                    </div>

                    @* CONTENT tab — dynamic module management *@
                    <div class="tab-pane fade" id="tabContent">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h6 class="fw-bold mb-0">Course Content / Syllabus</h6>
                            <button class="btn btn-sm" style="background:var(--orange);color:#fff;" data-bs-toggle="modal" data-bs-target="#addModuleModal">
                                <i class="bi bi-plus-lg me-1"></i>Add Module
                            </button>
                        </div>

                        <div class="accordion accordion-flush" id="syllabusAccordion">
                            @if (Model.modules != null && Model.modules.Any())
                            {
                                @for (int i = 0; i < Model.modules.Count; i++)
                                {
                                    var module = Model.modules[i];
                                    <div class="accordion-item border mb-3 rounded shadow-sm overflow-hidden">
                                        <h2 class="accordion-header">
                                            <div class="accordion-button d-flex justify-content-between align-items-center py-3 bg-light shadow-none">
                                                <div class="flex-grow-1 fw-bold text-dark" style="cursor:pointer;" data-bs-toggle="collapse" data-bs-target="#module-@module.Id">
                                                    <i class="bi bi-grid-3x3-gap me-2 text-muted"></i>Module @(i + 1): @module.ModuleName
                                                </div>
                                                <div class="d-flex gap-2 pe-3" style="z-index: 5;">
                                                    <button class="btn btn-sm btn-outline-primary py-1 px-2" style="font-size:11px;"
                                                            data-bs-toggle="modal" data-bs-target="#addLessonModal" data-module-id="@module.Id">
                                                        <i class="bi bi-plus"></i> Add Lesson
                                                    </button>
                                                    <form asp-action="DeleteModule" method="post" class="d-inline" onsubmit="return confirm('Delete this module and all its lessons?')">
                                                        <input type="hidden" name="moduleId" value="@module.Id" />
                                                        <input type="hidden" name="courseId" value="@Model.CourseId" />
                                                        <button type="submit" class="btn btn-sm btn-outline-danger py-1 px-2" style="font-size:11px;">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </div>
                                        </h2>
                                        <div id="module-@module.Id" class="accordion-collapse collapse show">
                                            <div class="accordion-body p-0 bg-white">
                                                <div class="list-group list-group-flush">
                                                    @foreach (var lesson in module.Lessons)
                                                    {
                                                        <div class="list-group-item d-flex justify-content-between align-items-center py-2 border-0 border-bottom ps-4">
                                                            <div class="d-flex align-items-center gap-2 min-w-0">
                                                                <i class="bi bi-play-circle text-muted flex-shrink-0"></i>
                                                                <div class="small fw-medium text-dark text-truncate">@lesson.Title</div>
                                                                <div class="text-muted text-truncate d-none d-sm-block" style="font-size: 10px; max-width: 200px;">(@lesson.VideoUrl)</div>
                                                            </div>
                                                            <form asp-action="DeleteLesson" method="post" onsubmit="return confirm('Delete this lesson?')">
                                                                <input type="hidden" name="lessonId" value="@lesson.Id" />
                                                                <input type="hidden" name="courseId" value="@Model.CourseId" />
                                                                <button type="submit" class="btn btn-link text-danger p-0 border-0 shadow-none">
                                                                    <i class="bi bi-x-circle"></i>
                                                                </button>
                                                            </form>
                                                        </div>
                                                    }
                                                    @if (!module.Lessons.Any())
                                                    {
                                                        <div class="p-3 text-center text-muted small">No lessons in this module.</div>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="text-center py-5 border rounded bg-light">
                                    <i class="bi bi-journal-text display-4 text-muted mb-3 d-block opacity-50"></i>
                                    <p class="text-muted small mb-0">No modules added yet. Start by adding your first module.</p>
                                </div>
                            }
                        </div>
                    </div>

                    @* STUDENTS tab — dynamic enrollment list *@
                    <div class="tab-pane fade" id="tabStudents">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="fw-semibold mb-0">Enrolled Students (@Model.EnrolledStudents.Count)</h6>
                            <button class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-download me-1"></i>Export List
                            </button>
                        </div>
                        <table class="table table-hover" style="font-size:13px;">
                            <thead class="table-light">
                                <tr>
                                    <th>#</th>
                                    <th>Student</th>
                                    <th>Email</th>
                                    <th>Enrolled</th>
                                    <th>Progress</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{ int studentCount = 1; }
                                @foreach (var student in Model.EnrolledStudents)
                                {
                                    <tr>
                                        <td class="text-muted">@studentCount</td>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold"
                                                     style="width:28px;height:28px;font-size:12px;background:var(--orange-soft);color:var(--orange);">
                                                    @student.Initial
                                                </div>
                                                @student.Name
                                            </div>
                                        </td>
                                        <td class="text-muted">@student.Email</td>
                                        <td class="text-muted">@student.EnrolledAt</td>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="progress flex-grow-1" style="height:5px; min-width:60px;">
                                                    <div class="progress-bar bg-success" style="width:@student.Progress%"></div>
                                                </div>
                                                <small class="text-muted">@student.Progress%</small>
                                            </div>
                                        </td>
                                    </tr>
                                    studentCount++;
                                }
                            </tbody>
                        </table>
                        @if (!Model.EnrolledStudents.Any())
                        {
                            <div class="text-center py-5">
                                <p class="text-muted mb-0">No students enrolled in this course yet.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<!-- Add Module Modal -->
<div class="modal fade" id="addModuleModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold">Add New Module</h5>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="AddModule" method="post">
                <div class="modal-body">
                    <input type="hidden" name="courseId" value="@Model.CourseId" />
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Module Name</label>
                        <input type="text" name="moduleName" class="form-control shadow-none" placeholder="e.g. Introduction to ASP.NET" required>
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0">
                    <button type="button" class="btn btn-sm btn-light px-3" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-sm px-3" style="background:var(--orange);color:#fff;">Create Module</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Add Lesson Modal -->
<div class="modal fade" id="addLessonModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold">Add New Lesson</h5>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="AddLesson" method="post">
                <div class="modal-body">
                    <input type="hidden" name="courseId" value="@Model.CourseId" />
                    <input type="hidden" name="moduleId" id="lessonModuleId" />
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Lesson Title</label>
                        <input type="text" name="title" class="form-control shadow-none" placeholder="e.g. Getting Started" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">YouTube Video URL</label>
                        <input type="url" name="videoUrl" class="form-control shadow-none" placeholder="https://www.youtube.com/watch?v=..." required>
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0">
                    <button type="button" class="btn btn-sm btn-light px-3" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-sm px-3" style="background:var(--orange);color:#fff;">Add Lesson</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    // Set module ID in lesson modal when opened
    const addLessonModal = document.getElementById('addLessonModal');
    if (addLessonModal) {
        addLessonModal.addEventListener('show.bs.modal', function (event) {
            const button = event.relatedTarget;
            const moduleId = button.getAttribute('data-module-id');
            document.getElementById('lessonModuleId').value = moduleId;
        });
    }
</script>
