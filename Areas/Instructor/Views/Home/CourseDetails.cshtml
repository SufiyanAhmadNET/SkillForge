@model SkillForge.Models.CourseDetailsVM

@{
    ViewData["Title"] = "Course Details";
    Layout = "~/Areas/Instructor/Views/Shared/InstructorLayout.cshtml";
}
<main class="p-4 flex-grow-1 inst-bg">
    @* top bar *@
    <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
        <a asp-action="MyCourses" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>My Courses
        </a>
        <div class="d-flex gap-2 flex-wrap">
            <a asp-action="EditCourse" asp-route-id="@Model.CourseId" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-pencil me-1"></i>Edit
            </a>
            @* preview as student *@
            <a asp-action="Courses" asp-area="User" asp-controller="Home" asp-route-id="@Model.CourseId" target="_blank" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-eye me-1"></i>Preview
            </a>
            @* submit for review *@
            <form asp-action="SubmitForReview" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.CourseId" />
                <button type="submit" class="btn btn-sm fw-semibold px-3"
                        style="background:var(--orange);color:#fff;border:none;">
                    <i class="bi bi-send me-1"></i>Submit for Review
                </button>
            </form>
        </div>
    </div>

    <div class="row g-3">
        @* LEFT: course info card *@
        <div class="col-lg-4">
            <div class="card border-0 inst-card mb-3">
                <div class="card-body">
                    <!-- Course thumbnail -->
                    <img src="@(string.IsNullOrEmpty(Model.ThumbnailUrl) ? "/img/course-placeholder.jpg" : Model.ThumbnailUrl)" 
                         class="w-100 rounded-3 mb-3" style="height:150px; object-fit:cover;">

                    <h6 class="fw-bold mb-1">@Model.Title</h6>

                    <!-- Status badge -->
                    <span class="badge @(Model.Status == "Published" ? "bg-success" : Model.Status == "PendingReview" ? "bg-warning" : "bg-secondary") mb-3">
                        @Model.Status
                    </span>

                    <!-- Course metadata -->
                    <div class="d-flex flex-column gap-2" style="font-size:13px;">
                        <div class="d-flex justify-content-between">
                            <span class="text-muted">Category</span>
                            <span class="fw-semibold">@(Model.CategoryName ?? "Uncategorized")</span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="text-muted">Level</span>
                            <span class="fw-semibold">@(Model.Difficulty ?? "None")</span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="text-muted">Duration</span>
                            <span class="fw-semibold">@Model.Duration weeks</span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="text-muted">Price</span>
                            <span class="fw-bold" style="color:var(--orange);">₹@Model.TotalPrice</span>
                        </div>
                    </div>
                </div>
            </div>

            @* Mini stats *@
            <div class="row g-2">
                <div class="col-6">
                    <div class="card border-0 inst-card text-center py-3">
                        <div class="fw-bold fs-5" style="color:var(--orange);">0</div>
                        <small class="text-muted">Students</small>
                    </div>
                </div>
                <div class="col-6">
                    <div class="card border-0 inst-card text-center py-3">
                        <div class="fw-bold fs-5" style="color:var(--orange);">4.8 ★</div>
                        <small class="text-muted">Rating</small>
                    </div>
                </div>
                <div class="col-12">
                    <div class="card border-0 inst-card text-center py-3">
                        <div class="fw-bold fs-5 text-success">₹7,79,844</div>
                        <small class="text-muted">Total Earned</small>
                    </div>
                </div>
            </div>
        </div>
        @* RIGHT: tabs *@
        <div class="col-lg-8">
            <div class="card border-0 inst-card">
                @* tab nav *@
                <div class="card-header bg-white border-bottom">
                    <ul class="nav nav-tabs card-header-tabs" id="courseTabs">
                        <li class="nav-item">
                            <a class="nav-link active" data-bs-toggle="tab" href="#tabOverview">
                                Overview
                            </a>
                        </li>
                        <li class="nav-item">
                            @* content tab — locked until published *@
                            <a class="nav-link text-muted" data-bs-toggle="tab" href="#tabContent">
                                Content <span class="badge bg-light text-muted border ms-1" style="font-size:10px;">Soon</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-bs-toggle="tab" href="#tabStudents">
                                Students
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-muted">
                                Analytics <span class="badge bg-light text-muted border ms-1" style="font-size:10px;">Soon</span>
                            </a>
                        </li>
                    </ul>
                </div>
                <div class="tab-content card-body">
                    @* OVERVIEW tab - dummy data *@
                    <div class="tab-pane fade show active" id="tabOverview">
                        <h6 class="fw-semibold mb-2">About this Course</h6>
                        <p class="text-muted" style="font-size:14px;">Master full-stack development with React, Node.js, and MongoDB. Build real-world projects and become a job-ready developer.</p>
                        <h6 class="fw-semibold mt-3 mb-2">What Students Will Learn</h6>
                        <ul class="text-muted ps-3" style="font-size:14px;">
                            <li class="mb-1">Build complete web applications from scratch</li>
                            <li class="mb-1">Master React hooks and state management</li>
                            <li class="mb-1">Create RESTful APIs with Node.js and Express</li>
                            <li class="mb-1">Deploy applications to production</li>
                        </ul>
                        <h6 class="fw-semibold mt-3 mb-2">Intro Video</h6>
                        <a href="https://youtube.com/watch?v=dummy" target="_blank"
                           class="btn btn-sm btn-outline-secondary">
                            <i class="bi bi-play-circle me-1 text-danger"></i>Watch on YouTube
                        </a>
                    </div>
                    @* STUDENTS tab - dummy data *@
                    <div class="tab-pane fade" id="tabStudents">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="fw-semibold mb-0">Enrolled Students</h6>
                            <button class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-download me-1"></i>Export List
                            </button>
                        </div>
                        <table class="table table-hover" style="font-size:13px;">
                            <thead class="table-light">
                                <tr>
                                    <th>#</th>
                                    <th>Student</th>
                                    <th>Email</th>
                                    <th>Enrolled</th>
                                    <th>Progress</th>
                                </tr>
                            </thead>
                            <tbody>
                                @* dummy student 1 *@
                                <tr>
                                    <td class="text-muted">1</td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold"
                                                 style="width:28px;height:28px;font-size:12px;background:var(--orange-soft);color:var(--orange);">
                                                R
                                            </div>
                                            Rahul Sharma
                                        </div>
                                    </td>
                                    <td class="text-muted">rahul.sharma@example.com</td>
                                    <td class="text-muted">Jan 15, 2026</td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="progress flex-grow-1" style="height:5px; min-width:60px;">
                                                <div class="progress-bar bg-success" style="width:75%"></div>
                                            </div>
                                            <small class="text-muted">75%</small>
                                        </div>
                                    </td>
                                </tr>
                                @* dummy student 2 *@
                                <tr>
                                    <td class="text-muted">2</td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold"
                                                 style="width:28px;height:28px;font-size:12px;background:var(--orange-soft);color:var(--orange);">
                                                P
                                            </div>
                                            Priya Patel
                                        </div>
                                    </td>
                                    <td class="text-muted">priya.patel@example.com</td>
                                    <td class="text-muted">Jan 20, 2026</td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="progress flex-grow-1" style="height:5px; min-width:60px;">
                                                <div class="progress-bar bg-success" style="width:45%"></div>
                                            </div>
                                            <small class="text-muted">45%</small>
                                        </div>
                                    </td>
                                </tr>
                                @* dummy student 3 *@
                                <tr>
                                    <td class="text-muted">3</td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold"
                                                 style="width:28px;height:28px;font-size:12px;background:var(--orange-soft);color:var(--orange);">
                                                A
                                            </div>
                                            Amit Kumar
                                        </div>
                                    </td>
                                    <td class="text-muted">amit.kumar@example.com</td>
                                    <td class="text-muted">Feb 1, 2026</td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="progress flex-grow-1" style="height:5px; min-width:60px;">
                                                <div class="progress-bar bg-success" style="width:20%"></div>
                                            </div>
                                            <small class="text-muted">20%</small>
                                        </div>
                                    </td>
                                </tr>
                                @* dummy student 4 *@
                                <tr>
                                    <td class="text-muted">4</td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold"
                                                 style="width:28px;height:28px;font-size:12px;background:var(--orange-soft);color:var(--orange);">
                                                N
                                            </div>
                                            Neha Gupta
                                        </div>
                                    </td>
                                    <td class="text-muted">neha.gupta@example.com</td>
                                    <td class="text-muted">Feb 10, 2026</td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="progress flex-grow-1" style="height:5px; min-width:60px;">
                                                <div class="progress-bar bg-success" style="width:60%"></div>
                                            </div>
                                            <small class="text-muted">60%</small>
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>