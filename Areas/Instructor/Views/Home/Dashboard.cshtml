@model SkillForge.Areas.Instructor.Models.InstructorDashboardVM
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Areas/Instructor/Views/Shared/InstructorLayout.cshtml";
}

<main class="p-4 flex-grow-1 inst-bg">

    <!-- Welcome -->
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div class="page-title-bar">
            <h5 class="fw-bold mb-0">Welcome back, @Model.FirstName 👋</h5>
            <p class="text-muted mb-0" style="font-size:14px;">Here's your teaching overview for today.</p>
        </div>
        @if (Model.ApplicationStatus == SkillForge.Services.Instructors.Models.MentorApplicationStatus.Approved)
        {
            <a asp-area="Instructor" asp-controller="Home" asp-action="AddCourse" class="btn btn-sm fw-semibold" style="background:var(--orange);color:#fff;border:none;">
                <i class="bi bi-plus-circle me-1"></i>Add New Course
            </a>
        }
    </div>

    @if (Model.ApplicationStatus != SkillForge.Services.Instructors.Models.MentorApplicationStatus.Approved)
    {
        <div class="card border-0 shadow-sm mb-4" style="border-radius:15px; overflow:hidden;">
            <div class="card-body p-0">
                <div class="row g-0">
                    <div class="col-md-8 p-4 p-lg-5">
                        <div class="badge bg-purple bg-opacity-10 text-purple mb-3 px-3 py-2 rounded-pill fw-bold" style="font-size: 11px;">
                            <i class="bi bi-stars me-1"></i> INSTRUCTOR ONBOARDING
                        </div>
                        <h2 class="fw-bold mb-3">Become a Verified Mentor</h2>
                        <p class="text-muted mb-4 fs-5" style="max-width: 600px;">
                            Creating courses that matter starts with a verified identity. 
                            Apply now to unlock course creation, student management, and professional teaching tools.
                        </p>

                        @if (Model.ApplicationStatus == SkillForge.Services.Instructors.Models.MentorApplicationStatus.NotApplied)
                        {
                            <div class="d-flex gap-3">
                                <a asp-action="Profile" asp-route-tab="application" class="btn btn-purple px-4 py-2 rounded-pill shadow-sm fw-bold">
                                    Apply as Mentor
                                </a>
                                <a asp-action="Profile" class="btn btn-outline-secondary px-4 py-2 rounded-pill fw-bold">
                                    Complete Profile
                                </a>
                            </div>
                        }
                        else if (Model.ApplicationStatus == SkillForge.Services.Instructors.Models.MentorApplicationStatus.Pending)
                        {
                            <div class="alert alert-primary border-0 bg-primary bg-opacity-10 d-flex align-items-center gap-3 p-3" style="border-radius: 12px; max-width: 500px;">
                                <i class="bi bi-clock-history fs-3"></i>
                                <div>
                                    <div class="fw-bold">Application Under Review</div>
                                    <div class="small opacity-75">Our team is reviewing your professional details. We'll notify you soon.</div>
                                </div>
                            </div>
                        }
                        else if (Model.ApplicationStatus == SkillForge.Services.Instructors.Models.MentorApplicationStatus.Rejected)
                        {
                            <div class="alert alert-danger border-0 bg-danger bg-opacity-10 d-flex align-items-center gap-3 p-3" style="border-radius: 12px; max-width: 500px;">
                                <i class="bi bi-exclamation-octagon fs-3"></i>
                                <div>
                                    <div class="fw-bold">Application Rejected</div>
                                    <div class="small opacity-75">Please check your profile for feedback and reapply.</div>
                                </div>
                            </div>
                            <a asp-action="Profile" asp-route-tab="application" class="btn btn-danger px-4 py-2 mt-3 rounded-pill shadow-sm fw-bold">
                                View Feedback & Reapply
                            </a>
                        }
                    </div>
                    <div class="col-md-4 d-none d-md-flex align-items-center justify-content-center bg-purple bg-opacity-10">
                        <i class="bi bi-mortarboard-fill text-purple" style="font-size: 10rem; opacity: 0.2;"></i>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (Model.ApplicationStatus == SkillForge.Services.Instructors.Models.MentorApplicationStatus.Approved)
    {
        <!-- STAT CARDS -->
        <div class="row g-3 mb-4">
            @* ... existing stat cards ... *@

        <div class="col-md-3">
            <div class="card border-0 stat-card">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background:var(--purple-soft);color:var(--purple);">
                        <i class="bi bi-journal-bookmark-fill"></i>
                    </div>
                    <div>
                        <div class="stat-label">My Courses</div>
                        <div class="stat-value">@Model.TotalCourses</div>
                        <small class="text-muted">Total uploaded</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 stat-card">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon bg-success bg-opacity-10 text-success">
                        <i class="bi bi-people-fill"></i>
                    </div>
                    <div>
                        <div class="stat-label">Total Students</div>
                        <div class="stat-value">@Model.TotalStudents</div>
                        <small class="text-success">Active enrollments</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 stat-card">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background:var(--orange-soft);color:var(--orange);">
                        <i class="bi bi-cash-stack"></i>
                    </div>
                    <div>
                        <div class="stat-label">Total Earnings</div>
                        <div class="stat-value">₹@(Model.TotalEarnings >= 1000 ? (Model.TotalEarnings / 1000).ToString("0.##") + "K" : Model.TotalEarnings.ToString())</div>
                        <small class="text-success">Lifetime revenue</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 stat-card">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon bg-warning bg-opacity-10 text-warning">
                        <i class="bi bi-star-fill"></i>
                    </div>
                    <div>
                        <div class="stat-label">Avg Rating</div>
                        <div class="stat-value">@Model.AvgRating</div>
                        <small class="text-muted">across all courses</small>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- MY COURSES + RECENT ENROLLMENTS -->
    <div class="row g-3">

        <!-- My active courses quick view -->
        <div class="col-lg-7">
            <div class="card border-0 inst-card h-100">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-journal-bookmark me-2" style="color:var(--purple);"></i>My Courses</h6>
                    <a asp-action="MyCourses" class="small" style="color:var(--orange);">View All →</a>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr><th>Course</th><th>Students</th><th>Rating</th><th>Status</th><th></th></tr>
                        </thead>
                        <tbody>
                            @foreach (var course in Model.ActiveCourses)
                            {
                                <tr>
                                    <td class="fw-semibold" style="font-size:13px;">@course.Title</td>
                                    <td>@course.StudentCount</td>
                                    <td><i class="bi bi-star-fill text-warning" style="font-size:11px;"></i> @course.Rating</td>
                                    <td><span class="badge @(course.Status == "Published" ? "bg-success" : "bg-secondary")">@course.Status</span></td>
                                    <td><a asp-action="CourseDetails" asp-route-id="@course.CourseId" class="btn btn-sm btn-outline-secondary">Manage</a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Recent enrollments -->
        <div class="col-lg-5">
            <div class="card border-0 inst-card h-100">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-person-plus me-2 text-success"></i>Recent Enrollments</h6>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr><th>Student</th><th>Course</th><th>Date</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var enr in Model.RecentEnrollments)
                            {
                                <tr>
                                    <td><div class="d-flex align-items-center gap-2"><div class="tbl-avatar" style="background:var(--orange-soft);color:var(--orange);">@enr.Initial</div>@enr.StudentName</div></td>
                                    <td class="text-muted small">@enr.CourseTitle</td>
                                    <td class="text-muted small">@enr.EnrolledDate</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>
    }

</main>
