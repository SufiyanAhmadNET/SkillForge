@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Areas/Instructor/Views/Shared/InstructorLayout.cshtml";
}


<body>
<main class="p-4 flex-grow-1 inst-bg">

    <!-- Welcome -->
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div class="page-title-bar">
            <h5 class="fw-bold mb-0">Welcome back, Suresh 👋</h5>
            <p class="text-muted mb-0" style="font-size:14px;">Here's your teaching overview for today.</p>
        </div>
        <!-- orange — brand tie-in, same as admin -->
        <a asp-area="Instructor" asp-controller="Home" asp-action="AddCourse" class="btn btn-sm fw-semibold" style="background:var(--orange);color:#fff;border:none;">
            <i class="bi bi-plus-circle me-1"></i>Add New Course
        </a>
    </div>

    <!-- STAT CARDS -->
    <div class="row g-3 mb-4">

        <div class="col-md-3">
            <div class="card border-0 stat-card">
                <div class="card-body d-flex align-items-center gap-3">
                    <!-- purple stat — instructor identity -->
                    <div class="stat-icon" style="background:var(--purple-soft);color:var(--purple);">
                        <i class="bi bi-journal-bookmark-fill"></i>
                    </div>
                    <div>
                        <div class="stat-label">My Courses</div>
                        <div class="stat-value">3</div>
                        <small class="text-muted">2 active</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 stat-card">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon bg-success bg-opacity-10 text-success">
                        <i class="bi bi-people-fill"></i>
                    </div>
                    <div>
                        <div class="stat-label">Total Students</div>
                        <div class="stat-value">1,240</div>
                        <small class="text-success">↑ 18 this week</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 stat-card">
                <div class="card-body d-flex align-items-center gap-3">
                    <!-- orange — brand tie-in -->
                    <div class="stat-icon" style="background:var(--orange-soft);color:var(--orange);">
                        <i class="bi bi-cash-stack"></i>
                    </div>
                    <div>
                        <div class="stat-label">Total Earnings</div>
                        <div class="stat-value">₹1.8L</div>
                        <small class="text-success">↑ 8% this month</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 stat-card">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon bg-warning bg-opacity-10 text-warning">
                        <i class="bi bi-star-fill"></i>
                    </div>
                    <div>
                        <div class="stat-label">Avg Rating</div>
                        <div class="stat-value">4.8</div>
                        <small class="text-muted">across all courses</small>
                    </div>
                </div>
            </div>
        </div>

    </div>
    <!-- /STAT CARDS -->
    <!-- MY COURSES + RECENT ENROLLMENTS -->
    <div class="row g-3">

        <!-- My active courses quick view -->
        <div class="col-lg-7">
            <div class="card border-0 inst-card h-100">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-journal-bookmark me-2" style="color:var(--purple);"></i>My Courses</h6>
                    <a href="instructor-courses.html" class="small" style="color:var(--orange);">View All →</a>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr><th>Course</th><th>Students</th><th>Rating</th><th>Status</th><th></th></tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="fw-semibold" style="font-size:13px;">Full Stack Web Dev</td>
                                <td>840</td>
                                <td><i class="bi bi-star-fill text-warning" style="font-size:11px;"></i> 4.9</td>
                                <td><span class="badge bg-success">Active</span></td>
                                <td><a asp-area="Instructor" asp-controller="Home" asp-action="EditCourses" class="btn btn-sm btn-outline-secondary">Manage</a></td>
                            </tr>
                            <tr>
                                <td class="fw-semibold" style="font-size:13px;">React & Node.js Bootcamp</td>
                                <td>280</td>
                                <td><i class="bi bi-star-fill text-warning" style="font-size:11px;"></i> 4.7</td>
                                <td><span class="badge bg-success">Active</span></td>
                                <td><a href="instructor-course-detail.html" class="btn btn-sm btn-outline-secondary">Manage</a></td>
                            </tr>
                            <tr>
                                <td class="fw-semibold" style="font-size:13px;">DSA with JavaScript</td>
                                <td>120</td>
                                <td><i class="bi bi-star-fill text-warning" style="font-size:11px;"></i> 4.6</td>
                                <td><span class="badge bg-secondary">Completed</span></td>
                                <td><a href="instructor-course-detail.html" class="btn btn-sm btn-outline-secondary">View</a></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Recent enrollments -->
        <div class="col-lg-5">
            <div class="card border-0 inst-card h-100">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-person-plus me-2 text-success"></i>Recent Enrollments</h6>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr><th>Student</th><th>Course</th><th>Date</th></tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><div class="d-flex align-items-center gap-2"><div class="tbl-avatar" style="background:var(--orange-soft);color:var(--orange);">A</div>Aarav S.</div></td>
                                <td class="text-muted small">Full Stack</td>
                                <td class="text-muted small">Today</td>
                            </tr>
                            <tr>
                                <td><div class="d-flex align-items-center gap-2"><div class="tbl-avatar bg-primary bg-opacity-10 text-primary">P</div>Priya P.</div></td>
                                <td class="text-muted small">React</td>
                                <td class="text-muted small">Yesterday</td>
                            </tr>
                            <tr>
                                <td><div class="d-flex align-items-center gap-2"><div class="tbl-avatar bg-success bg-opacity-10 text-success">M</div>Meera I.</div></td>
                                <td class="text-muted small">Full Stack</td>
                                <td class="text-muted small">Mar 11</td>
                            </tr>
                            <tr>
                                <td><div class="d-flex align-items-center gap-2"><div class="tbl-avatar bg-secondary bg-opacity-10 text-secondary">R</div>Rohan K.</div></td>
                                <td class="text-muted small">DSA</td>
                                <td class="text-muted small">Mar 10</td>
                            </tr>
                            <tr>
                                <td><div class="d-flex align-items-center gap-2"><div class="tbl-avatar bg-warning bg-opacity-10 text-warning">D</div>Dev P.</div></td>
                                <td class="text-muted small">React</td>
                                <td class="text-muted small">Mar 10</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>

</main>

</div>
</div>

</body>

