@model SkillForge.Models.CourseCardVM

<div class="c-card">
    <div class="c-thumb">
        <img src="@(Model.Thumbnail_Url ?? "https://via.placeholder.com/300")" alt="@Model.Title">
        <span class="diff-tag">@Model.Difficulty</span>

        @* heart — white circle, red border, fills red on click *@
        <button type="button" class="wish-btn @(Model.IsWishListed == true ? "wishlisted" : "")" 
                data-course-id="@Model.courseId"
                title="@(Model.IsWishListed == true ? "Remove from wishlist" : "Add to wishlist")">
            <i class="bi @(Model.IsWishListed == true ? "bi-heart-fill" : "bi-heart")"></i>
        </button>
    </div>

    <div class="c-body">
        <div class="c-cat">@Model.CategoryName</div>
        <div class="c-title">@Model.Title</div>
        <div class="c-sub">@Model.ShortSummary</div>

        <div class="c-price-row">
            <div>
                <span class="c-price">₹@Model.Total_Price</span>
                <span class="c-original">₹@Model.Actual_Price</span>
            </div>
            <span class="c-off">@Model.Discount_Percent% OFF</span>
        </div>

        @* Check if user is authenticated for proper redirection *@
        @{
            string detailsUrl = User.Identity.IsAuthenticated 
                ? $"/User/Home/CourseDetails?id={Model.courseId}" 
                : $"/Pubic/Home/CoursesDetails?id={Model.courseId}";
        }
        <a href="@detailsUrl" class="c-btn d-block text-center text-decoration-none">
            Check 
        </a>
    </div>
</div>
