<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SkillForge – Learn Skills That Matter</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Outfit:wght@600;700;800&display=swap" rel="stylesheet">
    <link href="~/css/Index.css" rel="stylesheet">
    <link href="~/css/alert.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>


</head>

<body>


    <!-- ── MOBILE HEADER ── -->

    <header class="sf-home-header">

        <div class="sf-logo">
            <i class="bi bi-mortarboard-fill"></i> SkillForge
        </div>

        <div class="sf-menu-icon" onclick="openMenu()">☰</div>

    </header>


    <!-- ── MOBILE Sidebar── -->

    <div id="sfMobileMenu" class="sf-mobile-menu">

        <div class="sf-close" onclick="closeMenu()">✕</div>

        <a href="/">Home</a>
        <a href="/Pubic/Home/Courses">Courses</a>
        <a href="/About">About</a>
        <a href="/Contact">Contact</a>

        <a href="/Auth/Login">Sign In</a>
        <a href="/Auth/Register">Sign Up</a>

    </div>


    <!-- ========================
         NAVBAR
    ======================== -->
    <nav class="navbar navbar-expand-lg bg-white border-bottom sticky-top">
        <div class="container-fluid px-5">

            <!-- Brand -->
            <a class="navbar-brand d-flex align-items-center" href="/">
                <i class="bi bi-mortarboard-fill me-3" style="color:var(--orange); font-size: 1.7rem;"></i>
                <span class="fs-4" style="font-weight: 700; letter-spacing: -0.4px;">SkillForge</span>
            </a>

            <!-- Right section: Links + Search + Auth -->
            <div class="ms-auto d-flex gap-3 align-items-center">
                
                <!-- Nav Links -->
                <div class="d-none d-lg-flex gap-4 me-2">
                    <a class="nav-link" href="/Pubic/Home/Courses">Courses</a>
                    <a class="nav-link" href="#">About</a>
                    <a class="nav-link" href="#">Contact</a>
                </div>

                <!-- Header Search -->
                <form asp-area="Pubic" asp-controller="Home" asp-action="Search" method="get" class="header-search d-none d-md-flex align-items-center px-2 py-1 border rounded-3 ms-2 me-3" style="background: #f8f9fa; max-width: 240px;">
                    <i class="bi bi-search text-muted small me-2"></i>
                    <input type="text" name="q" class="border-0 bg-transparent small" placeholder="Search courses..." style="outline: none; font-size: 0.85rem; width: 100%;">
                </form>

                <!-- Auth Actions -->
                <div class="d-flex gap-2 align-items-center">
                    <form asp-area="User" asp-controller="Auth" asp-action="StudentLogin">
                        <button class="btn btn-light px-4 fw-semibold" style="font-size: 0.9rem; border-radius: 10px;">Login</button>
                    </form>
                    <form asp-area="User" asp-controller="Auth" asp-action="StudentRegistration">
                        <button class="btn-orange px-4 py-2 fw-bold" style="font-size: 0.9rem; border-radius: 10px;">Sign Up</button>
                    </form>
                </div>
            </div>
        </div>
    </nav>


    <partial name="_Alert_Message_Partial" />

    @RenderBody()
    <!-- ========================
         FOOTER
    ======================== -->
    <footer class="footer border-top py-5">
        <div class="container-fluid px-5">
            <div class="row mb-4 g-4">

                <!-- Brand column -->
                <div class="col-md-4">
                    <a class="navbar-brand fw-bold text-dark text-decoration-none" href="#">
                        <i class="bi bi-mortarboard-fill me-2" style="color:var(--orange)"></i>SkillForge
                    </a>
                    <p class="text-muted small mt-2">
                        Practical, structured learning for real-world careers.
                    </p>
                    <div class="d-flex gap-3 mt-3">
                        <i class="bi bi-facebook fs-5" style="cursor:pointer;color:var(--muted)"></i>
                        <i class="bi bi-instagram fs-5" style="cursor:pointer;color:var(--muted)"></i>
                        <i class="bi bi-linkedin fs-5" style="cursor:pointer;color:var(--muted)"></i>
                        <i class="bi bi-youtube fs-5" style="cursor:pointer;color:var(--muted)"></i>
                    </div>
                </div>

                <div class="col">
                    <h6 class="fw-bold mb-3">Company</h6>
                    <a href="#" class="d-block mb-1">Our Story</a>
                    <a href="#" class="d-block mb-1">Careers</a>
                    <a href="#" class="d-block mb-1">Blog</a>
                    <a href="#" class="d-block mb-1">Press</a>
                </div>

                <div class="col">
                    <h6 class="fw-bold mb-3">Courses</h6>
                    <a href="/Pubic/Home/Courses" class="d-block mb-1">Web Dev</a>
                    <a href="/Pubic/Home/Courses" class="d-block mb-1">Data Science</a>
                    <a href="/Pubic/Home/Courses" class="d-block mb-1">AI & ML</a>
                    <a href="/Pubic/Home/Courses" class="d-block mb-1">Cloud</a>
                </div>

                <div class="col">
                    <h6 class="fw-bold mb-3">Support</h6>
                    <a href="#" class="d-block mb-1">Help Center</a>
                    <a href="#" class="d-block mb-1">Contact Us</a>
                    <a href="#" class="d-block mb-1">Community</a>
                    <a href="#" class="d-block mb-1">Refund Policy</a>
                </div>
            </div>
            <hr>
            <div class="d-flex justify-content-between text-muted small flex-wrap gap-2">
                <span>© 2026 SkillForge. All rights reserved.</span>
                <span>Privacy · Terms · Cookies</span>
            </div>
        </div>
    </footer>


    <!-- ========================
         JS — scroll arrows logi
    ======================== -->
    <script>
        // scroll left or right in a course row

        function scroll(rowId, dir) {
          const el = document.getElementById(rowId);
          if (!el) return;
          const card = el.querySelector('.c-card') || el.querySelector('.course-card');
          const cardWidth = card ? (card.offsetWidth + 20) : 340;
          el.scrollBy({ left: dir * cardWidth, behavior: 'smooth' });
        }

        function filterCategory(el, cat) {
          document.querySelectorAll('.category-pill').forEach(p => p.classList.remove('active'));
          el.classList.add('active');
          // filter course rows by category 
          console.log('filter:', cat);
        }

           function openMenu() {
           document.getElementById("sfMobileMenu").style.display = "flex";
        }

        function closeMenu() {
         document.getElementById("sfMobileMenu").style.display = "none";
        }

    </script>

    <script>
        // Global Auth State for UI logic
        const isAuthenticated = @(User.Identity.IsAuthenticated ? "true" : "false");
    </script>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/Alert.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
