@model string
@{
    bool isLoggedIn = !string.IsNullOrEmpty(Model);
    string currentArea = ViewContext.RouteData.Values["area"]?.ToString() ?? "User";
    string currentController = isLoggedIn ? "Home" : "Auth";
    
    bool emailSent = TempData["EmailSent"] != null ? (bool)TempData["EmailSent"] : false;
    bool otpVerified = TempData["OtpVerified"] != null ? (bool)TempData["OtpVerified"] : false;
    string forgotEmail = TempData["ForgotEmail"]?.ToString() ?? Model;
    string verifiedOtp = TempData["VerifiedOtp"]?.ToString();
    string role = (currentArea == "Instructor" ? "Instructor" : "Student");
    
    // Dynamic theme classes
    string btnClass = (currentArea == "Instructor" ? "btn-purple-save" : "btn-orange-save");
    string textClass = (currentArea == "Instructor" ? "text-purple" : "text-orange");
    string borderClass = (currentArea == "Instructor" ? "border-purple-soft" : "border-premium-orange");
}

<div class="recovery-container" style="max-width: 450px; margin: 0 auto;">
    
    <!-- Row 1: Email & Send OTP -->
    <div class="mb-3">
        <form action="/@currentArea/@currentController/@(isLoggedIn ? "SendProfileOTP" : "SendForgotOTP")" method="post">
            @Html.AntiForgeryToken()
            <label class="form-label small fw-bold">Recovery Email</label>
            <div class="input-group input-group-sm">
                <span class="input-group-text @(emailSent ? "bg-light" : "bg-white")"><i class="bi bi-envelope text-muted"></i></span>
                <input type="email" name="email" class="form-control @(emailSent ? "bg-light" : "")" 
                       value="@forgotEmail" @(emailSent ? "readonly" : "required") placeholder="Enter registered email">
                <input type="hidden" name="role" value="@role">
                <input type="hidden" name="source" value="forgot">
                
                @if (!emailSent)
                {
                    <button class="btn @btnClass text-white fw-bold px-3" type="submit">Send OTP</button>
                }
                else if (!otpVerified)
                {
                    <a href="@(isLoggedIn ? "/"+currentArea+"/Home/Profile?tab=security&view=forgot" : "/"+currentArea+"/Auth/ForgotPassword")" 
                       class="btn btn-outline-secondary btn-sm px-3 d-flex align-items-center" 
                       style="font-size: 10px; text-transform: uppercase; font-weight: 700;" title="Change Email">Edit</a>
                }
            </div>
        </form>
    </div>

    <!-- Row 2: OTP Input (Visible once email is sent or verified) -->
    <div class="mb-3" style="@(emailSent || otpVerified ? "" : "display:none;")">
        <form action="/@currentArea/@currentController/VerifyForgotOTP" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="email" value="@forgotEmail">
            <input type="hidden" name="source" value="forgot">
            <label class="form-label small fw-bold">Verification Code</label>
            <div class="input-group input-group-sm">
                <span class="input-group-text @(otpVerified ? "bg-light" : "bg-white")"><i class="bi bi-shield-check text-muted"></i></span>
                <input type="text" name="otp" class="form-control @(otpVerified ? "bg-light" : "")" 
                       placeholder="Enter 6-digit OTP" required maxlength="6" 
                       value="@verifiedOtp" @(otpVerified ? "readonly" : "")>
                @if (!otpVerified)
                {
                    <button class="btn @btnClass text-white fw-bold px-3" type="submit">Verify</button>
                }
                else
                {
                    <span class="input-group-text bg-light text-success border-start-0"><i class="bi bi-check-circle-fill"></i></span>
                }
            </div>
            @if (emailSent && !otpVerified)
            {
                <small class="text-muted d-block mt-1" style="font-size: 0.7rem;">Check your inbox for the code.</small>
            }
        </form>
    </div>

    <!-- Row 3, 4, 5: Reset Password (Visible once OTP is verified) -->
    <div id="passwordFields" style="@(otpVerified ? "" : "display:none;")" class="pt-3 border-top">
        <form action="/@currentArea/@currentController/@(isLoggedIn ? "ResetProfilePassword" : "ResetPassword")" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="email" value="@forgotEmail">
            <input type="hidden" name="otp" value="@verifiedOtp">
            <input type="hidden" name="role" value="@role">

            <div class="mb-3">
                <label class="form-label small fw-bold">New Password</label>
                <div class="input-group input-group-sm">
                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-key text-muted"></i></span>
                    <input type="password" name="newPassword" class="form-control border-start-0" placeholder="Min. 6 chars" required minlength="6" @(otpVerified ? "" : "disabled")>
                </div>
            </div>
            
            <div class="mb-4">
                <label class="form-label small fw-bold">Confirm Password</label>
                <div class="input-group input-group-sm">
                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-check2-all text-muted"></i></span>
                    <input type="password" name="confirmPassword" class="form-control border-start-0" placeholder="Repeat password" required @(otpVerified ? "" : "disabled")>
                </div>
            </div>

            <div class="text-end">
                <button type="submit" class="btn @btnClass btn-sm w-100 py-2 shadow-sm rounded-pill fw-bold" @(otpVerified ? "" : "disabled")>
                    <i class="bi bi-shield-lock-fill me-2"></i>Reset Password
                </button>
            </div>
        </form>
    </div>
</div>

<style>
    /* Purple Theme */
    .recovery-container .btn-purple-save {
        background-color: #7c3aed;
        border-color: #7c3aed;
    }
    .recovery-container .btn-purple-save:hover {
        background-color: #6d28d9;
        border-color: #6d28d9;
    }

    /* Orange Theme */
    .recovery-container .btn-orange-save {
        background-color: #ff6b00;
        border-color: #ff6b00;
    }
    .recovery-container .btn-orange-save:hover {
        background-color: #e66000;
        border-color: #e66000;
    }

    .recovery-container input:focus {
        border-color: @(currentArea == "Instructor" ? "#7c3aed" : "#ff6b00");
        box-shadow: 0 0 0 0.2rem @(currentArea == "Instructor" ? "rgba(124, 58, 237, 0.15)" : "rgba(255, 107, 0, 0.15)");
    }
</style>
