@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


    <!-- ========================
         HERO SECTION
    ======================== -->

    <section class="section-padding">
        <div class="container-fluid px-5">
            <div class="row align-items-center g-5">

                <!-- Left: copy -->
                <div class="col-lg-6">

                    <!-- small label badge -->
                    <div class="trust-badge mb-3">
                        <i class="bi bi-patch-check-fill"></i> 50,000+ learners trust SkillForge
                    </div>

                    <h1 class="display-4 fw-bold lh-sm">
                        Master Skills That<br>Matter in the <span style="color:var(--orange)">Real World</span>
                    </h1>

                    <p class="fs-5 text-muted mt-3">
                        Learn through practical, structured courses designed by industry experts.
                        Build a portfolio. Get hired.
                    </p>

                    <!-- search bar -->
                    <div class="hero-search mt-4 mb-4">
                        <i class="bi bi-search text-muted"></i>
                        <input type="text" placeholder="Search courses, topics, skills…">
                        <button class="btn-orange px-4 py-2" style="border-radius:8px">Search</button>
                    </div>

                    <!-- CTA buttons -->
                    <div class="d-flex gap-3 flex-wrap">
                        <button class="btn-orange btn-lg">Browse Courses</button>
                        <button class="btn-orange-outline btn-lg">Free Demo</button>
                    </div>

                    <!-- quick links below CTA -->
                    <div class="mt-3 d-flex gap-3 flex-wrap">
                        <span class="text-muted small">Popular:</span>
                        <a href="#" class="small" style="color:var(--orange);text-decoration:none">Python</a>
                        <a href="#" class="small" style="color:var(--orange);text-decoration:none">React</a>
                        <a href="#" class="small" style="color:var(--orange);text-decoration:none">Machine Learning</a>
                        <a href="#" class="small" style="color:var(--orange);text-decoration:none">Cloud</a>
                    </div>
                </div>

                <!-- Right: image -->
                <div class="col-lg-6">
                    <img class="w-100 hero-img"
                         src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?w=900"
                         alt="Students learning">
                </div>

            </div>
        </div>
    </section>


    <!-- ========================
         STATS BAR
    ======================== -->
    <section class="bg-light py-5 border-top border-bottom">
        <div class="container-fluid px-5">
            <div class="row text-center g-3">

                <div class="col stat-box">
                    <i class="bi bi-people-fill"></i>
                    <h3 class="fw-bold mt-2 mb-0">50,000+</h3>
                    <p class="text-muted mb-0">Students</p>
                </div>
                <div class="col stat-box">
                    <i class="bi bi-book-fill"></i>
                    <h3 class="fw-bold mt-2 mb-0">200+</h3>
                    <p class="text-muted mb-0">Courses</p>
                </div>
                <div class="col stat-box">
                    <i class="bi bi-award-fill"></i>
                    <h3 class="fw-bold mt-2 mb-0">150+</h3>
                    <p class="text-muted mb-0">Expert Mentors</p>
                </div>
                <div class="col stat-box">
                    <i class="bi bi-trophy-fill"></i>
                    <h3 class="fw-bold mt-2 mb-0">10,000+</h3>
                    <p class="text-muted mb-0">Certificates</p>
                </div>
                <div class="col stat-box">
                    <i class="bi bi-star-fill"></i>
                    <h3 class="fw-bold mt-2 mb-0">4.8★</h3>
                    <p class="text-muted mb-0">Avg. Rating</p>
                </div>

            </div>
        </div>
    </section>


    <!-- ========================
         CATEGORIES FILTER BAR
         clicking pill =  filter course rows by category
    ======================== -->
    <section class="pt-5 pb-2">
        <div class="container-fluid px-5">

            <div class="text-center mb-4">
                <span class="section-label">EXPLORE</span>
                <h2 class="fw-bold">Browse by Category</h2>
                <p class="text-muted">Find what suits you best</p>
            </div>

            <!-- horizontally scrollable pill row -->
            <div class="d-flex gap-2 flex-wrap justify-content-center">
                <!-- active = currently selected, rest = default -->
                <button class="category-pill active" onclick="filterCategory(this,'all')">
                    <i class="bi bi-grid me-1"></i> All
                </button>
                <button class="category-pill" onclick="filterCategory(this,'webdev')">
                    <i class="bi bi-code-slash me-1"></i> Web Dev
                </button>
                <button class="category-pill" onclick="filterCategory(this,'ai')">
                    <i class="bi bi-robot me-1"></i> AI & ML
                </button>
                <button class="category-pill" onclick="filterCategory(this,'cloud')">
                    <i class="bi bi-cloud me-1"></i> Cloud
                </button>
                <button class="category-pill" onclick="filterCategory(this,'data')">
                    <i class="bi bi-bar-chart me-1"></i> Data Science
                </button>
                <button class="category-pill" onclick="filterCategory(this,'mobile')">
                    <i class="bi bi-phone me-1"></i> Mobile Dev
                </button>
                <button class="category-pill" onclick="filterCategory(this,'design')">
                    <i class="bi bi-palette me-1"></i> UI/UX Design
                </button>
                <button class="category-pill" onclick="filterCategory(this,'devops')">
                    <i class="bi bi-gear me-1"></i> DevOps
                </button>
                <button class="category-pill" onclick="filterCategory(this,'cyber')">
                    <i class="bi bi-shield me-1"></i> Cybersecurity
                </button>
            </div>

        </div>
    </section>


