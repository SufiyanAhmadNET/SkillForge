@model SkillForge.Models.CoursePageVM
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/courses.css" />


    <!-- ========================
         HERO SECTION
    ======================== -->

    <section class="hero-section text-center d-flex align-items-center justify-content-center">
        <div class="container-fluid px-5 position-relative z-1">
            <div class="row justify-content-center">
                <div class="col-lg-8">

                    <!-- small label badge -->
                    <div class="trust-badge mb-4 mx-auto border-light text-light" style="background: rgba(255,255,255,0.1); backdrop-filter: blur(4px);">
                        <i class="bi bi-patch-check-fill text-orange"></i> 50,000+ learners trust SkillForge
                    </div>

                    <h1 class="display-3 fw-bold lh-sm text-white mb-4">
                        Master Skills That<br>Matter in the <span style="color:var(--orange)">Real World</span>
                    </h1>

                    <p class="fs-5 text-light mb-5 mx-auto" style="max-width: 650px;">
                        Learn through practical, structured courses designed by industry experts.
                        Build a portfolio. Get hired.
                    </p>

                    <!-- CTA buttons -->
                    <div class="d-flex gap-3 justify-content-center flex-wrap">
                        <a href="/Pubic/Home/Courses" class="btn-orange btn-lg px-5 text-decoration-none">Explore Courses</a>
                        <a href="#" class="btn btn-outline-light btn-lg px-5" style="font-weight: 600; border-radius: 10px;">Watch Demo</a>
                    </div>
                    
                </div>
            </div>
        </div>
    </section>


    <!-- ========================
         STATS BAR
    ======================== -->
    <section class="bg-light py-5 border-bottom">
        <div class="container-fluid px-5">
            <div class="row text-center g-3">

                <div class="col stat-box">
                    <i class="bi bi-people-fill"></i>
                    <h3 class="fw-bold mt-2 mb-0">50,000+</h3>
                    <p class="text-muted mb-0">Students</p>
                </div>
                <div class="col stat-box">
                    <i class="bi bi-book-fill"></i>
                    <h3 class="fw-bold mt-2 mb-0">200+</h3>
                    <p class="text-muted mb-0">Courses</p>
                </div>
                <div class="col stat-box">
                    <i class="bi bi-award-fill"></i>
                    <h3 class="fw-bold mt-2 mb-0">150+</h3>
                    <p class="text-muted mb-0">Expert Mentors</p>
                </div>
                <div class="col stat-box">
                    <i class="bi bi-trophy-fill"></i>
                    <h3 class="fw-bold mt-2 mb-0">10,000+</h3>
                    <p class="text-muted mb-0">Certificates</p>
                </div>
                <div class="col stat-box">
                    <i class="bi bi-star-fill"></i>
                    <h3 class="fw-bold mt-2 mb-0">4.8★</h3>
                    <p class="text-muted mb-0">Avg. Rating</p>
                </div>

            </div>
        </div>
    </section>




    <!-- ========================
         CATEGORIES FILTER BAR
         clicking pill =  filter course rows by category
    ======================== -->
    <section class="pt-5 pb-2">
        <div class="container-fluid px-5">

            <div class="text-center mb-4">
                <span class="section-label">EXPLORE</span>
                <h2 class="fw-bold">Browse by Category</h2>
                <p class="text-muted">Find what suits you best</p>
            </div>

            <!-- horizontally scrollable pill row -->
            <div class="d-flex gap-2 flex-wrap justify-content-center">
                <!-- active = currently selected, rest = default -->
                <button class="category-pill active" onclick="filterCategory(this,'all')">
                    <i class="bi bi-grid me-1"></i> All
                </button>
                <button class="category-pill" onclick="filterCategory(this,'webdev')">
                    <i class="bi bi-code-slash me-1"></i> Web Dev
                </button>
                <button class="category-pill" onclick="filterCategory(this,'ai')">
                    <i class="bi bi-robot me-1"></i> AI & ML
                </button>
                <button class="category-pill" onclick="filterCategory(this,'cloud')">
                    <i class="bi bi-cloud me-1"></i> Cloud
                </button>
                <button class="category-pill" onclick="filterCategory(this,'data')">
                    <i class="bi bi-bar-chart me-1"></i> Data Science
                </button>
                <button class="category-pill" onclick="filterCategory(this,'mobile')">
                    <i class="bi bi-phone me-1"></i> Mobile Dev
                </button>
                <button class="category-pill" onclick="filterCategory(this,'design')">
                    <i class="bi bi-palette me-1"></i> UI/UX Design
                </button>
                <button class="category-pill" onclick="filterCategory(this,'devops')">
                    <i class="bi bi-gear me-1"></i> DevOps
                </button>
                <button class="category-pill" onclick="filterCategory(this,'cyber')">
                    <i class="bi bi-shield me-1"></i> Cybersecurity
                </button>
            </div>

        </div>
    </section>


    <!-- ========================
         COURSE ROWS SECTION    
    ======================== -->
    @{
        // Gather all unique courses from the VM to find the latest
        var allLandingCourses = Model.CategorySections
            .Where(c => c.Courses != null)
            .SelectMany(c => c.Courses)
            .Concat(Model.PopularCourses ?? new List<CourseCardVM>())
            .GroupBy(c => c.courseId)
            .Select(g => g.First())
            .ToList();

        var recentlyAdded = allLandingCourses
            .OrderByDescending(c => c.courseId)
            .Take(8)
            .ToList();

        var landingValidCategories = Model.CategorySections
            .Where(c => c.Courses != null && c.Courses.Count >= 3)
            .OrderByDescending(c => c.Courses.Count)
            .Take(2)
            .ToList();
    }
    
    <section class="py-4">

        <!-- ---- ROW 1: Recently Added ---- -->
        @if (recentlyAdded.Any())
        {
            <div class="category-section border-0 shadow-none bg-transparent">
                <div class="sec-head">
                    <div class="cat-left">
                        <span class="cat-bar"></span>
                        <h2 class="fw-bold mb-0">Recently Added</h2>
                    </div>
                    <a href="/Pubic/Home/Courses" class="text-decoration-none small fw-bold" style="color:var(--orange);">
                        See all <i class="bi bi-arrow-right"></i>
                    </a>
                </div>

                <div class="position-relative course-section-inner">
                    <button type="button" class="arr left" onclick="scrollRow('recent',-1)"><i class="bi bi-chevron-left"></i></button>
                    <button type="button" class="arr right" onclick="scrollRow('recent', 1)"><i class="bi bi-chevron-right"></i></button>

                    <div class="course-scroll" id="recent">
                        @foreach (var course in recentlyAdded)
                        {
                            <partial name="_CourseCardPartial" model="course" />
                        }
                    </div>
                </div>
            </div>
        }


        <!-- ---- DYNAMIC CATEGORY ROWS (Max 2) ---- -->
        @foreach (var category in landingValidCategories)
        {
            <div class="category-section border-0 shadow-none bg-transparent" data-cat="@category.CategoryName">
                <div class="sec-head">
                    <div class="cat-left">
                        <span class="cat-bar"></span>
                        <h2 class="fw-bold mb-0">@category.CategoryName</h2>
                    </div>
                    <a href="/Pubic/Home/Courses" class="text-decoration-none small fw-bold" style="color:var(--orange);">
                        View All <i class="bi bi-arrow-right"></i>
                    </a>
                </div>

                <div class="position-relative course-section-inner">
                    @{ var rowId = "cat-" + category.CategoryName.Replace(" ", "-").ToLower(); }
                    <button type="button" class="arr left" onclick="scrollRow('@rowId',-1)"><i class="bi bi-chevron-left"></i></button>
                    <button type="button" class="arr right" onclick="scrollRow('@rowId', 1)"><i class="bi bi-chevron-right"></i></button>
                    <div class="course-scroll" id="@rowId">
                        @foreach (var course in category.Courses)
                        {
                            <partial name="_CourseCardPartial" model="course" />
                        }
                    </div>
                </div>
            </div>
        }

        <!-- ---- EXPLORE ALL CTA ---- -->
        <div class="container-fluid px-5 text-center mt-4">
            <a href="/Pubic/Home/Courses" class="btn btn-orange btn-lg px-5 fw-bold shadow-sm" style="border-radius: 12px;">
                Explore All Courses <i class="bi bi-arrow-right ms-2"></i>
            </a>
        </div>

    </section>


