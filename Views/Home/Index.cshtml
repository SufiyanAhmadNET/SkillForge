            <p class="fs-5 opacity-75 mb-4">Join 50,000+ students already building their careers on SkillForge</p>
            
            <div class="d-flex justify-content-center gap-3 flex-wrap">
                <a asp-area="User" asp-controller="Auth" asp-action="StudentRegistration"
               class="btn btn-light btn-lg px-5"  >
                Get Started Free  </a>

             <a asp-area="Pubic" asp-controller="Home" asp-action="Courses" 
